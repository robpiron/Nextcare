function populateDropdownsRIS() {
    const doctors = DB.get('doctors');
    const staff = DB.get('staff');
    const services = DB.get('medical_services').filter(s => s.type === 'ris' || s.type === 'pacchetto');
    
    const docSelect = document.getElementById('ris-doctor');
    docSelect.innerHTML = '<option value="">-- Seleziona --</option>';
    doctors.forEach(d => {
        const s = staff.find(st => st.id === d.staff_id);
        docSelect.innerHTML += `<option value="${d.id}">Dott. ${s.last_name} (${d.specialization})</option>`;
    });

    const srvSelect = document.getElementById('ris-service');
    srvSelect.innerHTML = '<option value="">-- Seleziona --</option>';
    const doseClasses = DB.get('dose_classes') || [];
    services.forEach(s => {
        let doseLabel = '';
        if (s.dose_class_id) {
            const dc = doseClasses.find(c => c.id === s.dose_class_id);
            if (dc) {
                doseLabel = ` [Classe Dose: ${dc.code} (${dc.range_msv})]`;
            }
        }
        srvSelect.innerHTML += `<option value="${s.id}">${s.code ? `[${s.code}] ` : ''}${s.name} (${s.branch || ''})${doseLabel}</option>`;
    });

    const doseInfoDiv = document.getElementById('ris-service-dose-info');
    if (doseInfoDiv) {
        // Reset
        doseInfoDiv.style.display = 'none';
        doseInfoDiv.innerHTML = '';
        
        // Remove existing listener to avoid duplication if any
        const newSrvSelect = srvSelect.cloneNode(true);
        srvSelect.parentNode.replaceChild(newSrvSelect, srvSelect);
        
        newSrvSelect.addEventListener('change', function() {
            const srvId = parseInt(this.value);
            const selectedSrv = services.find(s => s.id === srvId);
            if (selectedSrv && selectedSrv.dose_class_id) {
                const dc = doseClasses.find(c => c.id === selectedSrv.dose_class_id);
                if (dc) {
                    doseInfoDiv.style.display = 'block';
                    doseInfoDiv.innerHTML = `\n                        <div style="margin-top: 8px; padding: 10px; background-color: var(--accent-light); border-left: 4px solid var(--accent-color); border-radius: 4px; font-size: 0.8rem; color: var(--text-main); line-height: 1.4;">\n                            <strong style="color: var(--accent-color);">D.Lgs. 101/2020: Classe di Dose ${dc.code}</strong> (${dc.range_msv})<br>\n                            <span style="font-size: 0.75rem; color: var(--text-secondary);">${dc.description}</span>\n                        </div>\n                    `;
                    return;
                }
            }
            doseInfoDiv.style.display = 'none';
            doseInfoDiv.innerHTML = '';
        });
    }

    const filterDocSelect = document.getElementById('ris-filter-doctor');
    if (filterDocSelect) {
        filterDocSelect.innerHTML = '<option value="">Tutti i medici</option>';
        doctors.forEach(d => {
            const s = staff.find(st => st.id === d.staff_id);
            if (s) {
                filterDocSelect.innerHTML += `<option value="${d.id}">Dott. ${s.last_name} (${d.specialization})</option>`;
            }
        });
    }
}

