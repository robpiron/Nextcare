// --- 19. FORM HANDLERS AND SUBMISSIONS ---
function initFormHandlers() {
    // FORM: Add/Register Patient
    document.getElementById('form-add-patient').addEventListener('submit', (e) => {
        e.preventDefault();
        const patient = {
            uuid: crypto.randomUUID ? crypto.randomUUID() : '550e8400-e29b-41d4-a716-' + Math.floor(Math.random() * 900000),
            first_name: document.getElementById('p-first-name').value,
            last_name: document.getElementById('p-last-name').value,
            tax_code: document.getElementById('p-tax-code').value.toUpperCase(),
            birth_date: document.getElementById('p-birth-date').value,
            gender: document.getElementById('p-gender').value,
            phone: document.getElementById('p-phone').value,
            email: document.getElementById('p-email').value,
            address: document.getElementById('p-address').value
        };
        
        const newPat = DB.insert('patients', patient);
        
        const consent = {
            patient_id: newPat.id,
            treatment_consent: 1,
            marketing_consent: document.getElementById('p-consent-marketing').checked ? 1 : 0,
            profiling_consent: document.getElementById('p-consent-profiling').checked ? 1 : 0,
            signed_at: new Date().toISOString()
        };
        DB.insert('patient_consents', consent);
        DB.logAudit(6, "INSERT_PATIENT", "patients", newPat.id, { tax_code: patient.tax_code });
        
        closeModal('modal-add-patient');
        document.getElementById('form-add-patient').reset();
        
        // If inline patient creation was triggered, select the patient dynamically
        if (inlinePatientTargetSelect) {
            window.setPatientSelectValue(inlinePatientTargetSelect, newPat.id);
            inlinePatientTargetSelect = null;
        }

        renderPatients();
    });

    // FORM: Add/Edit Service Setup
    document.getElementById('form-add-service').addEventListener('submit', (e) => {
        e.preventDefault();
        const editId = document.getElementById('srv-edit-id').value;
        const type = document.getElementById('srv-type').value;
        const clinicVal = document.getElementById('srv-clinic').value;
        const equipVal = document.getElementById('srv-equip').value;
        const sampleVal = document.getElementById('srv-sample').value;
        const sampleCollectionVal = document.getElementById('srv-sample-collection-type').value;
        const instrumentVal = document.getElementById('srv-lis-instrument') ? document.getElementById('srv-lis-instrument').value : '';
        const refRange = document.getElementById('srv-ref-range').value;
        const unit = document.getElementById('srv-unit').value;
        const codeVal = document.getElementById('srv-code').value.toUpperCase().trim();
        const priceVal = parseFloat(document.getElementById('srv-price').value || 0.0);
        const branchVal = document.getElementById('srv-branch').value.trim();
        const alertNote = document.getElementById('srv-alert-note').value.trim();
        
        let profitCenterVal = document.getElementById('srv-profit-center').value;
        if (!profitCenterVal) {
            if (type === 'visita') profitCenterVal = 'SPECIALISTICA';
            else if (type === 'ris') profitCenterVal = 'IMAGING';
            else if (type === 'lis') profitCenterVal = 'LABORATORIO';
            else if (type === 'pacchetto') profitCenterVal = 'DIAGNOSTICA';
        }

        // Compile LIS detailed parameters from rows
        const parameters = [];
        if (type === 'lis') {
            const paramRows = document.querySelectorAll('.srv-param-row');
            paramRows.forEach(row => {
                const pName = row.querySelector('.srv-param-name').value.trim();
                const pRange = row.querySelector('.srv-param-range').value.trim();
                const pUnit = row.querySelector('.srv-param-unit').value.trim();
                const pType = row.querySelector('.srv-param-type').value;
                if (pName) {
                    parameters.push({
                        name: pName,
                        reference_range: pRange,
                        unit: pUnit,
                        result_type: pType
                    });
                }
            });
        }

        // Compile package items from checkboxes
        const packageItems = [];
        if (type === 'pacchetto') {
            const checkedBoxes = document.querySelectorAll('.srv-package-item-checkbox:checked');
            checkedBoxes.forEach(cb => {
                packageItems.push(parseInt(cb.value));
            });
        }

        const updatedFields = {
            name: document.getElementById('srv-name').value,
            type: type,
            code: codeVal || null,
            price: priceVal,
            branch: (type === 'visita' || type === 'ris') ? branchVal : (type === 'pacchetto' ? 'Pacchetto' : 'Laboratorio'),
            clinic_id: (type === 'visita' || type === 'ris') && clinicVal ? parseInt(clinicVal) : null,
            equipment_id: type === 'ris' && equipVal ? parseInt(equipVal) : null,
            sample_type: type === 'lis' ? sampleVal : null,
            sample_collection_type_id: type === 'lis' && sampleCollectionVal ? parseInt(sampleCollectionVal) : null,
            instrument_id: type === 'lis' && instrumentVal ? parseInt(instrumentVal) : null,
            reference_range: type === 'lis' ? refRange : null,
            unit: type === 'lis' ? unit : null,
            alert_note: alertNote || null,
            profit_center: profitCenterVal || null,
            parameters: type === 'lis' ? parameters : null,
            package_items: type === 'pacchetto' ? packageItems : null
        };

        if (type === 'ris') {
            const doseClassVal = document.getElementById('srv-dose-class').value;
            if (doseClassVal) {
                updatedFields.dose_class_id = parseInt(doseClassVal);
            } else {
                updatedFields.dose_class_id = window.guessDoseClassIdByName(updatedFields.name);
            }
        }

        if (editId) {
            const srvId = parseInt(editId);
            DB.update('medical_services', srvId, updatedFields);
            DB.logAudit(6, "UPDATE_SERVICE", "medical_services", srvId, { name: updatedFields.name });
            alert("Prestazione aggiornata con successo.");
        } else {
            const newSrv = DB.insert('medical_services', updatedFields);
            DB.logAudit(6, "CREATE_SERVICE", "medical_services", newSrv.id, { name: updatedFields.name, type: type });
            alert("Nuova prestazione configurata con successo.");
        }

        closeModal('modal-add-service');
        document.getElementById('form-add-service').reset();
        toggleServiceFormFields('visita');
        renderServices();
        populateBranchFilter();
    });

    // FORM: Add/Book Appointment CUP (Multi-service & Agenda checking)
    document.getElementById('form-add-appointment').addEventListener('submit', (e) => {
        e.preventDefault();
        const appId = parseInt(document.getElementById('app-edit-id').value || 0);
        const patientId = parseInt(document.getElementById('app-patient').value);
        const doctorIdVal = document.getElementById('app-doctor').value;
        const datetime = document.getElementById('app-datetime').value;
        const notes = document.getElementById('app-notes').value;
        const duration = parseInt(document.getElementById('app-duration').value || 30);

        if (selectedCupServiceIds.length === 0) {
            alert("Errore: Aggiungere almeno una prestazione!");
            return;
        }

        const doctorId = doctorIdVal ? parseInt(doctorIdVal) : null;
        
        if (doctorId) {
            const agendas = DB.get('doctor_agendas') || [];
            const targetDateStr = datetime.split('T')[0];
            const targetDate = new Date(datetime);
            
            const docAgendas = agendas.filter(a => a.doctor_id === doctorId);
            const activeAgenda = docAgendas.find(a => targetDateStr >= a.start_date && targetDateStr <= a.end_date);

            if (!activeAgenda) {
                alert("Errore: Il medico selezionato non ha un'agenda operativa valida per questa data.");
                return;
            }

            const weekdays = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
            const activeDaysList = activeAgenda.active_days.split(',');
            if (!activeDaysList.includes(weekdays[targetDate.getDay()])) {
                alert(`Errore: Il medico non ha ore lavorative abilitate per il giorno ${weekdays[targetDate.getDay()]}.`);
                return;
            }
        } else {
            const services = DB.get('medical_services') || [];
            const chosenServices = selectedCupServiceIds.map(id => services.find(s => s.id === id));
            const hasDoctorNeededSrv = chosenServices.some(s => s.type === 'visita' || s.type === 'ris');
            if (hasDoctorNeededSrv) {
                alert("Errore: Per prenotare visite specialistiche o esami RIS è obbligatorio selezionare un medico.");
                return;
            }
        }

        if (doctorId) {
            const isBooked = (DB.get('appointments') || []).some(app => 
                app.id !== appId &&
                app.doctor_id === doctorId && 
                app.appointment_datetime === datetime && 
                app.status === 'scheduled'
            );
            if (isBooked) {
                const proceed = confirm("ALLERTA OVERBOOKING! Lo slot orario selezionato per questo medico è già occupato da un'altra prenotazione. Vuoi forzare la prenotazione in overbooking?");
                if (!proceed) {
                    return;
                }
            }
        }

        const appointmentFields = {
            patient_id: patientId,
            doctor_id: doctorId,
            appointment_datetime: datetime,
            duration_minutes: duration,
            notes: notes,
            status: 'scheduled'
        };

        if (appId) {
            DB.update('appointments', appId, appointmentFields);
            DB.logAudit(6, "RESCHEDULE_APPOINTMENT", "appointments", appId, { doctor_id: doctorId });
            
            const appServices = DB.get('appointment_services') || [];
            const remaining = appServices.filter(as => as.appointment_id !== appId);
            DB.set('appointment_services', remaining);
            
            selectedCupServiceIds.forEach(srvId => {
                DB.insert('appointment_services', {
                    appointment_id: appId,
                    service_id: srvId
                });
            });
            alert("Prenotazione aggiornata e riprogrammata con successo.");
        } else {
            const newApp = DB.insert('appointments', appointmentFields);
            selectedCupServiceIds.forEach(srvId => {
                DB.insert('appointment_services', {
                    appointment_id: newApp.id,
                    service_id: srvId
                });
            });
            DB.logAudit(6, "BOOK_APPOINTMENT", "appointments", newApp.id, { doctor_id: doctorId, services_count: selectedCupServiceIds.length });
            alert("Nuova prenotazione registrata con successo.");
        }

        const p = DB.get('patients').find(pat => pat.id === patientId);
        const pName = p ? `${p.first_name} ${p.last_name}` : 'Paziente';
        const srvsList = DB.get('medical_services');
        const chosenServices = selectedCupServiceIds.map(id => srvsList.find(s => s.id === id)).filter(Boolean);
        const srvNames = chosenServices.map(s => s.name).join(', ');
        
        let docDetails = 'Nessun medico (Laboratorio LIS)';
        if (doctorId) {
            const doc = DB.get('doctors').find(d => d.id === doctorId);
            const st = doc ? DB.get('staff').find(s => s.id === doc.staff_id) : null;
            docDetails = st ? `Dott. ${st.last_name} (${doc.specialization})` : 'Medico';
        }

        const notesArray = [];
        chosenServices.forEach(srv => {
            if (srv && srv.alert_note) {
                notesArray.push(`- ${srv.name}: ${srv.alert_note}`);
            }
        });
        const preparationNotes = notesArray.length > 0 ? `\n\n\n\nNote di preparazione:\n\n${notesArray.join('\n\n')}` : '';
        
        sendSimulatedEmail(patientId, 'new_appointment', {
            paziente: pName,
            data: new Date(datetime).toLocaleString('it-IT'),
            prestazione: srvNames,
            dettaglio: `${docDetails}${preparationNotes}`
        });
        
        closeModal('modal-add-appointment');
        document.getElementById('form-add-appointment').reset();
        selectedCupServiceIds = [];
        renderAppointments();
    });

    // FORM: Add Sample LIS
    document.getElementById('form-add-sample').addEventListener('submit', (e) => {
        e.preventDefault();
        const patientId = parseInt(document.getElementById('sam-patient').value);
        const listinoId = parseInt(document.getElementById('sam-listino').value || 1);
        const claimIdVal = document.getElementById('sam-claim').value;
        const discountVal = parseFloat(document.getElementById('sam-discount-val').value || 0);
        const discountType = document.getElementById('sam-discount-type').value;
        const requestingDoctorVal = (document.getElementById('sam-requester')?.value || '').trim();

        if (selectedLisServiceIds.length === 0) {
            alert("Selezionare almeno un esame da eseguire tramite la barra di ricerca!");
            return;
        }

        const services = DB.get('medical_services');
        const selectedServices = selectedLisServiceIds.map(id => services.find(s => s.id === id));
        const priceListItems = DB.get('price_list_items') || [];
        
        const tubeTypes = DB.get('tube_types') || [];
        const sessionUid = 'LIS-SESS-' + Date.now() + '-' + Math.floor(Math.random() * 1000);

        // Explode packages for sample collection and test assignment
        const explodedServiceIds = window.expandServices(selectedLisServiceIds);
        const executionServices = services.filter(s => explodedServiceIds.includes(s.id));

        // Group services by sample_type (only LIS items)
        const servicesByTube = {};
        executionServices.forEach(srv => {
            if (srv.type !== 'lis') return;
            const tube = srv.sample_type || "Sangue (Tappo Viola)";
            if (!servicesByTube[tube]) {
                servicesByTube[tube] = [];
            }
            servicesByTube[tube].push(srv);
        });

        let newSam = null;

        for (const [tubeType, srvs] of Object.entries(servicesByTube)) {
            const matchedTube = tubeTypes.find(t => t.name === tubeType);
            const tubeSuffix = matchedTube ? matchedTube.suffix : '000';
            const barcodeNum = getNextBarcode(tubeSuffix);

            const sample = {
                patient_id: patientId,
                barcode: barcodeNum,
                sample_type: tubeType,
                status: 'da prelevare',
                session_uid: sessionUid,
                collected_at: null,
                collected_by: null,
                report_notes: "",
                requesting_doctor: requestingDoctorVal || null
            };
            const created = DB.insert('lab_samples', sample);
            if (!newSam) {
                newSam = created; // For invoice link reference
            }

            srvs.forEach(srv => {
                if (srv.parameters && srv.parameters.length > 0) {
                    srv.parameters.forEach(p => {
                        const test = {
                            sample_id: created.id,
                            service_id: srv.id,
                            test_name: p.name,
                            result_value: null,
                            reference_range: p.reference_range || '',
                            unit: p.unit || '',
                            result_type: p.result_type || 'ALFABETICO',
                            status: 'pending',
                            verified_by: null,
                            verified_at: null
                        };
                        DB.insert('lab_tests', test);
                    });
                } else {
                    const test = {
                        sample_id: created.id,
                        service_id: srv.id,
                        test_name: srv.name,
                        result_value: null,
                        reference_range: srv.reference_range || '',
                        unit: srv.unit || '',
                        result_type: 'ALFABETICO',
                        status: 'pending',
                        verified_by: null,
                        verified_at: null
                    };
                    DB.insert('lab_tests', test);
                }
            });
            
            DB.logAudit(4, "SAMPLE_COLLECT", "lab_samples", created.id, { barcode: barcodeNum, tests_count: srvs.length, session_uid: sessionUid });
        }

        // Handle mixed services (RIS / Visite) included in the packages
        const nonLisServices = executionServices.filter(s => s.type === 'ris' || s.type === 'visita');
        let createdStudyId = null;
        if (nonLisServices.length > 0) {
            nonLisServices.forEach(srv => {
                let studyType = 'XRAY';
                if (srv.type === 'visita') studyType = 'VISIT';
                else if (srv.name.toLowerCase().includes('risonanza') || srv.name.toLowerCase().includes('mri')) studyType = 'MRI';
                else if (srv.name.toLowerCase().includes('tac') || srv.name.toLowerCase().includes('computerizzata')) studyType = 'CT';
                else if (srv.name.toLowerCase().includes('eco')) studyType = 'ULTRASOUND';

                const study = {
                    patient_id: patientId,
                    doctor_id: 2, // Default specialist
                    service_id: srv.id,
                    study_type: studyType,
                    scheduled_at: new Date().toISOString().substring(0, 16),
                    status: srv.type === 'visita' ? 'in_progress' : 'scheduled',
                    dicom_series_uid: '1.2.840.113619.2.' + Math.floor(Math.random()*9000) + '.' + Math.floor(Math.random()*900),
                    report_text: null,
                    signed_by: null,
                    signed_at: null,
                    requesting_doctor: requestingDoctorVal || null
                };
                const newStudy = DB.insert('radiology_studies', study);
                if (!createdStudyId) createdStudyId = newStudy.id;
                DB.logAudit(6, "ACCEPT_MIXED_BOOKING", "radiology_studies", newStudy.id, { type: studyType });
            });
        }

        // Calculate billing
        let subtotal = 0;
        const customRates = {};
        const inputs = document.querySelectorAll('#sam-selected-tests .sam-price-input');
        inputs.forEach(input => {
            const srvId = parseInt(input.dataset.serviceId);
            const price = parseFloat(input.value || 0) || 0;
            customRates[srvId] = price;
            subtotal += price;
        });

        // Apply discount
        let discountAmt = 0;
        if (discountType === 'percentage') {
            discountAmt = subtotal * (discountVal / 100);
        } else {
            discountAmt = discountVal;
        }
        discountAmt = Math.min(discountAmt, subtotal);
        const discountedTotal = subtotal - discountAmt;

        // Apply insurance claim copay/deductible
        let insuranceCovered = 0;
        let patientTotal = discountedTotal;
        if (claimIdVal) {
            const claim = DB.get('patient_claims').find(c => c.id === parseInt(claimIdVal));
            if (claim) {
                if (claim.deductible_type === 'percentage') {
                    patientTotal = discountedTotal * (claim.deductible_value / 100);
                    insuranceCovered = discountedTotal - patientTotal;
                } else {
                    patientTotal = Math.min(discountedTotal, claim.deductible_value);
                    insuranceCovered = discountedTotal - patientTotal;
                }
            }
        }

        // Generate invoice if subtotal > 0
        let createdInvoiceId = null;
        if (subtotal > 0) {
            let billingMode = 'single';
            if (claimIdVal) {
                const claim = DB.get('patient_claims').find(c => c.id === parseInt(claimIdVal));
                if (claim) {
                    const ins = DB.get('insurances').find(i => i.id === claim.insurance_id);
                    if (ins) {
                        billingMode = ins.billing_mode || 'single';
                    }
                }
            }

            if (billingMode === 'split' && insuranceCovered > 0) {
                // Patient invoice
                const invNumPat = getNextInvoiceNumber();
                let stampDuty = 0.00;
                let amountDue = patientTotal;
                if (patientTotal > 77.47) {
                    stampDuty = 2.00;
                    amountDue = patientTotal + 2.00;
                }
                const invPat = {
                    admission_id: null,
                    appointment_id: null,
                    sample_id: newSam ? newSam.id : null,
                    study_id: newSam ? null : (createdStudyId || null),
                    invoice_number: invNumPat,
                    issue_date: new Date().toISOString().split('T')[0],
                    subtotal: patientTotal,
                    discount_value: 0,
                    discount_type: 'flat',
                    discount_amount: 0,
                    price_list_id: listinoId,
                    claim_id: parseInt(claimIdVal),
                    insurance_covered_amount: 0,
                    stamp_duty: stampDuty,
                    amount_due: amountDue,
                    amount_paid: 0.0,
                    payment_status: 'unpaid',
                    payment_method: null,
                    paid_at: null,
                    is_insurance_invoice: false,
                    custom_rates: customRates
                };
                const insertedPat = DB.insert('invoices', invPat);
                createdInvoiceId = insertedPat.id;
                DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invNumPat, amount: amountDue, type: 'patient_split' });

                // Insurance invoice
                const invNumIns = getNextInvoiceNumber();
                const invIns = {
                    admission_id: null,
                    appointment_id: null,
                    sample_id: newSam ? newSam.id : null,
                    study_id: newSam ? null : (createdStudyId || null),
                    invoice_number: invNumIns,
                    issue_date: new Date().toISOString().split('T')[0],
                    subtotal: insuranceCovered,
                    discount_value: 0,
                    discount_type: 'flat',
                    discount_amount: 0,
                    price_list_id: listinoId,
                    claim_id: parseInt(claimIdVal),
                    insurance_covered_amount: 0,
                    stamp_duty: 0.00,
                    amount_due: insuranceCovered,
                    amount_paid: 0.0,
                    payment_status: 'unpaid',
                    payment_method: null,
                    paid_at: null,
                    is_insurance_invoice: true,
                    custom_rates: customRates
                };
                DB.insert('invoices', invIns);
                DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invNumIns, amount: insuranceCovered, type: 'insurance_split' });
            } else {
                const invoiceNum = getNextInvoiceNumber();
                let stampDuty = 0.00;
                let amountDue = patientTotal;
                if (patientTotal > 77.47) {
                    stampDuty = 2.00;
                    amountDue = patientTotal + 2.00;
                }
                const invoice = {
                    admission_id: null,
                    appointment_id: null,
                    sample_id: newSam ? newSam.id : null,
                    study_id: newSam ? null : (createdStudyId || null),
                    invoice_number: invoiceNum,
                    issue_date: new Date().toISOString().split('T')[0],
                    subtotal: subtotal,
                    discount_value: discountVal,
                    discount_type: discountType,
                    discount_amount: discountAmt,
                    price_list_id: listinoId,
                    claim_id: claimIdVal ? parseInt(claimIdVal) : null,
                    insurance_covered_amount: insuranceCovered,
                    stamp_duty: stampDuty,
                    amount_due: amountDue,
                    amount_paid: 0.0,
                    payment_status: 'unpaid',
                    payment_method: null,
                    paid_at: null,
                    is_insurance_invoice: false,
                    custom_rates: customRates
                };
                const insertedInv = DB.insert('invoices', invoice);
                createdInvoiceId = insertedInv.id;
                DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invoiceNum, amount: amountDue });
            }
        }
        
        closeModal('modal-add-sample');
        document.getElementById('form-add-sample').reset();
        selectedLisServiceIds = [];
        renderSamples();
        renderAdmissionsAndInvoices();
        window.populateRequesterDatalist();

        // Open print prompt modal
        if (newSam) {
            document.getElementById('print-prompt-sample-id').value = newSam.id;
            document.getElementById('print-prompt-barcode-label').innerText = newSam.barcode;
            openModal('modal-lis-print-prompt');
        }

        if (createdInvoiceId) {
            setTimeout(() => {
                window.promptDirectPaymentAndPrint(createdInvoiceId);
            }, 150);
        }
    });

    // FORM: Enter LIS Results (Supporting modification/edit)
    document.getElementById('form-enter-results').addEventListener('submit', (e) => {
        e.preventDefault();
        const sampleId = parseInt(document.getElementById('res-sample-id').value);
        const samples = DB.get('lab_samples') || [];
        const sam = samples.find(s => s.id === sampleId);
        if (!sam) return;

        // Find all samples in the same session
        let sessionSamples = [];
        if (sam.session_uid) {
            sessionSamples = samples.filter(s => s.session_uid === sam.session_uid && s.status !== 'suspended');
        } else {
            const patId = sam.patient_id;
            const dateStr = (sam.collected_at || sam.created_at || '').substring(0, 10);
            sessionSamples = samples.filter(s => {
                const sDateStr = (s.collected_at || s.created_at || '').substring(0, 10);
                return s.patient_id === patId && sDateStr === dateStr && !s.session_uid && s.status !== 'suspended';
            });
        }

        if (sessionSamples.length === 0) {
            sessionSamples = [sam];
        }

        const tests = DB.get('lab_tests') || [];
        let anyModified = false;
        let finalizationDone = false;

        // Check if we need doctor signature first
        const needsSignature = sessionSamples.some(s => s.status === 'validated' || s.status === 'completed');
        let signerDocId = null;
        let reportNotesHTML = '';

        if (needsSignature) {
            const signerDocIdVal = document.getElementById('lis-signer-doctor').value;
            if (!signerDocIdVal) {
                alert("Errore: Selezionare il medico firmatario prima di finalizzare il referto.");
                return;
            }
            signerDocId = parseInt(signerDocIdVal);
            reportNotesHTML = document.getElementById('lis-report-editor').innerHTML;
        }

        sessionSamples.forEach(currSam => {
            const currSamTests = tests.filter(t => t.sample_id === currSam.id);
            if (currSamTests.length === 0) return;

            if (currSam.status === 'processing' || currSam.status === 'to_validate' || currSam.status === 'validated') {
                // technician/doctor entering results
                let hasInput = false;
                currSamTests.forEach(t => {
                    const inputEl = document.getElementById(`test-input-${t.id}`);
                    if (inputEl) {
                        const inputVal = inputEl.value;
                        t.result_value = inputVal;
                        t.status = window.checkTestValueIsNormal(inputVal, t.reference_range);
                        t.verified_by = null;
                        t.verified_at = null;
                        hasInput = true;
                    }
                });
                if (hasInput) {
                    anyModified = true;
                    if (currSam.status === 'processing') {
                        DB.update('lab_samples', currSam.id, { status: 'to_validate' });
                        DB.logAudit(5, "LAB_ENTER_RESULTS", "lab_samples", currSam.id, { entered_by: 5 });
                    }
                }
            }

            if (currSam.status === 'validated' || currSam.status === 'completed') {
                // doctor signing/reporting
                const updatedSam = DB.update('lab_samples', currSam.id, {
                    status: 'completed',
                    report_notes: reportNotesHTML,
                    signed_by_doctor_id: signerDocId
                });
                DB.logAudit(5, "LAB_REFERTATION", "lab_samples", currSam.id, { signed_by_doctor_id: signerDocId });
                finalizationDone = true;

                // Trigger Email Notification
                const patient = DB.get('patients').find(p => p.id === updatedSam.patient_id);
                if (patient) {
                    const testNames = currSamTests.map(t => t.test_name).join(', ');
                    sendSimulatedEmail(patient.id, 'report_ready', {
                        paziente: `${patient.first_name} ${patient.last_name}`,
                        data: new Date().toLocaleDateString('it-IT'),
                        prestazione: testNames,
                        dettaglio: `Codice campione LIS: ${updatedSam.barcode}`
                    });
                }
            }
        });

        DB.set('lab_tests', tests);

        if (finalizationDone) {
            alert("Referto LIS finalizzato, firmato digitalmente e archiviato con successo!");
        } else if (anyModified) {
            alert("Risultati inseriti e inviati alla validazione.");
        }

        closeModal('modal-enter-results');
        renderSamples();
        if (typeof window.renderLisValidationView === 'function') {
            window.renderLisValidationView();
        }
    });

    // FORM: Request RIS
    document.getElementById('form-add-ris').addEventListener('submit', (e) => {
        e.preventDefault();
        const srvId = parseInt(document.getElementById('ris-service').value);
        const services = DB.get('medical_services');
        const srv = services.find(s => s.id === srvId);
        
        let studyType = 'XRAY';
        if (srv.name.toLowerCase().includes('risonanza') || srv.name.toLowerCase().includes('mri')) studyType = 'MRI';
        else if (srv.name.toLowerCase().includes('tac') || srv.name.toLowerCase().includes('computerizzata')) studyType = 'CT';
        else if (srv.name.toLowerCase().includes('eco')) studyType = 'ULTRASOUND';

        const doctorInputVal = document.getElementById('ris-doctor').value.trim();
        const resDoc = window.resolveDoctorFromName(doctorInputVal);
        const doctorId = resDoc.doctor_id || 2;
        const datetime = document.getElementById('ris-date').value;

        // Check if doctor has active agenda for this day
        if (doctorId) {
            const agendas = DB.get('doctor_agendas') || [];
            const targetDateStr = datetime.split('T')[0];
            const targetDate = new Date(datetime);
            
            const docAgendas = agendas.filter(a => a.doctor_id === doctorId);
            const activeAgenda = docAgendas.find(a => targetDateStr >= a.start_date && targetDateStr <= a.end_date);
            
            let outsideAgenda = false;
            if (!activeAgenda) {
                outsideAgenda = true;
            } else {
                const weekdays = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
                const activeDaysList = activeAgenda.active_days.split(',');
                if (!activeDaysList.includes(weekdays[targetDate.getDay()])) {
                    outsideAgenda = true;
                }
            }

            if (outsideAgenda) {
                const proceedOutside = confirm("Il medico selezionato non ha un'agenda operativa valida o orari lavorativi abilitati per questa data. Vuoi comunque procedere ed effettuare l'accettazione fuori agenda?");
                if (!proceedOutside) return;
            }
        }

        // Check for overbooking / slot conflicts (in both appointments and radiology_studies)
        if (doctorId) {
            const hasAppConflict = (DB.get('appointments') || []).some(app => 
                app.doctor_id === doctorId && 
                app.appointment_datetime === datetime && 
                app.status === 'scheduled'
            );
            const hasStudyConflict = (DB.get('radiology_studies') || []).some(st => 
                st.doctor_id === doctorId && 
                st.scheduled_at === datetime && 
                st.status === 'scheduled'
            );

            if (hasAppConflict || hasStudyConflict) {
                const proceedOverbooking = confirm("ALLERTA OVERBOOKING! Lo slot orario selezionato per questo medico è già occupato da un'altra prenotazione o accettazione. Vuoi forzare l'accettazione in overbooking?");
                if (!proceedOverbooking) return;
            }
        }

        const study = {
            patient_id: parseInt(document.getElementById('ris-patient').value),
            doctor_id: doctorId,
            service_id: srvId,
            study_type: studyType,
            scheduled_at: datetime,
            status: 'scheduled',
            dicom_series_uid: '1.2.840.113619.2.' + Math.floor(Math.random()*9000) + '.' + Math.floor(Math.random()*900),
            report_text: null,
            signed_by: null,
            signed_at: null,
            requesting_doctor: resDoc.requesting_doctor
        };
        
        const newStudy = DB.insert('radiology_studies', study);
        DB.logAudit(6, "RIS_REQUEST", "radiology_studies", newStudy.id, { type: study.study_type });
        
        // Auto-generate invoice for manually created RIS studies if price > 0
        const price = srv ? (Number(srv.price) || 0) : 0;
        if (price > 0) {
            const invoiceNum = getNextInvoiceNumber();
            let stampDuty = 0.00;
            let amountDue = price;
            if (price > 77.47) {
                stampDuty = 2.00;
                amountDue = price + 2.00;
            }
            const invoice = {
                admission_id: null,
                appointment_id: null,
                sample_id: null,
                study_id: newStudy.id,
                invoice_number: invoiceNum,
                issue_date: new Date().toISOString().split('T')[0],
                subtotal: price,
                discount_value: 0,
                discount_type: 'flat',
                discount_amount: 0,
                price_list_id: 1, // Default listino
                claim_id: null,
                insurance_covered_amount: 0,
                stamp_duty: stampDuty,
                amount_due: amountDue,
                amount_paid: 0.0,
                payment_status: 'unpaid',
                payment_method: null,
                paid_at: null,
                is_insurance_invoice: false,
                custom_rates: null
            };
            const inserted = DB.insert('invoices', invoice);
            DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invoiceNum, amount: amountDue, context: 'RIS_manual_study' });
            setTimeout(() => {
                window.promptDirectPaymentAndPrint(inserted.id);
            }, 150);
        }

        closeModal('modal-add-ris');
        document.getElementById('form-add-ris').reset();
        window.renderRisStudies();
        window.renderAdmissionsAndInvoices();
        window.populateRequesterDatalist();
    });

    // FORM: DICOM Report signing (Supporting modification/edit)
    document.getElementById('form-dicom-report').addEventListener('submit', (e) => {
        e.preventDefault();
        const studyId = parseInt(document.getElementById('dicom-study-id').value);
        const reportHTML = document.getElementById('dicom-report-editor').innerHTML;
        const radId = parseInt(document.getElementById('dicom-radiologist').value);
        
        if (!reportHTML.trim() || reportHTML === '<br>' || reportHTML === 'Scrivi qui il referto radiologico dell\'esame eseguito...') {
            alert("Inserire il testo del referto prima di firmare!");
            return;
        }

        const study = DB.get('radiology_studies').find(s => s.id === studyId);
        const isVisit = study && study.study_type === 'VISIT';

        const doseInput = document.getElementById('dicom-dose-value');
        let doseVal = null;
        if (doseInput && doseInput.value.trim() !== '' && !isVisit) {
            doseVal = parseFloat(doseInput.value);
            if (isNaN(doseVal)) {
                doseVal = null;
            }
        }

        const updatedStudy = DB.update('radiology_studies', studyId, {
            report_text: reportHTML,
            signed_by: radId,
            signed_at: new Date().toISOString(),
            status: 'completed',
            dose_value_msv: doseVal
        });
        
        DB.logAudit(radId, "RIS_REPORT_SIGN", "radiology_studies", studyId, { signed_by: radId });
        
        // Trigger Email Notification
        const patient = DB.get('patients').find(p => p.id === updatedStudy.patient_id);
        if (patient) {
            const srv = DB.get('medical_services').find(s => s.id === updatedStudy.service_id);
            const srvName = srv ? srv.name : updatedStudy.study_type;
            const docStaff = DB.get('staff').find(s => s.id === radId);
            const docName = docStaff ? `Firmato digitalmente da Dott. ${docStaff.last_name}` : 'Firmato digitalmente';
            
            sendSimulatedEmail(patient.id, 'report_ready', {
                paziente: `${patient.first_name} ${patient.last_name}`,
                data: new Date(updatedStudy.signed_at).toLocaleDateString('it-IT'),
                prestazione: srvName,
                dettaglio: docName
            });
        }

        closeModal('modal-dicom-viewer');
        renderRisStudies();
    });

    // FORM: Add Admission
    document.getElementById('form-add-admission').addEventListener('submit', (e) => {
        e.preventDefault();
        const claimVal = document.getElementById('adm-claim').value;
        const admission = {
            patient_id: parseInt(document.getElementById('adm-patient').value),
            department: document.getElementById('adm-dept').value,
            reason: document.getElementById('adm-reason').value,
            admission_date: new Date().toISOString(),
            discharge_date: null,
            status: 'active',
            price_list_id: parseInt(document.getElementById('adm-listino').value || 1),
            claim_id: claimVal ? parseInt(claimVal) : null,
            discount_value: parseFloat(document.getElementById('adm-discount-val').value || 0),
            discount_type: document.getElementById('adm-discount-type').value || 'percentage'
        };
        
        const newAdm = DB.insert('admissions', admission);
        DB.logAudit(6, "PATIENT_ADMIT", "admissions", newAdm.id, { department: admission.department });
        
        closeModal('modal-add-admission');
        document.getElementById('form-add-admission').reset();
        renderAdmissionsAndInvoices();
    });

    // FORM: Add Shift HRIS
    document.getElementById('form-add-shift').addEventListener('submit', (e) => {
        e.preventDefault();
        const staffId = parseInt(document.getElementById('sh-staff').value);
        const day = document.getElementById('sh-date').value;
        const start = document.getElementById('sh-start').value;
        const end = document.getElementById('sh-end').value;
        const role = document.getElementById('sh-role').value;
        
        const shift = {
            staff_id: staffId,
            start_time: `${day}T${start}`,
            end_time: `${day}T${end}`,
            role_assigned: role
        };
        
        const newShift = DB.insert('shifts', shift);
        DB.logAudit(6, "SHIFT_SCHEDULE", "shifts", newShift.id, { staff_id: staffId });
        
        closeModal('modal-add-shift');
        document.getElementById('form-add-shift').reset();
        renderStaffAndShifts();
    });

    // FORM: Add Clinic
    document.getElementById('form-add-clinic').addEventListener('submit', (e) => {
        e.preventDefault();
        const editId = document.getElementById('cli-edit-id').value;
        const clinic = {
            name: document.getElementById('cli-name').value,
            location: document.getElementById('cli-location').value,
            capacity: parseInt(document.getElementById('cli-capacity').value)
        };
        
        if (editId) {
            const cliId = parseInt(editId);
            DB.update('clinics', cliId, clinic);
            DB.logAudit(6, "UPDATE_CLINIC", "clinics", cliId, { name: clinic.name });
            alert("Ambulatorio aggiornato con successo!");
        } else {
            const newCli = DB.insert('clinics', clinic);
            DB.logAudit(6, "INSERT_CLINIC", "clinics", newCli.id, { name: clinic.name });
            alert("Nuovo ambulatorio aggiunto con successo!");
        }
        
        closeModal('modal-add-clinic');
        document.getElementById('form-add-clinic').reset();
        
        populateDropdownsServiceSetup();
        populateDropdownsEquipmentSetup();
        if (currentTab === 'clinics') renderClinicsAndEquipment();
    });

    // FORM: Add Equipment
    document.getElementById('form-add-equipment').addEventListener('submit', (e) => {
        e.preventDefault();
        const editId = document.getElementById('eq-edit-id').value;
        const clinicVal = document.getElementById('eq-clinic').value;
        const type = document.getElementById('eq-type').value.toUpperCase();
        
        const equipment = {
            clinic_id: clinicVal ? parseInt(clinicVal) : null,
            name: document.getElementById('eq-name').value,
            type: type,
            serial_number: document.getElementById('eq-serial').value,
            status: document.getElementById('eq-status').value
        };
        
        if (type === 'LIS') {
            equipment.lis_interface_type = document.getElementById('eq-lis-interface-type').value;
            equipment.lis_import_path = document.getElementById('eq-lis-import-path').value || null;
            equipment.lis_export_path = document.getElementById('eq-lis-export-path').value || null;
            equipment.lis_file_name = document.getElementById('eq-lis-file-name').value || null;
            equipment.lis_file_format = document.getElementById('eq-lis-file-format').value || null;
            
            const socketPortVal = document.getElementById('eq-lis-socket-port').value;
            equipment.lis_socket_port = socketPortVal ? parseInt(socketPortVal) : null;
            equipment.lis_socket_format = document.getElementById('eq-lis-socket-format').value || null;
            
            // Collect transcoding rows
            const transRows = [];
            const rows = document.querySelectorAll('#eq-lis-transcoding-tbody tr');
            rows.forEach(r => {
                const rowType = r.querySelector('.trans-type-select').value;
                const rowTarget = r.querySelector('.trans-target-select').value;
                const rowInstCode = r.querySelector('.trans-instrument-code').value;
                
                if (rowType === 'service') {
                    transRows.push({
                        nc_type: 'service',
                        nc_code: rowTarget,
                        instrument_code: rowInstCode
                    });
                } else {
                    transRows.push({
                        nc_type: 'parameter',
                        nc_name: rowTarget,
                        instrument_code: rowInstCode
                    });
                }
            });
            equipment.lis_transcoding = transRows;
            
            // Clear DICOM fields for LIS
            equipment.dicom_ip = null;
            equipment.dicom_port = null;
            equipment.dicom_aetitle = null;
            equipment.dicom_modality = null;
        } else {
            // Standard equipment DICOM config
            equipment.dicom_ip = document.getElementById('eq-dicom-ip').value || null;
            const dicomPortVal = document.getElementById('eq-dicom-port').value;
            equipment.dicom_port = dicomPortVal ? parseInt(dicomPortVal) : null;
            equipment.dicom_aetitle = document.getElementById('eq-dicom-aetitle').value || null;
            equipment.dicom_modality = document.getElementById('eq-dicom-modality').value || null;
            
            // Clear LIS fields for non-LIS
            equipment.lis_interface_type = 'none';
            equipment.lis_import_path = null;
            equipment.lis_export_path = null;
            equipment.lis_file_name = null;
            equipment.lis_file_format = null;
            equipment.lis_socket_port = null;
            equipment.lis_socket_format = null;
            equipment.lis_transcoding = [];
        }
        
        if (editId) {
            const eqId = parseInt(editId);
            DB.update('equipment', eqId, equipment);
            DB.logAudit(6, "UPDATE_EQUIPMENT", "equipment", eqId, { name: equipment.name });
            alert("Apparecchiatura aggiornata con successo!");
        } else {
            const newEq = DB.insert('equipment', equipment);
            DB.logAudit(6, "INSERT_EQUIPMENT", "equipment", newEq.id, { name: equipment.name });
            alert("Nuova apparecchiatura aggiunta con successo!");
        }

        closeModal('modal-add-equipment');
        document.getElementById('form-add-equipment').reset();
        
        populateDropdownsServiceSetup();
        populateDropdownsEquipmentSetup();
        if (currentTab === 'clinics') renderClinicsAndEquipment();
    });

    // FORM: HRIS Add/Edit Staff Directory
    document.getElementById('form-add-staff').addEventListener('submit', (e) => {
        e.preventDefault();
        const editId = document.getElementById('st-edit-id').value;
        const firstName = document.getElementById('st-first-name').value;
        const lastName = document.getElementById('st-last-name').value;
        const email = document.getElementById('st-email').value;
        const phone = document.getElementById('st-phone').value;
        const role = document.getElementById('st-role').value;
        const active = document.getElementById('st-active').checked ? 1 : 0;

        const username = document.getElementById('st-username').value.trim() || null;
        const password = document.getElementById('st-password').value || null;
        const selectedProfiles = [];
        const checkedBoxes = document.querySelectorAll('input[name="st-profile-checkbox"]:checked');
        checkedBoxes.forEach(cb => selectedProfiles.push(cb.value));

        const staffFields = {
            first_name: firstName,
            last_name: lastName,
            email: email,
            phone: phone,
            role: role,
            active: active,
            username: username,
            password: password,
            profiles: selectedProfiles
        };

        let targetStaffId = null;

        if (editId) {
            targetStaffId = parseInt(editId);
            DB.update('staff', targetStaffId, staffFields);
            DB.logAudit(6, "UPDATE_STAFF", "staff", targetStaffId, { name: lastName });
            
            if (role === 'doctor') {
                const doctors = DB.get('doctors') || [];
                const doc = doctors.find(d => d.staff_id === targetStaffId);
                const spec = document.getElementById('st-specialization').value;
                const duration = parseInt(document.getElementById('st-visit-duration').value || 30);
                const stampText = document.getElementById('st-stamp-text').value;
                const enabledValidation = document.getElementById('st-enabled-validation').checked ? 1 : 0;
                const stampImage = document.getElementById('st-stamp-image-base64').value;
                
                const doctorFields = {
                    specialization: spec,
                    visit_duration_minutes: duration,
                    stamp_text: stampText,
                    enabled_for_validation: enabledValidation,
                    stamp_image: stampImage,
                    active: active
                };
                
                if (doc) {
                    DB.update('doctors', doc.id, doctorFields);
                } else {
                    doctorFields.staff_id = targetStaffId;
                    DB.insert('doctors', doctorFields);
                }
            } else {
                const doctors = DB.get('doctors') || [];
                const doc = doctors.find(d => d.staff_id === targetStaffId);
                if (doc) {
                    DB.update('doctors', doc.id, { active: 0 });
                }
            }
            alert("Operatore sanitario aggiornato correttamente.");
        } else {
            const newStaff = DB.insert('staff', staffFields);
            targetStaffId = newStaff.id;
            DB.logAudit(6, "INSERT_STAFF", "staff", targetStaffId, { name: lastName });

            if (role === 'doctor') {
                const spec = document.getElementById('st-specialization').value;
                const duration = parseInt(document.getElementById('st-visit-duration').value || 30);
                const stampText = document.getElementById('st-stamp-text').value;
                const enabledValidation = document.getElementById('st-enabled-validation').checked ? 1 : 0;
                const stampImage = document.getElementById('st-stamp-image-base64').value;
                DB.insert('doctors', {
                    staff_id: targetStaffId,
                    specialization: spec,
                    visit_duration_minutes: duration,
                    stamp_text: stampText,
                    enabled_for_validation: enabledValidation,
                    stamp_image: stampImage,
                    active: active
                });
            }
            alert("Nuovo operatore sanitario registrato con successo.");
        }

        closeModal('modal-add-staff');
        document.getElementById('form-add-staff').reset();
        renderStaffAndShifts();
        populateDropdownsHRIS();
        populateDropdownsCUP();
        populateDropdownsRIS();
    });

    // FORM: HRIS Add/Edit Doctor Agenda
    document.getElementById('form-add-agenda').addEventListener('submit', (e) => {
        e.preventDefault();
        const editId = document.getElementById('ag-edit-id').value;
        const doctorId = parseInt(document.getElementById('ag-doctor').value);
        const startDate = document.getElementById('ag-start-date').value;
        const endDate = document.getElementById('ag-end-date').value;
        const duration = parseInt(document.getElementById('ag-slot-duration').value);

        // Collect all time slots
        const timeSlots = [];
        const startInputs = document.querySelectorAll('.ag-slot-start');
        const endInputs = document.querySelectorAll('.ag-slot-end');
        for (let i = 0; i < startInputs.length; i++) {
            if (startInputs[i].value && endInputs[i].value) {
                timeSlots.push({
                    start: startInputs[i].value,
                    end: endInputs[i].value
                });
            }
        }

        if (timeSlots.length === 0) {
            alert("Aggiungere almeno una fascia oraria valida per l'agenda!");
            return;
        }

        // Sort time slots chronologically by start time
        timeSlots.sort((a, b) => a.start.localeCompare(b.start));

        // For legacy database compatibility: start_hour is first start, end_hour is last end
        const startHour = timeSlots[0].start;
        const endHour = timeSlots[timeSlots.length - 1].end;

        // Read checked days
        const checkedDays = [];
        const dayCheckboxes = document.querySelectorAll('input[name="ag-days"]:checked');
        dayCheckboxes.forEach(cb => checkedDays.push(cb.value));

        if (checkedDays.length === 0) {
            alert("Selezionare almeno un giorno settimanale attivo per l'agenda!");
            return;
        }

        const activeDaysStr = checkedDays.join(',');

        const agendaFields = {
            doctor_id: doctorId,
            start_date: startDate,
            end_date: endDate,
            active_days: activeDaysStr,
            slot_duration_minutes: duration,
            start_hour: startHour,
            end_hour: endHour,
            time_slots: timeSlots
        };

        let savedAgendaId = null;

        if (editId) {
            savedAgendaId = parseInt(editId);
            DB.update('doctor_agendas', savedAgendaId, agendaFields);
            DB.logAudit(6, "UPDATE_DOCTOR_AGENDA", "doctor_agendas", savedAgendaId, { doctor_id: doctorId });
            alert("Agenda operativa aggiornata con successo.");
        } else {
            const newAgenda = DB.insert('doctor_agendas', agendaFields);
            savedAgendaId = newAgenda.id;
            DB.logAudit(6, "CREATE_DOCTOR_AGENDA", "doctor_agendas", savedAgendaId, { doctor_id: doctorId });
            alert("Nuova agenda associata al medico correttamente.");
        }

        // Save agenda services
        const selectedServices = selectedAgendaServiceIds;

        const agendaServices = DB.get('doctor_agenda_services') || [];
        // Clean existing services linked to this agenda
        const remainingServices = agendaServices.filter(as => as.agenda_id !== savedAgendaId);
        
        selectedServices.forEach(srvId => {
            remainingServices.push({
                agenda_id: savedAgendaId,
                service_id: srvId
            });
        });

        DB.set('doctor_agenda_services', remainingServices);

        closeModal('modal-add-agenda');
        document.getElementById('form-add-agenda').reset();
        renderStaffAndShifts();
    });

    // FORM: Pay Invoice Custom
    document.getElementById('form-pay-invoice').addEventListener('submit', (e) => {
        e.preventDefault();
        const invoiceId = parseInt(document.getElementById('pay-invoice-id').value);
        const payDate = document.getElementById('pay-invoice-date').value;
        const payMethod = document.getElementById('pay-invoice-method').value;
        
        const invoices = DB.get('invoices');
        const inv = invoices.find(i => i.id === invoiceId);
        if (!inv) return;
        
        DB.update('invoices', invoiceId, {
            payment_status: 'paid',
            amount_paid: inv.amount_due,
            payment_method: payMethod,
            paid_at: payDate
        });
        
        DB.logAudit(6, "BILL_PAYMENT", "invoices", invoiceId, { amount: inv.amount_due, method: payMethod, date: payDate });
        
        closeModal('modal-pay-invoice');
        
        // Refresh depending on where we are
        if (currentTab === 'admission') {
            renderAdmissionsAndInvoices();
        } else if (currentTab === 'accounting') {
            renderAccountingDashboard();
        }
        
        alert(`Fattura ${inv.invoice_number} saldata in data ${payDate} via ${payMethod}.`);
        
        if (window.payInvoiceIsDirect) {
            if (typeof window.openInvoiceReportView === 'function') {
                window.openInvoiceReportView(invoiceId);
            }
        }
    });
}

// --- 20. MODAL UTILITIES ---
window.openModal = function(modalId) {
    document.getElementById(modalId).classList.add('active');
};

window.closeModal = function(modalId) {
    document.getElementById(modalId).classList.remove('active');
};

// --- 20b. ROLE MANAGEMENT ---
window.changeUserRole = function(role) {
    const avatarBadge = document.getElementById('user-avatar-badge');
    const loggedName = document.getElementById('user-logged-name');
    
    // Get logged-in operator details
    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const hasLoggedUser = loggedUser.id !== undefined;
    
    if (avatarBadge) {
        if (hasLoggedUser) {
            avatarBadge.innerText = `${loggedUser.first_name[0]}${loggedUser.last_name[0]}`.toUpperCase();
        } else {
            if (role === 'admin') avatarBadge.innerText = 'AD';
            else if (role === 'doctor_1') avatarBadge.innerText = 'DR';
            else if (role === 'doctor_2') avatarBadge.innerText = 'DB';
            else if (role === 'segreteria' || role === 'staff') avatarBadge.innerText = 'SE';
            else if (role === 'tsrm') avatarBadge.innerText = 'TR';
            else if (role === 'infermiere') avatarBadge.innerText = 'IN';
            else if (role === 'biologo') avatarBadge.innerText = 'BI';
        }
    }
    
    if (loggedName) {
        let label = '';
        if (role === 'admin') label = 'Amministratore';
        else if (role === 'doctor_1') label = 'Medico (Rossi)';
        else if (role === 'doctor_2') label = 'Medico (Bianchi)';
        else if (role === 'segreteria' || role === 'staff') label = 'Segreteria';
        else if (role === 'tsrm') label = 'Tecnico TSRM';
        else if (role === 'infermiere') label = 'Infermiere LIS';
        else if (role === 'biologo') label = 'Biologo LIS';
        
        if (hasLoggedUser) {
            loggedName.innerText = `${loggedUser.first_name} ${loggedUser.last_name} (${label})`;
        } else {
            loggedName.innerText = label;
        }
    }

    // Define allowed tabs for each role
    const allowedTabs = {
        admin: ['dashboard', 'core', 'cup', 'admission', 'accounting', 'lis', 'ris', 'unified-reports', 'services', 'clinics', 'hris', 'reporting-services', 'reporting-acceptances', 'notifications', 'templates', 'insurance-config', 'integrations', 'database', 'lis-logs', 'faq'],
        tsrm: ['ris', 'faq'],
        segreteria: ['dashboard', 'core', 'cup', 'admission', 'accounting', 'unified-reports', 'reporting-services', 'reporting-acceptances', 'notifications', 'faq'],
        doctor_1: ['dashboard', 'unified-reports', 'ris', 'reporting-services', 'reporting-acceptances', 'faq'],
        doctor_2: ['dashboard', 'unified-reports', 'ris', 'reporting-services', 'reporting-acceptances', 'faq'],
        infermiere: ['lis'],
        biologo: ['dashboard', 'lis', 'unified-reports', 'clinics', 'notifications', 'faq']
    };

    // Mapping legacy 'staff' value to 'segreteria' for safety
    const normalizedRole = (role === 'staff') ? 'segreteria' : role;

    // Handle visibility of navigation tabs
    const navItems = document.querySelectorAll('.nav-item');
    const allowed = allowedTabs[normalizedRole] || allowedTabs['admin'];
    
    navItems.forEach(item => {
        const tab = item.getAttribute('data-tab');
        if (allowed.includes(tab)) {
            item.style.display = 'flex';
        } else {
            item.style.display = 'none';
        }
    });

    // Handle active tab safety fallback
    const activeTab = localStorage.getItem('nextcare_active_tab') || 'dashboard';
    if (!allowed.includes(activeTab)) {
        const fallbackTab = allowed[0];
        if (typeof switchTab === 'function') {
            switchTab(fallbackTab);
        }
    }

    // Dynamic style sheet for hiding financial data for medico role
    let styleEl = document.getElementById('medico-financial-hide-style');
    if (normalizedRole === 'doctor_1' || normalizedRole === 'doctor_2') {
        if (!styleEl) {
            styleEl = document.createElement('style');
            styleEl.id = 'medico-financial-hide-style';
            styleEl.innerHTML = `\n                .financial-only, [data-financial="true"], .price-col, .total-col,\n                #dashboard-incomes-card, #dashboard-billing-card,\n                .reporting-services-amount-col, .reporting-acceptances-amount-col,\n                #reporting-services-table th:nth-child(5), #reporting-services-table td:nth-child(5),\n                #reporting-acceptances-table th:nth-child(6), #reporting-acceptances-table td:nth-child(6),\n                .invoice-price-cell, .invoice-total-cell, .card-incomes, .card-billing {\n                    display: none !important;\n                }\n            `;
            document.head.appendChild(styleEl);
        }
    } else {
        if (styleEl) styleEl.remove();
    }

    // Subtab & views visibility based on role
    
    // RIS Tab subtabs
    const btnExams = document.getElementById('btn-sub-ris-exams');
    if (btnExams) {
        if (normalizedRole === 'tsrm') {
            btnExams.style.display = 'none';
        } else {
            btnExams.style.display = '';
        }
    }

    // LIS Tab subtabs
    const lisSubtabs = document.querySelectorAll('#tab-lis .sub-tab-btn');
    lisSubtabs.forEach(btn => {
        const onclickAttr = btn.getAttribute('onclick') || '';
        if (normalizedRole === 'infermiere') {
            if (onclickAttr.includes('lis-samples')) {
                btn.style.display = '';
            } else {
                btn.style.display = 'none';
            }
        } else {
            btn.style.display = '';
        }
    });

    // Clinics Tab layouts (biologo role sees only LIS tools)
    const clinicsLayout = document.querySelector('#tab-clinics .dashboard-layout');
    const clinicsHeaderBtns = document.querySelector('#tab-clinics .section-header div:last-child');
    if (normalizedRole === 'biologo') {
        if (clinicsLayout) clinicsLayout.style.display = 'none';
        if (clinicsHeaderBtns) clinicsHeaderBtns.style.display = 'none';
    } else {
        if (clinicsLayout) clinicsLayout.style.display = '';
        if (clinicsHeaderBtns) clinicsHeaderBtns.style.display = '';
    }

    // Execute tab switches if necessary
    if (normalizedRole === 'tsrm') {
        if (typeof switchTab === 'function') switchTab('ris');
        if (typeof switchRisSubTab === 'function') switchRisSubTab('tsrm');
    } else if (normalizedRole === 'infermiere') {
        if (typeof switchTab === 'function') switchTab('lis');
        if (typeof switchLisSubTab === 'function') switchLisSubTab('lis-samples');
    } else if (normalizedRole === 'biologo') {
        if (typeof switchTab === 'function') switchTab('lis');
    } else {
        if (typeof loadActiveTab === 'function') {
            loadActiveTab();
        }
    }
};

window.initLoginSystem = function() {
    const loggedUserStr = localStorage.getItem('nextcare_logged_in_user');
    const activeProfile = localStorage.getItem('nextcare_active_profile');
    const overlay = document.getElementById('login-overlay');
    
    if (loggedUserStr && activeProfile) {
        try {
            const user = JSON.parse(loggedUserStr);
            if (overlay) overlay.style.display = 'none';
            window.applyUserPermissions(activeProfile, user);
        } catch (e) {
            console.error("Error parsing logged user session, clearing...", e);
            localStorage.removeItem('nextcare_logged_in_user');
            localStorage.removeItem('nextcare_active_profile');
            if (overlay) overlay.style.display = 'flex';
        }
    } else {
        if (overlay) overlay.style.display = 'flex';
    }
};

window.applyUserPermissions = function(activeProfile, user) {
    const roleSelect = document.getElementById('user-role-select');
    if (roleSelect) {
        if (user.profiles && user.profiles.includes('admin')) {
            roleSelect.style.display = 'block';
            roleSelect.innerHTML = `\n                <option value="admin">Amministratore (Admin)</option>\n                <option value="doctor_1">Medico: Dr. Rossi</option>\n                <option value="doctor_2">Medico: Dr.ssa Bianchi</option>\n                <option value="segreteria">Segreteria</option>\n                <option value="tsrm">Tecnico TSRM</option>\n                <option value="infermiere">Infermiere</option>\n                <option value="biologo">Biologo</option>\n            `;
        } else if (user.profiles && user.profiles.length > 1) {
            roleSelect.style.display = 'block';
            roleSelect.innerHTML = user.profiles.map(p => {
                let text = p;
                let val = p;
                if (p === 'medico') {
                    val = user.id === 1 ? 'doctor_1' : (user.id === 2 ? 'doctor_2' : 'doctor_1');
                    text = 'Medico';
                } else if (p === 'tsrm') text = 'Tecnico TSRM';
                else if (p === 'infermiere') text = 'Infermiere';
                else if (p === 'biologo') text = 'Biologo';
                else if (p === 'segreteria') text = 'Segreteria';
                return `<option value="${val}">${text}</option>`;
            }).join('');
        } else {
            roleSelect.style.display = 'none';
        }
        
        let val = activeProfile;
        if (activeProfile === 'medico') {
            val = user.id === 1 ? 'doctor_1' : (user.id === 2 ? 'doctor_2' : 'doctor_1');
        }
        roleSelect.value = val;
    }
    
    let roleVal = roleSelect ? roleSelect.value : activeProfile;
    if (roleVal === 'medico') {
        roleVal = user.id === 1 ? 'doctor_1' : (user.id === 2 ? 'doctor_2' : 'doctor_1');
    }
    window.changeUserRole(roleVal);
};

window.performLogin = function() {
    const usernameInput = document.getElementById('login-username');
    const passwordInput = document.getElementById('login-password');
    const errorMsg = document.getElementById('login-error-msg');
    
    if (!usernameInput || !passwordInput) return;
    
    const username = usernameInput.value.trim();
    const password = passwordInput.value;
    
    if (errorMsg) {
        errorMsg.style.display = 'none';
        errorMsg.innerText = '';
    }
    
    const handleLoginSuccess = (user) => {
        const profiles = user.profiles || [];
        if (profiles.length === 0) {
            if (errorMsg) {
                errorMsg.style.display = 'block';
                errorMsg.innerText = "Nessun profilo abilitato per questo operatore.";
            }
            return;
        }
        
        if (profiles.length > 1) {
            const loginCard = document.getElementById('login-card');
            loginCard.innerHTML = `\n                <div class="logo-icon" style="margin: 0 auto 24px auto; width: 64px; height: 64px; font-size: 24px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">NC</div>\n                <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 8px; color: var(--text-primary); font-family: var(--font-heading);">Seleziona Profilo</h2>\n                <p style="font-size: 14px; color: var(--text-secondary); margin-bottom: 32px;">Scegli il profilo con cui vuoi accedere</p>\n                \n                <div style="text-align: left; margin-bottom: 24px;">\n                    <label for="login-profile-select" style="display: block; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); margin-bottom: 6px;">Profilo</label>\n                    <select id="login-profile-select" style="width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-surface); color: var(--text-primary); font-size: 14px; outline: none; cursor: pointer;">\n                        ${profiles.map(p => `<option value="${p}">${p.toUpperCase()}</option>`).join('')}\n                    </select>\n                </div>\n                \n                <button class="btn btn-primary" onclick="window.confirmProfileLogin(${JSON.stringify(user).replace(/"/g, '&quot;')})" style="width: 100%; padding: 14px; font-size: 15px; font-weight: 700;">Conferma</button>\n            `;
        } else {
            window.completeLogin(user, profiles[0]);
        }
    };
    
    if (window.location.port === '8001') {
        const staff = DB.get('staff') || [];
        const matched = staff.find(s => s.username === username && s.password === password && s.active === 1);
        if (matched) {
            const log = {
                staff_id: matched.id,
                action: 'LOGIN_SUCCESS',
                table_name: 'staff',
                record_id: matched.id,
                details: JSON.stringify({ username: username, status: 'success', mode: 'local' }),
                created_at: new Date().toISOString()
            };
            DB.insert('audit_logs', log);
            handleLoginSuccess(matched);
        } else {
            const log = {
                staff_id: null,
                action: 'LOGIN_FAILURE',
                table_name: 'staff',
                record_id: null,
                details: JSON.stringify({ username: username, status: 'failed', mode: 'local' }),
                created_at: new Date().toISOString()
            };
            DB.insert('audit_logs', log);
            if (errorMsg) {
                errorMsg.style.display = 'block';
                errorMsg.innerText = "Username o password non validi.";
            }
        }
    } else {
        fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password })
        })
        .then(res => {
            if (!res.ok) {
                return res.json().then(err => { throw new Error(err.error || "Errore durante il login") });
            }
            return res.json();
        })
        .then(res => {
            handleLoginSuccess(res.data);
        })
        .catch(err => {
            if (errorMsg) {
                errorMsg.style.display = 'block';
                errorMsg.innerText = err.message || "Errore di rete.";
            }
        });
    }
};

window.confirmProfileLogin = function(user) {
    const sel = document.getElementById('login-profile-select');
    if (sel) {
        window.completeLogin(user, sel.value);
    }
};

window.completeLogin = function(user, activeProfile) {
    localStorage.setItem('nextcare_logged_in_user', JSON.stringify(user));
    localStorage.setItem('nextcare_active_profile', activeProfile);
    
    const overlay = document.getElementById('login-overlay');
    if (overlay) overlay.style.display = 'none';
    
    window.applyUserPermissions(activeProfile, user);
};

window.performLogout = function() {
    localStorage.removeItem('nextcare_logged_in_user');
    localStorage.removeItem('nextcare_active_profile');
    window.location.reload();
};

// --- 21. NEW FEATURES INITIALIZATION ---
document.addEventListener('DOMContentLoaded', () => {
    try {
        initNewFeatures();
    } catch (e) {
        console.error("[NextCare Init Error] Failed to initialize NewFeatures:", e);
    }
});

function initNewFeatures() {
    // Auto-guess dose classes for existing RIS exams on startup
    try {
        const services = DB.get('medical_services') || [];
        let servicesChanged = false;
        services.forEach(srv => {
            if (srv.type === 'ris' && (srv.dose_class_id === undefined || srv.dose_class_id === null)) {
                srv.dose_class_id = window.guessDoseClassIdByName(srv.name);
                servicesChanged = true;
            }
        });
        if (servicesChanged) {
            DB.set('medical_services', services);
            console.log("[Auto-Dose] Classi di dose auto-configurate per le prestazioni RIS esistenti.");
        }
    } catch (err) {
        console.error("[Auto-Dose Error]", err);
    }

    const roleSelect = document.getElementById('user-role-select');
    if (roleSelect) {
        roleSelect.addEventListener('change', (e) => {
            let profile = e.target.value;
            if (profile === 'doctor_1' || profile === 'doctor_2') profile = 'medico';
            localStorage.setItem('nextcare_active_profile', profile);
            changeUserRole(e.target.value);
        });
    }
    
    // Check session or display login overlay
    window.initLoginSystem();
    
    // Initialize Consents Editor
    window.initializeConsentsEditor();

    // Dynamic claims dropdown for LIS prelievo and Admission
    const samPat = document.getElementById('sam-patient');
    if (samPat) {
        samPat.addEventListener('change', () => {
            updatePatientClaimsDropdown('sam-patient', 'sam-claim');
            if (typeof updateSampleCalculations === 'function') updateSampleCalculations();
        });
    }
    const admPat = document.getElementById('adm-patient');
    if (admPat) {
        admPat.addEventListener('change', () => updatePatientClaimsDropdown('adm-patient', 'adm-claim'));
    }

    // Populates price lists static dropdowns
    populatePriceListsDropdown('sam-listino');
    populatePriceListsDropdown('adm-listino');

    // Live calculations listeners for LIS sample
    const samListino = document.getElementById('sam-listino');
    if (samListino) {
        samListino.addEventListener('change', (e) => {
            const listinoId = parseInt(e.target.value || 1);
            const priceListItems = DB.get('price_list_items') || [];
            const services = DB.get('medical_services') || [];
            const inputs = document.querySelectorAll('#sam-selected-tests .sam-price-input');
            inputs.forEach(input => {
                const srvId = parseInt(input.dataset.serviceId);
                const srv = services.find(s => s.id === srvId);
                const item = priceListItems.find(p => p.price_list_id === listinoId && p.service_id === srvId);
                const price = Number(item ? item.price : (srv ? srv.price : 0)) || 0;
                input.value = price.toFixed(2);
                input.dataset.originalPrice = price;
            });
            if (typeof updateSampleCalculations === 'function') updateSampleCalculations();
        });
    }

    const samCalcIds = ['sam-claim', 'sam-discount-val', 'sam-discount-type'];
    samCalcIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.addEventListener('change', () => { if (typeof updateSampleCalculations === 'function') updateSampleCalculations(); });
            el.addEventListener('input', () => { if (typeof updateSampleCalculations === 'function') updateSampleCalculations(); });
        }
    });

    // Add filter change listeners for Reporting Services
    const srvFilterIds = ['rep-srv-filter-type', 'rep-srv-filter-status', 'rep-srv-filter-start', 'rep-srv-filter-end', 'rep-srv-filter-branch', 'rep-srv-filter-search'];
    srvFilterIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.addEventListener('input', renderReportingServices);
            el.addEventListener('change', renderReportingServices);
        }
    });

    // Add filter change listeners for Reporting Acceptances
    const accFilterIds = ['rep-acc-filter-type', 'rep-acc-filter-start', 'rep-acc-filter-end', 'rep-acc-filter-listino', 'rep-acc-filter-payment', 'rep-acc-filter-search'];
    accFilterIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.addEventListener('input', renderReportingAcceptances);
            el.addEventListener('change', renderReportingAcceptances);
        }
    });

    // Attach form submit handlers
    const checkinForm = document.getElementById('form-checkin-appointment');
    if (checkinForm) {
        checkinForm.addEventListener('submit', handleCheckinSubmit);
    }
    const claimForm = document.getElementById('form-add-claim');
    if (claimForm) {
        claimForm.addEventListener('submit', handleAddClaimSubmit);
    }
    const editInvForm = document.getElementById('form-edit-invoice');
    if (editInvForm) {
        editInvForm.addEventListener('submit', handleEditInvoiceSubmit);
    }
    const smtpSettingsForm = document.getElementById('form-smtp-settings');
    if (smtpSettingsForm) {
        smtpSettingsForm.addEventListener('submit', handleSmtpSettingsSubmit);
    }

    // Setup Edit Invoice paid status changes to show/hide method & date
    const editInvStatus = document.getElementById('edit-invoice-status');
    if (editInvStatus) {
        editInvStatus.addEventListener('change', () => {
            const methodGrp = document.getElementById('edit-invoice-method-group');
            const paidDateGrp = document.getElementById('edit-invoice-paid-date-group');
            if (editInvStatus.value === 'paid') {
                if (methodGrp) methodGrp.style.display = 'block';
                if (paidDateGrp) paidDateGrp.style.display = 'block';
            } else {
                if (methodGrp) methodGrp.style.display = 'none';
                if (paidDateGrp) paidDateGrp.style.display = 'none';
            }
        });
    }

    // Populate SMTP settings config values from DB
    const settings = DB.get('email_settings') || {};
    const smtpM365 = document.getElementById('smtp-use-m365');
    if (smtpM365) smtpM365.checked = settings.smtp_use_m365 === 1;
    const smtpHost = document.getElementById('smtp-host');
    if (smtpHost) smtpHost.value = settings.smtp_host || 'smtp.office365.com';
    const smtpPort = document.getElementById('smtp-port');
    if (smtpPort) smtpPort.value = settings.smtp_port || 587;
    const smtpSecurity = document.getElementById('smtp-security');
    if (smtpSecurity) smtpSecurity.value = settings.smtp_security || 'starttls';
    const smtpAuth = document.getElementById('smtp-auth');
    if (smtpAuth) smtpAuth.value = settings.smtp_auth || 'login';
    const smtpIgnoreCert = document.getElementById('smtp-ignore-cert');
    if (smtpIgnoreCert) smtpIgnoreCert.checked = settings.smtp_ignore_cert === 1;
    const smtpSenderName = document.getElementById('smtp-sender-name');
    if (smtpSenderName) smtpSenderName.value = settings.smtp_sender_name || 'Clinica NextCare';
    const smtpSenderEmail = document.getElementById('smtp-sender-email');
    if (smtpSenderEmail) smtpSenderEmail.value = settings.smtp_sender_email || 'notifiche@nextcare.it';
    const smtpUser = document.getElementById('smtp-user');
    if (smtpUser) smtpUser.value = settings.smtp_user || 'notifiche@nextcare.it';
    const smtpPass = document.getElementById('smtp-pass');
    if (smtpPass) smtpPass.value = settings.smtp_pass || 'm365securetokenpass';

    if (smtpM365) {
        smtpM365.addEventListener('change', () => {
            if (smtpM365.checked) {
                if (smtpHost) smtpHost.value = 'smtp.office365.com';
                if (smtpPort) smtpPort.value = 587;
                if (smtpSecurity) smtpSecurity.value = 'starttls';
                if (smtpAuth) smtpAuth.value = 'login';
                if (typeof window.toggleSmtpAuthFields === 'function') {
                    window.toggleSmtpAuthFields();
                }
            }
        });
    }

    // Toggle credentials group and required attributes based on authentication type
    if (typeof window.toggleSmtpAuthFields === 'function') {
        window.toggleSmtpAuthFields();
    }

    // Calendar date select initial value
    const calDateSelect = document.getElementById('cal-date-select');
    if (calDateSelect) {
        calDateSelect.addEventListener('change', () => {
            if (typeof window.renderCalendarGrid === 'function') {
                window.renderCalendarGrid();
            }
        });
    }

    // Dynamic tube types dropdown for services form
    window.ensureAllTubeTypesExist();
    populateTubeTypesDropdown('srv-sample');
    if (typeof window.renderTubesTable === 'function') {
        window.renderTubesTable();
    }

    // Attach new configurations form submit handlers
    const insForm = document.getElementById('form-add-insurance');
    if (insForm) {
        insForm.addEventListener('submit', handleAddInsuranceSubmit);
    }
    const tubeForm = document.getElementById('form-add-tube-type');
    if (tubeForm) {
        tubeForm.addEventListener('submit', handleAddTubeTypeSubmit);
    }

    const xmlExportForm = document.getElementById('form-export-lis-xml');
    if (xmlExportForm) {
        xmlExportForm.addEventListener('submit', window.exportLisRequestsXml);
    }

    const worksheetForm = document.getElementById('form-add-worksheet');
    if (worksheetForm) {
        // Clear the default inline attribute so the listener handles it
        worksheetForm.removeAttribute('onsubmit');
        worksheetForm.addEventListener('submit', window.handleWorksheetSubmit);
    }
    
    // Seed default LIS worksheet if empty
    const worksheets = DB.get('lis_worksheets') || [];
    if (worksheets.length === 0) {
        const services = DB.get('medical_services') || [];
        const lisSrvs = services.filter(s => s.type === 'lis').map(s => s.id);
        if (lisSrvs.length > 0) {
            worksheets.push({
                id: 1,
                name: "Chimica Clinica",
                service_ids: lisSrvs.slice(0, 3) // Take up to 3 LIS services
            });
            DB.set('lis_worksheets', worksheets);
        }
    }

    if (typeof window.renderWorksheetsTable === 'function') {
        window.renderWorksheetsTable();
    }

    // Dynamic resizing / section display on typing 'LIS' in equipment type
    const eqTypeInput = document.getElementById('eq-type');
    if (eqTypeInput) {
        eqTypeInput.addEventListener('input', (e) => {
            const isLis = e.target.value.trim().toUpperCase() === 'LIS';
            const dicomSection = document.getElementById('equipment-dicom-section');
            const lisConnSection = document.getElementById('equipment-lis-connection-section');
            const lisTransSection = document.getElementById('equipment-lis-transcoding-section');
            const modalGrid = document.getElementById('equipment-modal-grid');
            const modalBox = document.querySelector('#modal-add-equipment .modal-box');
            if (isLis) {
                if (dicomSection) dicomSection.style.display = 'none';
                if (lisConnSection) lisConnSection.style.display = 'block';
                if (lisTransSection) lisTransSection.style.display = 'block';
                if (modalGrid) modalGrid.style.gridTemplateColumns = '1fr 1.2fr';
                if (modalBox) {
                    modalBox.style.width = '1000px';
                    modalBox.style.maxWidth = '95%';
                }
                
                const interfaceType = document.getElementById('eq-lis-interface-type');
                if (interfaceType && (!interfaceType.value || interfaceType.value === '')) {
                    interfaceType.value = 'none';
                }
                if (typeof window.toggleLisInterfacingFields === 'function') {
                    window.toggleLisInterfacingFields();
                }
            } else {
                if (dicomSection) dicomSection.style.display = 'block';
                if (lisConnSection) lisConnSection.style.display = 'none';
                if (lisTransSection) lisTransSection.style.display = 'none';
                if (modalGrid) modalGrid.style.gridTemplateColumns = '1fr';
                if (modalBox) {
                    modalBox.style.width = '650px';
                    modalBox.style.maxWidth = '90%';
                }
            }
        });
    }
    
    // Initialize Integrations Settings
    if (typeof window.initIntegrationSettings === 'function') {
        window.initIntegrationSettings();
    }
}

// --- 22. DYNAMIC DROPDOWNS POPULATION ---
function populatePriceListsDropdown(selectId) {
    const el = document.getElementById(selectId);
    if (!el) return;
    const lists = DB.get('price_lists') || [];
    el.innerHTML = '';
    lists.forEach(l => {
        el.innerHTML += `<option value="${l.id}">${l.name}</option>`;
    });
}

function populateTubeTypesDropdown(selectId) {
    const el = document.getElementById(selectId);
    if (!el) return;
    const tubes = DB.get('tube_types') || [];
    el.innerHTML = '<option value="">-- Nessuna provetta / Non richiesto --</option>';
    tubes.forEach(t => {
        el.innerHTML += `<option value="${t.name}">${t.name} (Suf: ${t.suffix})</option>`;
    });
}

window.getTubeBadgeHtml = function(sampleType) {
    if (!sampleType) return '<span class="text-muted" style="font-size:0.75rem;">Senza provetta</span>';
    
    const lower = sampleType.toLowerCase();
    let bg = '#f1f5f9';
    let color = '#475569';
    let capColor = '#94a3b8'; // Default grey cap
    let liquidColor = null;   // Default no liquid
    
    if (lower.includes('viola')) {
        bg = '#f3e8ff'; color = '#701a75'; capColor = '#a855f7'; liquidColor = '#ef4444'; // Purple cap, blood liquid
    } else if (lower.includes('giallo')) {
        bg = '#fef9c3'; color = '#713f12'; capColor = '#eab308'; liquidColor = '#f59e0b'; // Yellow cap, serum liquid
    } else if (lower.includes('rosso')) {
        bg = '#fee2e2'; color = '#991b1b'; capColor = '#ef4444'; liquidColor = '#b91c1c'; // Red cap, blood liquid
    } else if (lower.includes('verde')) {
        bg = '#dcfce7'; color = '#166534'; capColor = '#22c55e'; liquidColor = '#ef4444'; // Green cap, blood liquid
    } else if (lower.includes('azzurro')) {
        bg = '#e0f2fe'; color = '#075985'; capColor = '#0ea5e9'; liquidColor = '#ef4444'; // Blue cap, blood liquid
    } else if (lower.includes('grigio')) {
        bg = '#f1f5f9'; color = '#334155'; capColor = '#64748b'; liquidColor = '#ef4444'; // Grey cap, blood liquid
    } else if (lower.includes('urine') || lower.includes('urino')) {
        bg = '#fef3c7'; color = '#92400e'; capColor = '#d97706'; liquidColor = '#fde047'; // Yellow cap, urine liquid
    } else if (lower.includes('feci')) {
        bg = '#ffedd5'; color = '#9a3412'; capColor = '#b45309'; liquidColor = '#b45309'; // Brown cap, feces liquid
    } else if (lower.includes('tampone')) {
        bg = '#ccfbf1'; color = '#115e59'; capColor = '#0d9488'; liquidColor = null;      // Swab - Teal cap, empty
    } else if (lower.includes('metal')) {
        bg = '#eff6ff'; color = '#1e3a8a'; capColor = '#2563eb'; liquidColor = '#ef4444'; // Metal Free - Royal Blue cap
    }
    
    const svg = `\n        <svg viewBox="0 0 24 24" width="13" height="13" stroke="${color}" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle; margin-right: 5px; flex-shrink: 0;">\n            <!-- Liquid at the bottom of the tube -->\n            ${liquidColor ? `<path d="M8 12v5a4 4 0 1 0 8 0v-5z" fill="${liquidColor}" stroke="none" opacity="0.8" />` : ''}\n            <!-- Colored Cap -->\n            <path d="M6 3h12v3H6z" fill="${capColor}" stroke="${color}" stroke-width="2" />\n            <!-- Glass Tube -->\n            <path d="M8 6v11a4 4 0 1 0 8 0V6z" stroke="${color}" stroke-width="2" />\n            <!-- Graduation Marks -->\n            <line x1="9" y1="10" x2="15" y2="10" stroke="${color}" stroke-width="1.5" />\n            <line x1="9" y1="13" x2="13" y2="13" stroke="${color}" stroke-width="1.5" />\n        </svg>\n    `;
    
    return `\n        <span class="badge" style="background-color: ${bg}; color: ${color}; border: 1px solid rgba(0,0,0,0.05); display: inline-flex; align-items: center; font-size: 0.75rem; padding: 4px 8px; font-weight: 600; border-radius: var(--radius-sm); white-space: nowrap;">\n            ${svg}\n            <span>${sampleType}</span>\n        </span>\n    `;
};

window.ensureAllTubeTypesExist = function() {
    const services = DB.get('medical_services') || [];
    const tubeTypes = DB.get('tube_types') || [];
    
    const uniqueSampleTypes = new Set();
    services.forEach(s => {
        if (s.type === 'lis' && s.sample_type) {
            const trimmed = s.sample_type.trim();
            if (trimmed) {
                uniqueSampleTypes.add(trimmed);
            }
        }
    });

    let modified = false;
    let maxSuffix = 0;
    tubeTypes.forEach(t => {
        const parsed = parseInt(t.suffix);
        if (!isNaN(parsed) && parsed > maxSuffix) {
            maxSuffix = parsed;
        }
    });

    if (maxSuffix === 0) {
        maxSuffix = 5;
    }

    uniqueSampleTypes.forEach(stName => {
        const exists = tubeTypes.some(t => t.name.toLowerCase() === stName.toLowerCase());
        if (!exists) {
            maxSuffix++;
            const newId = tubeTypes.length > 0 ? Math.max(...tubeTypes.map(t => t.id)) + 1 : 1;
            const newTube = {
                id: newId,
                name: stName,
                suffix: String(maxSuffix).padStart(3, '0')
            };
            tubeTypes.push(newTube);
            modified = true;
        }
    });

    if (modified) {
        DB.set('tube_types', tubeTypes);
        populateTubeTypesDropdown('srv-sample');
        if (typeof renderTubesTable === 'function') {
            renderTubesTable();
        }
    }
};

function updatePatientClaimsDropdown(patientSelectId, claimSelectId) {
    const patSelect = document.getElementById(patientSelectId);
    const claimSelect = document.getElementById(claimSelectId);
    if (!patSelect || !claimSelect) return;
    
    const patientId = parseInt(patSelect.value);
    claimSelect.innerHTML = '<option value="">-- Nessuna Assicurazione (Privato) --</option>';
    if (!patientId) return;

    const claims = DB.get('patient_claims') || [];
    const insurances = DB.get('insurances') || [];
    
    const patientClaims = claims.filter(c => c.patient_id === patientId && c.status === 'open');
    patientClaims.forEach(c => {
        const ins = insurances.find(i => i.id === c.insurance_id);
        const insName = ins ? ins.name : `Assicurazione ${c.insurance_id}`;
        const desc = `${insName} (Polizza: ${c.policy_number} - Franchigia: ${c.deductible_value}${c.deductible_type === 'percentage' ? '%' : '€'})`;
        claimSelect.innerHTML += `<option value="${c.id}">${desc}</option>`;
    });
}

// --- 23. CHECK-IN / ACCEPT APPOINTMENT LOGIC ---
window.openCheckinModal = function(appId) {
    const appointments = DB.get('appointments') || [];
    const app = appointments.find(a => a.id === appId);
    if (!app) return;

    const patient = DB.get('patients').find(p => p.id === app.patient_id);
    if (!patient) return;

    document.getElementById('checkin-app-id').value = appId;
    document.getElementById('checkin-patient-name').innerText = `${patient.last_name} ${patient.first_name} (${patient.tax_code})`;

    // Populate Companies, Price Lists and Claims dropdowns
    if (typeof populateCompaniesDropdown === 'function') populateCompaniesDropdown('checkin-company');
    if (patient.company_id) {
        const checkinCo = document.getElementById('checkin-company');
        if (checkinCo) checkinCo.value = patient.company_id;
        const cos = DB.get('companies') || [];
        const co = cos.find(c => c.id == patient.company_id);
        populatePriceListsDropdown('checkin-listino');
        document.getElementById('checkin-listino').value = co && co.price_list_id ? co.price_list_id : 1;
    } else {
        const checkinCo = document.getElementById('checkin-company');
        if (checkinCo) checkinCo.value = '';
        populatePriceListsDropdown('checkin-listino');
        document.getElementById('checkin-listino').value = 1; // Privato Standard
    }

    // Get booked services list
    const appServices = DB.get('appointment_services') || [];
    const services = DB.get('medical_services') || [];
    const priceListItems = DB.get('price_list_items') || [];
    const srvIds = appServices.filter(as => as.appointment_id === appId).map(as => as.service_id);
    const booked = services.filter(sv => srvIds.includes(sv.id));

    const servicesListDiv = document.getElementById('checkin-services-list');
    servicesListDiv.innerHTML = '';
    
    const listinoId = 1; // Privato Standard initial value
    booked.forEach(srv => {
        const item = priceListItems.find(p => p && p.price_list_id === listinoId && p.service_id === srv.id);
        const currentPrice = Number(item ? item.price : (srv.price || 0)) || 0;
        servicesListDiv.innerHTML += `\n            <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.85rem; padding:4px 8px; background:var(--bg-base); border-radius:var(--radius-sm); margin-bottom:4px; border:1px solid var(--border-color); width:100%;">\n                <span><strong>[${srv.type.toUpperCase()}]</strong> ${srv.name}</span>\n                <div style="display:flex; align-items:center; gap:5px;">\n                    <span>€</span>\n                    <input type="number" step="0.01" class="form-control checkin-price-input" \n                           data-service-id="${srv.id}" data-original-price="${currentPrice}" \n                           value="${currentPrice.toFixed(2)}" \n                           style="width: 80px; padding: 2px 6px; text-align: right; border: 1px solid var(--border-color); border-radius: var(--radius-sm);">\n                </div>\n            </div>\n        `;
    });

    const inputs = servicesListDiv.querySelectorAll('.checkin-price-input');
    inputs.forEach(input => {
        input.addEventListener('change', (e) => {
            const newVal = parseFloat(e.target.value) || 0;
            const origVal = parseFloat(e.target.dataset.originalPrice) || 0;
            if (newVal !== origVal) {
                alert(`La tariffa è cambiata!\n\nPrezzo precedente: € ${origVal.toFixed(2)}\n\nNuovo prezzo: € ${newVal.toFixed(2)}`);
                e.target.dataset.originalPrice = newVal;
            }
            updateCheckinCalculations();
        });
    });

    const listinoSelect = document.getElementById('checkin-listino');
    if (listinoSelect) {
        // Remove existing listener to avoid duplicates
        const newSelect = listinoSelect.cloneNode(true);
        listinoSelect.parentNode.replaceChild(newSelect, listinoSelect);
        
        newSelect.addEventListener('change', (e) => {
            const currentListinoId = parseInt(e.target.value || 1);
            const plItems = DB.get('price_list_items') || [];
            const allSrv = DB.get('medical_services') || [];
            const checkinInputs = document.querySelectorAll('#checkin-services-list .checkin-price-input');
            checkinInputs.forEach(input => {
                const srvId = parseInt(input.dataset.serviceId);
                const srv = allSrv.find(s => s.id === srvId);
                const item = plItems.find(p => p.price_list_id === currentListinoId && p.service_id === srvId);
                const price = Number(item ? item.price : (srv ? srv.price : 0)) || 0;
                input.value = price.toFixed(2);
                input.dataset.originalPrice = price;
            });
            updateCheckinCalculations();
        });
    }

    // Handle TSRM container
    const risServices = booked.filter(s => s.type === 'ris');
    const tsrmContainer = document.getElementById('checkin-tsrm-container');
    const tsrmSelect = document.getElementById('checkin-tsrm');
    
    if (tsrmContainer && tsrmSelect) {
        if (risServices.length > 0) {
            tsrmContainer.classList.remove('hidden');
            tsrmContainer.style.display = 'block';
            tsrmSelect.innerHTML = '<option value="">-- Seleziona Tecnico TSRM --</option>';
            const staffList = DB.get('staff') || [];
            const technicians = staffList.filter(s => s.role === 'technician' && s.active === 1);
            technicians.forEach(t => {
                tsrmSelect.innerHTML += `<option value="${t.id}">${t.last_name} ${t.first_name}</option>`;
            });
            tsrmSelect.setAttribute('required', 'true');
        } else {
            tsrmContainer.classList.add('hidden');
            tsrmContainer.style.display = 'none';
            tsrmSelect.removeAttribute('required');
            tsrmSelect.innerHTML = '';
        }
    }

    // Populate Patient claims
    const claimSelect = document.getElementById('checkin-claim');
    claimSelect.innerHTML = '<option value="">-- Nessuna Assicurazione (Privato) --</option>';
    const claims = DB.get('patient_claims') || [];
    const insurances = DB.get('insurances') || [];
    const patientClaims = claims.filter(c => c.patient_id === app.patient_id && c.status === 'open');
    patientClaims.forEach(c => {
        const ins = insurances.find(i => i.id === c.insurance_id);
        const insName = ins ? ins.name : `Assicurazione ${c.insurance_id}`;
        const desc = `${insName} (Polizza: ${c.policy_number} - Franchigia: ${c.deductible_value}${c.deductible_type === 'percentage' ? '%' : '€'})`;
        claimSelect.innerHTML += `<option value="${c.id}">${desc}</option>`;
    });

    // Reset discount
    document.getElementById('checkin-discount-val').value = '';
    document.getElementById('checkin-discount-type').value = 'percentage';

    // Setup calculations triggers
    const triggerIds = ['checkin-claim', 'checkin-discount-val', 'checkin-discount-type'];
    triggerIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.removeEventListener('change', updateCheckinCalculations);
            el.addEventListener('change', updateCheckinCalculations);
            el.removeEventListener('input', updateCheckinCalculations);
            el.addEventListener('input', updateCheckinCalculations);
        }
    });

    updateCheckinCalculations();
    openModal('modal-checkin-appointment');
};

window.updateCheckinCalculations = function() {
    const appId = parseInt(document.getElementById('checkin-app-id').value);
    const claimIdVal = document.getElementById('checkin-claim').value;
    const discountVal = parseFloat(document.getElementById('checkin-discount-val').value || 0);
    const discountType = document.getElementById('checkin-discount-type').value;

    const app = DB.get('appointments').find(a => a.id === appId);
    if (!app) return;

    let subtotal = 0;
    const inputs = document.querySelectorAll('#checkin-services-list .checkin-price-input');
    inputs.forEach(input => {
        const price = parseFloat(input.value || 0) || 0;
        subtotal += price;
    });

    // Apply discount
    let discountAmt = 0;
    if (discountType === 'percentage') {
        discountAmt = subtotal * (discountVal / 100);
    } else {
        discountAmt = discountVal;
    }
    discountAmt = Math.min(discountAmt, subtotal);
    const discountedTotal = subtotal - discountAmt;

    // Apply insurance
    let insuranceCovered = 0;
    let patientTotal = discountedTotal;

    const insRow = document.getElementById('checkin-calc-insurance-row');
    if (claimIdVal) {
        const claim = DB.get('patient_claims').find(c => c.id === parseInt(claimIdVal));
        if (claim) {
            if (claim.deductible_type === 'percentage') {
                patientTotal = discountedTotal * (claim.deductible_value / 100);
                insuranceCovered = discountedTotal - patientTotal;
            } else {
                patientTotal = Math.min(discountedTotal, claim.deductible_value);
                insuranceCovered = discountedTotal - patientTotal;
            }
            if (insRow) insRow.style.display = 'flex';
        }
    } else {
        if (insRow) insRow.style.display = 'none';
    }

    let stampDuty = 0.00;
    if (patientTotal > 77.47) {
        stampDuty = 2.00;
    }

    const stampRow = document.getElementById('checkin-calc-stamp-duty-row');
    const stampEl = document.getElementById('checkin-calc-stamp-duty');
    if (stampDuty > 0) {
        if (stampRow) stampRow.style.display = 'flex';
        if (stampEl) stampEl.innerText = `€ ${stampDuty.toFixed(2)}`;
        patientTotal += stampDuty;
    } else {
        if (stampRow) stampRow.style.display = 'none';
    }

    document.getElementById('checkin-calc-subtotal').innerText = `€ ${subtotal.toFixed(2)}`;
    document.getElementById('checkin-calc-discount').innerText = `€ ${discountAmt.toFixed(2)}`;
    document.getElementById('checkin-calc-insurance').innerText = `€ ${insuranceCovered.toFixed(2)}`;
    document.getElementById('checkin-calc-total').innerText = `€ ${patientTotal.toFixed(2)}`;
};

window.openAddClaimModalFromCheckin = function() {
    const appId = parseInt(document.getElementById('checkin-app-id').value);
    const appointments = DB.get('appointments') || [];
    const app = appointments.find(a => a.id === appId);
    if (!app) return;

    const patient = DB.get('patients').find(p => p.id === app.patient_id);
    if (!patient) return;

    // Reset form BEFORE setting value to prevent wiping out inputs
    document.getElementById('form-add-claim').reset();

    document.getElementById('claim-patient-id').value = patient.id;
    document.getElementById('claim-patient-name-label').innerText = `${patient.last_name} ${patient.first_name} (${patient.tax_code})`;

    // Populate insurance dropdown
    const insSelect = document.getElementById('claim-insurance');
    insSelect.innerHTML = '<option value="">-- Seleziona Compagnia --</option>';
    const insurances = DB.get('insurances') || [];
    insurances.forEach(ins => {
        insSelect.innerHTML += `<option value="${ins.id}">${ins.name}</option>`;
    });

    openModal('modal-add-claim');
};

window.refreshClaimsDropdowns = function(patientId, selectedClaimId = null) {
    const claims = DB.get('patient_claims') || [];
    const insurances = DB.get('insurances') || [];
    const patientClaims = claims.filter(c => c.patient_id === patientId && c.status === 'open');

    const selectIds = ['checkin-claim', 'sam-claim', 'adm-claim'];
    selectIds.forEach(selectId => {
        const el = document.getElementById(selectId);
        if (el) {
            el.innerHTML = '<option value="">-- Nessuna Assicurazione (Privato) --</option>';
            patientClaims.forEach(c => {
                const ins = insurances.find(i => i.id === c.insurance_id);
                const insName = ins ? ins.name : `Assicurazione ${c.insurance_id}`;
                const desc = `${insName} (Polizza: ${c.policy_number} - Franchigia: ${c.deductible_value}${c.deductible_type === 'percentage' ? '%' : '€'})`;
                el.innerHTML += `<option value="${c.id}">${desc}</option>`;
            });
            if (selectedClaimId) {
                el.value = selectedClaimId;
            }
        }
    });
};

function handleAddClaimSubmit(e) {
    e.preventDefault();
    const patientId = parseInt(document.getElementById('claim-patient-id').value);
    const insId = parseInt(document.getElementById('claim-insurance').value);
    const policyNum = document.getElementById('claim-policy-number').value;
    const deductibleVal = parseFloat(document.getElementById('claim-deductible-val').value);
    const deductibleType = document.getElementById('claim-deductible-type').value;

    const claim = {
        patient_id: patientId,
        insurance_id: insId,
        policy_number: policyNum,
        deductible_value: deductibleVal,
        deductible_type: deductibleType,
        status: 'open'
    };

    const newClaim = DB.insert('patient_claims', claim);
    DB.logAudit(6, "CREATE_PATIENT_CLAIM", "patient_claims", newClaim.id, { policy: policyNum });

    closeModal('modal-add-claim');

    // Refresh claims lists in all modals
    window.refreshClaimsDropdowns(patientId, newClaim.id);

    // If checkin modal is active, update calculations
    const activeCheckinAppId = document.getElementById('checkin-app-id').value;
    if (activeCheckinAppId) {
        updateCheckinCalculations();
    }
    // If LIS prelievo modal calculations are active
    if (typeof updateSampleCalculations === 'function') {
        updateSampleCalculations();
    }
}

function handleCheckinSubmit(e) {
    e.preventDefault();
    const appId = parseInt(document.getElementById('checkin-app-id').value);
    const listinoId = parseInt(document.getElementById('checkin-listino').value);
    const claimIdVal = document.getElementById('checkin-claim').value;
    const discountVal = parseFloat(document.getElementById('checkin-discount-val').value || 0);
    const discountType = document.getElementById('checkin-discount-type').value;
    const requestingDoctorVal = (document.getElementById('checkin-requester')?.value || '').trim();
    const resDoc = window.resolveDoctorFromName(requestingDoctorVal);

    const appointments = DB.get('appointments') || [];
    const app = appointments.find(a => a.id === appId);
    if (!app) return;

    DB.update('appointments', appId, {
        doctor_id: resDoc.doctor_id || app.doctor_id,
        requesting_doctor: resDoc.requesting_doctor || null
    });

    const appServices = DB.get('appointment_services') || [];
    const services = DB.get('medical_services') || [];
    const priceListItems = DB.get('price_list_items') || [];
    const patients = DB.get('patients');

    const patient = patients.find(p => p.id === app.patient_id);
    const serviceIds = appServices.filter(as => as.appointment_id === appId).map(as => as.service_id);
    const bookedServices = services.filter(sv => serviceIds.includes(sv.id));

    if (bookedServices.length === 0) {
        alert("Errore: Nessuna prestazione associata a questa prenotazione.");
        return;
    }

    // Explode packages for clinical execution
    const explodedServiceIds = window.expandServices(serviceIds);
    const executionServices = services.filter(sv => explodedServiceIds.includes(sv.id));

    const lisServices = executionServices.filter(s => s.type === 'lis');
    const risServices = executionServices.filter(s => s.type === 'ris');
    const visitServices = executionServices.filter(s => s.type === 'visita');

    // TSRM Validation
    let tsrmId = null;
    if (risServices.length > 0) {
        const tsrmIdVal = document.getElementById('checkin-tsrm').value;
        if (!tsrmIdVal) {
            alert("Errore: Selezionare un tecnico TSRM prima di procedere con l'accettazione RIS.");
            return;
        }
        tsrmId = parseInt(tsrmIdVal);
    }

    let subtotal = 0;
    const customRates = {};
    const inputs = document.querySelectorAll('#checkin-services-list .checkin-price-input');
    inputs.forEach(input => {
        const srvId = parseInt(input.dataset.serviceId);
        const price = parseFloat(input.value || 0) || 0;
        customRates[srvId] = price;
        subtotal += price;
    });

    let discountAmt = 0;
    if (discountType === 'percentage') {
        discountAmt = subtotal * (discountVal / 100);
    } else {
        discountAmt = discountVal;
    }
    discountAmt = Math.min(discountAmt, subtotal);
    const discountedTotal = subtotal - discountAmt;

    let insuranceCovered = 0;
    let patientTotal = discountedTotal;
    if (claimIdVal) {
        const claim = DB.get('patient_claims').find(c => c.id === parseInt(claimIdVal));
        if (claim) {
            if (claim.deductible_type === 'percentage') {
                patientTotal = discountedTotal * (claim.deductible_value / 100);
                insuranceCovered = discountedTotal - patientTotal;
            } else {
                patientTotal = Math.min(discountedTotal, claim.deductible_value);
                insuranceCovered = discountedTotal - patientTotal;
            }
        }
    }

    let createdSample = null;
    let createdStudyIds = [];

    // LIS Acceptance
    if (lisServices.length > 0) {
        const tubeType = lisServices[0].sample_type || "Sangue intero (EDTA - Viola)";
        const tubeTypes = DB.get('tube_types') || [];
        const matchedTube = tubeTypes.find(t => t.name === tubeType);
        const tubeSuffix = matchedTube ? matchedTube.suffix : '000';
        const barcodeNum = window.getNextBarcode(tubeSuffix);
        const sessionUid = 'SESS-LIS-' + app.patient_id + '-' + Date.now();
        
        const sample = {
            patient_id: app.patient_id,
            barcode: barcodeNum,
            sample_type: tubeType,
            status: 'da prelevare',
            session_uid: sessionUid,
            collected_at: null,
            collected_by: null,
            report_notes: "",
            requesting_doctor: resDoc.requesting_doctor || null
        };
        createdSample = DB.insert('lab_samples', sample);
        
        lisServices.forEach(srv => {
            if (srv.parameters && srv.parameters.length > 0) {
                srv.parameters.forEach(p => {
                    const test = {
                        sample_id: createdSample.id,
                        service_id: srv.id,
                        test_name: p.name,
                        result_value: null,
                        reference_range: p.reference_range || '',
                        unit: p.unit || '',
                        result_type: p.result_type || 'ALFABETICO',
                        status: 'pending',
                        verified_by: null,
                        verified_at: null
                    };
                    DB.insert('lab_tests', test);
                });
            } else {
                const test = {
                    sample_id: createdSample.id,
                    service_id: srv.id,
                    test_name: srv.name,
                    result_value: null,
                    reference_range: srv.reference_range || '',
                    unit: srv.unit || '',
                    result_type: 'ALFABETICO',
                    status: 'pending',
                    verified_by: null,
                    verified_at: null
                };
                DB.insert('lab_tests', test);
            }
        });
        DB.logAudit(4, "ACCEPT_LIS_BOOKING", "lab_samples", createdSample.id, { barcode: barcodeNum, tests: lisServices.length });
    }

    // RIS Acceptance
    if (risServices.length > 0) {
        risServices.forEach(srv => {
            let studyType = 'XRAY';
            if (srv.name.toLowerCase().includes('risonanza') || srv.name.toLowerCase().includes('mri')) studyType = 'MRI';
            else if (srv.name.toLowerCase().includes('tac') || srv.name.toLowerCase().includes('computerizzata')) studyType = 'CT';
            else if (srv.name.toLowerCase().includes('eco')) studyType = 'ULTRASOUND';

            const study = {
                patient_id: app.patient_id,
                doctor_id: resDoc.doctor_id || app.doctor_id || 2,
                service_id: srv.id,
                study_type: studyType,
                scheduled_at: app.appointment_datetime,
                status: 'scheduled',
                dicom_series_uid: '1.2.840.113619.2.' + Math.floor(Math.random()*9000) + '.' + Math.floor(Math.random()*900),
                report_text: null,
                signed_by: null,
                signed_at: null,
                tsrm_id: tsrmId,
                requesting_doctor: resDoc.requesting_doctor || null
            };
            const newStudy = DB.insert('radiology_studies', study);
            createdStudyIds.push(newStudy.id);
            DB.logAudit(6, "ACCEPT_RIS_BOOKING", "radiology_studies", newStudy.id, { type: studyType, tsrm_id: tsrmId });
        });
    }

    // Visite Acceptance
    if (visitServices.length > 0) {
        visitServices.forEach(srv => {
            const study = {
                patient_id: app.patient_id,
                doctor_id: app.doctor_id || 2,
                service_id: srv.id,
                study_type: 'VISIT',
                scheduled_at: app.appointment_datetime,
                status: 'in_progress',
                dicom_series_uid: '1.2.840.113619.2.' + Math.floor(Math.random()*9000) + '.' + Math.floor(Math.random()*900),
                report_text: null,
                signed_by: null,
                signed_at: null
            };
            const newStudy = DB.insert('radiology_studies', study);
            createdStudyIds.push(newStudy.id);
            DB.logAudit(6, "ACCEPT_VISIT_BOOKING", "radiology_studies", newStudy.id, { type: 'VISIT' });
        });
    }

    DB.update('appointments', appId, { status: 'completed' });
    DB.logAudit(6, "CUP_ACCEPTANCE_CONVERTED", "appointments", appId, { sample_id: createdSample ? createdSample.id : null, studies_count: createdStudyIds.length });

    // Billing
    let finalAmountToPay = 0;
    let createdInvoiceId = null;
    if (subtotal > 0) {
        let billingMode = 'single';
        if (claimIdVal) {
            const claim = DB.get('patient_claims').find(c => c.id === parseInt(claimIdVal));
            if (claim) {
                const ins = DB.get('insurances').find(i => i.id === claim.insurance_id);
                if (ins) {
                    billingMode = ins.billing_mode || 'single';
                }
            }
        }

        if (billingMode === 'split' && insuranceCovered > 0) {
            const invNumPat = getNextInvoiceNumber();
            let stampDuty = 0.00;
            let amountDue = patientTotal;
            if (patientTotal > 77.47) {
                stampDuty = 2.00;
                amountDue = patientTotal + 2.00;
            }
            const invPat = {
                admission_id: null,
                appointment_id: appId,
                sample_id: createdSample ? createdSample.id : null,
                study_id: createdStudyIds.length > 0 ? createdStudyIds[0] : null,
                invoice_number: invNumPat,
                issue_date: new Date().toISOString().split('T')[0],
                subtotal: patientTotal,
                discount_value: 0,
                discount_type: 'flat',
                discount_amount: 0,
                price_list_id: listinoId,
                claim_id: parseInt(claimIdVal),
                insurance_covered_amount: 0,
                stamp_duty: stampDuty,
                amount_due: amountDue,
                amount_paid: 0.0,
                payment_status: 'unpaid',
                payment_method: null,
                paid_at: null,
                is_insurance_invoice: false,
                custom_rates: customRates
            };
            const insertedPat = DB.insert('invoices', invPat);
            createdInvoiceId = insertedPat.id;
            DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invNumPat, amount: amountDue, type: 'patient_split' });
            finalAmountToPay = amountDue;

            const invNumIns = getNextInvoiceNumber();
            const invIns = {
                admission_id: null,
                appointment_id: appId,
                sample_id: createdSample ? createdSample.id : null,
                study_id: createdStudyIds.length > 0 ? createdStudyIds[0] : null,
                invoice_number: invNumIns,
                issue_date: new Date().toISOString().split('T')[0],
                subtotal: insuranceCovered,
                discount_value: 0,
                discount_type: 'flat',
                discount_amount: 0,
                price_list_id: listinoId,
                claim_id: parseInt(claimIdVal),
                insurance_covered_amount: 0,
                stamp_duty: 0.00,
                amount_due: insuranceCovered,
                amount_paid: 0.0,
                payment_status: 'unpaid',
                payment_method: null,
                paid_at: null,
                is_insurance_invoice: true,
                custom_rates: customRates
            };
            DB.insert('invoices', invIns);
            DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invNumIns, amount: insuranceCovered, type: 'insurance_split' });
        } else {
            const invoiceNum = getNextInvoiceNumber();
            let stampDuty = 0.00;
            let amountDue = patientTotal;
            if (patientTotal > 77.47) {
                stampDuty = 2.00;
                amountDue = patientTotal + 2.00;
            }
            const invoice = {
                admission_id: null,
                appointment_id: appId,
                sample_id: createdSample ? createdSample.id : null,
                study_id: createdStudyIds.length > 0 ? createdStudyIds[0] : null,
                invoice_number: invoiceNum,
                issue_date: new Date().toISOString().split('T')[0],
                subtotal: subtotal,
                discount_value: discountVal,
                discount_type: discountType,
                discount_amount: discountAmt,
                price_list_id: listinoId,
                claim_id: claimIdVal ? parseInt(claimIdVal) : null,
                insurance_covered_amount: insuranceCovered,
                stamp_duty: stampDuty,
                amount_due: amountDue,
                amount_paid: 0.0,
                payment_status: 'unpaid',
                payment_method: null,
                paid_at: null,
                is_insurance_invoice: false,
                custom_rates: customRates
            };
            const insertedInv = DB.insert('invoices', invoice);
            createdInvoiceId = insertedInv.id;
            DB.logAudit(6, "AUTO_BILL_EMITTED", "invoices", null, { invoice_number: invoiceNum, amount: amountDue });
            finalAmountToPay = amountDue;
        }
    }

    closeModal('modal-checkin-appointment');

    alert(`Accettazione completata con successo!\n\n- Prenotazione completata.\n\n${createdSample ? `- Campione LIS creato con Barcode: ${createdSample.barcode}\n\n` : ''}${createdStudyIds.length > 0 ? `- Generati ${createdStudyIds.length} studi/visite in elaborazione.\n\n` : ''}- Emessa fattura non pagata di € ${finalAmountToPay.toFixed(2)} (incluso bollo se applicabile).`);

    renderAppointments();
    renderSamples();
    renderRisStudies();
    renderAdmissionsAndInvoices();
    window.populateRequesterDatalist();

    const requiredTemplates = window.evaluateRequiredConsents(app.patient_id, explodedServiceIds, resDoc.doctor_id || app.doctor_id);

    if (requiredTemplates.length > 0) {
        window.lastCheckoutConsents = requiredTemplates;
        window.lastCheckoutPatientId = app.patient_id;
        window.lastCheckoutServiceIds = explodedServiceIds;
        window.lastCheckoutDoctorId = resDoc.doctor_id || app.doctor_id;
        
        const listEl = document.getElementById('print-consents-list');
        listEl.innerHTML = '';
        requiredTemplates.forEach(tpl => {
            let ruleDesc = "Generico";
            if (tpl.scope === 'by_modality') ruleDesc = `Branca: ${tpl.modality}`;
            else if (tpl.scope === 'by_doctor') ruleDesc = "Specifico per Medico";
            else if (tpl.scope === 'gender_age') ruleDesc = `Donne Fertili (${tpl.min_age}-${tpl.max_age} anni)`;
            
            const div = document.createElement('div');
            div.style.display = 'flex';
            div.style.justifyContent = 'space-between';
            div.style.alignItems = 'center';
            div.style.padding = '12px';
            div.style.background = 'var(--bg-base)';
            div.style.border = '1px solid var(--border-color)';
            div.style.borderRadius = 'var(--radius-md)';
            
            div.innerHTML = `\n                <div>\n                    <strong style="color: var(--text-primary); font-size: 0.95rem;">${tpl.title}</strong><br>\n                    <span style="font-size: 0.75rem; color: var(--text-secondary);">${ruleDesc}</span>\n                </div>\n                <button class="btn btn-primary btn-sm" onclick="window.printPatientConsent(${tpl.id}, window.lastCheckoutPatientId, window.lastCheckoutServiceIds, window.lastCheckoutDoctorId)">\n                    <i data-lucide="printer" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px;"></i> Stampa Consenso\n                </button>\n            `;
            listEl.appendChild(div);
        });
        if (window.lucide) window.lucide.createIcons();
        
        window.pendingInvoiceIdAfterConsents = createdInvoiceId || null;
        openModal('modal-print-consents');
    } else {
        if (createdInvoiceId) {
            setTimeout(() => {
                window.promptDirectPaymentAndPrint(createdInvoiceId);
            }, 150);
        }
    }

    if (createdSample) {
        document.getElementById('print-prompt-sample-id').value = createdSample.id;
        document.getElementById('print-prompt-barcode-label').innerText = createdSample.barcode;
        openModal('modal-lis-print-prompt');
    }
}

window.openAgendasCalendar = function() {
    const todayStr = new Date().toISOString().split('T')[0];
    const dateInput = document.getElementById('cal-date-select');
    if (dateInput && !dateInput.value) {
        dateInput.value = todayStr;
    }
    window.syncFromMySQL(() => {
        renderCalendarGrid();
        openModal('modal-agendas-calendar');
    });
};

window.refreshCalendarData = function() {
    window.syncFromMySQL(() => {
        renderCalendarGrid();
    });
};

window.renderCalendarGrid = function() {
    const container = document.getElementById('calendar-visualizer-container');
    if (!container) return;

    const dateVal = document.getElementById('cal-date-select').value;
    if (!dateVal) return;

    const doctorIdVal = document.getElementById('cal-doctor-select').value;
    const doctors = DB.get('doctors') || [];
    const staff = DB.get('staff') || [];
    const agendas = DB.get('doctor_agendas') || [];
    const appointments = DB.get('appointments') || [];
    const appServices = DB.get('appointment_services') || [];
    const services = DB.get('medical_services') || [];

    if (doctorIdVal) {
        const doctorId = parseInt(doctorIdVal);
        const d = doctors.find(doc => doc.id === doctorId);
        if (!d) return;
        const s = staff.find(st => st.id === d.staff_id);
        const docName = s ? `Dr. ${s.last_name}` : `Medico ${d.id}`;

        container.style.gridTemplateColumns = `80px repeat(7, 1fr)`;
        container.innerHTML = '';

        const targetDate = new Date(dateVal);
        const day = targetDate.getDay();
        const diff = targetDate.getDate() - day + (day === 0 ? -6 : 1);
        const monday = new Date(targetDate.setDate(diff));

        const weekDates = [];
        const weekdaysIt = ["Lun", "Mar", "Mer", "Gio", "Ven", "Sab", "Dom"];
        const weekdaysEn = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

        const timeHeader = document.createElement('div');
        timeHeader.className = 'calendar-header-cell';
        timeHeader.innerText = 'Orario';
        container.appendChild(timeHeader);

        for (let i = 0; i < 7; i++) {
            const currentDate = new Date(monday);
            currentDate.setDate(monday.getDate() + i);
            const dateStr = currentDate.toISOString().split('T')[0];
            const dateDisplay = currentDate.toLocaleDateString('it-IT', { day: '2-digit', month: '2-digit' });
            
            weekDates.push({ dateStr, dayNameEn: weekdaysEn[i], dayNameIt: weekdaysIt[i] });

            const headerCell = document.createElement('div');
            headerCell.className = 'calendar-header-cell';
            headerCell.innerHTML = `<div>${weekdaysIt[i]}</div><div style="font-size: 0.7rem; font-weight: normal; color: var(--text-muted);">${dateDisplay}</div>`;
            container.appendChild(headerCell);
        }

        const docAgendas = agendas.filter(a => a.doctor_id === d.id);
        const activeAgenda = docAgendas.find(a => dateVal >= a.start_date && dateVal <= a.end_date) || docAgendas[0];

        let slotDur = 30;
        const timeSlots = [];
        
        if (activeAgenda) {
            slotDur = activeAgenda.slot_duration_minutes || 30;
            const ranges = activeAgenda.time_slots || [
                { start: activeAgenda.start_hour || '08:00', end: activeAgenda.end_hour || '14:00' }
            ];
            
            ranges.forEach(r => {
                const startParts = r.start.split(':');
                const endParts = r.end.split(':');
                const startMin = parseInt(startParts[0]) * 60 + parseInt(startParts[1] || 0);
                const endMin = parseInt(endParts[0]) * 60 + parseInt(endParts[1] || 0);
                
                let currentMinutes = startMin;
                while (currentMinutes < endMin) {
                    const hh = Math.floor(currentMinutes / 60);
                    const mm = currentMinutes % 60;
                    const timeStr = `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
                    if (!timeSlots.includes(timeStr)) {
                        timeSlots.push(timeStr);
                    }
                    currentMinutes += slotDur;
                }
            });
            timeSlots.sort();
        } else {
            let currentMinutes = 8 * 60;
            const endMinutes = 14 * 60;
            while (currentMinutes < endMinutes) {
                const hh = Math.floor(currentMinutes / 60);
                const mm = currentMinutes % 60;
                timeSlots.push(`${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`);
                currentMinutes += slotDur;
            }
        }

        timeSlots.forEach(timeStr => {
            const timeCell = document.createElement('div');
            timeCell.className = 'calendar-time-cell';
            timeCell.innerText = timeStr;
            container.appendChild(timeCell);

            weekDates.forEach(dayObj => {
                const cell = document.createElement('div');
                cell.className = 'calendar-slot-cell';

                const dayDateVal = dayObj.dateStr;
                const slotDatetime = `${dayDateVal}T${timeStr}`;

                const dayAgenda = docAgendas.find(a => dayDateVal >= a.start_date && dayDateVal <= a.end_date && a.active_days.split(',').includes(dayObj.dayNameEn));

                let inServiceForSlot = false;
                if (dayAgenda) {
                    const ranges = dayAgenda.time_slots || [
                        { start: dayAgenda.start_hour || '08:00', end: dayAgenda.end_hour || '14:00' }
                    ];
                    const parts = timeStr.split(':');
                    const slotMin = parseInt(parts[0]) * 60 + parseInt(parts[1] || 0);
                    
                    inServiceForSlot = ranges.some(r => {
                        const startParts = r.start.split(':');
                        const endParts = r.end.split(':');
                        const startMin = parseInt(startParts[0]) * 60 + parseInt(startParts[1] || 0);
                        const endMin = parseInt(endParts[0]) * 60 + parseInt(endParts[1] || 0);
                        return slotMin >= startMin && slotMin < endMin;
                    });
                }

                if (!dayAgenda || !inServiceForSlot) {
                    cell.classList.add('calendar-slot-inactive');
                    cell.innerText = 'Non in servizio';
                } else {
                    const cellBookings = appointments.filter(app => 
                        app.doctor_id === d.id && 
                        app.appointment_datetime === slotDatetime && 
                        ['scheduled', 'completed', 'no_show'].includes(app.status)
                    );

                    if (cellBookings.length > 0) {
                        cell.innerHTML = '';
                        const bookingsWrapper = document.createElement('div');
                        bookingsWrapper.style.display = 'flex';
                        bookingsWrapper.style.flexDirection = 'column';
                        bookingsWrapper.style.gap = '4px';
                        bookingsWrapper.style.width = '100%';
                        const isPast = new Date(slotDatetime) < new Date();
                        
                        cellBookings.forEach(booking => {
                            const p = DB.get('patients').find(pat => pat.id === booking.patient_id);
                            const pName = p ? `${p.last_name} ${p.first_name}` : 'Paziente';
                            const srvIds = appServices.filter(as => as.appointment_id === booking.id).map(as => as.service_id);
                            const bookedServices = services.filter(sv => srvIds.includes(sv.id));
                            const srvNames = bookedServices.map(s => s.name).join(', ') || 'Nessuna prestazione';
                            
                            let bgColor = 'rgba(37, 99, 235, 0.1)';
                            let borderColor = 'var(--primary)';
                            let textColor = 'var(--primary)';
                            let statusLabel = '';
                            
                            if (booking.status === 'completed') {
                                bgColor = 'rgba(16, 185, 129, 0.1)';
                                borderColor = 'var(--success)';
                                textColor = 'var(--success)';
                                statusLabel = ' (Eseguito)';
                            } else if (booking.status === 'no_show') {
                                bgColor = 'rgba(239, 68, 68, 0.1)';
                                borderColor = 'var(--danger)';
                                textColor = 'var(--danger)';
                                statusLabel = ' (No-Show)';
                            }
                            
                            const bookingDiv = document.createElement('div');
                            bookingDiv.className = 'calendar-slot-booked-card';
                            bookingDiv.style.background = bgColor;
                            bookingDiv.style.borderLeft = `3px solid ${borderColor}`;
                            bookingDiv.style.borderRadius = 'var(--radius-sm)';
                            bookingDiv.style.padding = '4px 6px';
                            bookingDiv.style.fontSize = '0.7rem';
                            bookingDiv.style.color = textColor;
                            bookingDiv.style.fontWeight = '500';
                            bookingDiv.style.cursor = 'pointer';
                            bookingDiv.style.boxShadow = 'var(--shadow-sm)';
                            
                            if (isPast) {
                                bookingDiv.style.opacity = '0.75';
                                bookingDiv.style.filter = 'grayscale(30%)';
                            }
                            
                            bookingDiv.innerHTML = `
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <strong>${pName}${statusLabel}</strong>
                                </div>
                                <div style="font-size:0.6rem; color:var(--text-secondary); text-overflow:ellipsis; overflow:hidden; white-space:nowrap;">${srvNames}</div>
                            `;
                            
                            bookingDiv.addEventListener('click', (ev) => {
                                ev.stopPropagation();
                                closeModal('modal-agendas-calendar');
                                window.openEditAppointmentModal(booking.id);
                            });
                            
                            bookingsWrapper.appendChild(bookingDiv);
                        });
                        
                        const overbookBtn = document.createElement('div');
                        overbookBtn.className = 'calendar-slot-free';
                        overbookBtn.style.padding = '2px';
                        overbookBtn.style.marginTop = '2px';
                        overbookBtn.style.fontSize = '0.65rem';
                        overbookBtn.innerHTML = '<i data-lucide="plus" style="width: 10px; height: 10px;"></i> Sovrapreprenotazione';
                        overbookBtn.addEventListener('click', (ev) => {
                            ev.stopPropagation();
                            closeModal('modal-agendas-calendar');
                            openAddAppointmentModal();
                            setTimeout(() => {
                                const docSelect = document.getElementById('app-doctor');
                                const dtInput = document.getElementById('app-datetime');
                                if (docSelect) { docSelect.value = d.id; findAndRenderFreeSlots(); }
                                if (dtInput) { dtInput.value = slotDatetime; syncActiveSlotBadge(); }
                            }, 200);
                        });
                        bookingsWrapper.appendChild(overbookBtn);
                        cell.appendChild(bookingsWrapper);
                    } else {
                        const freeDiv = document.createElement('div');
                        freeDiv.className = 'calendar-slot-free';
                        freeDiv.innerHTML = '<i data-lucide="plus" style="width: 12px; height: 12px; vertical-align: middle;"></i> Prenota';
                        freeDiv.addEventListener('click', () => {
                            closeModal('modal-agendas-calendar');
                            openAddAppointmentModal();
                            
                            setTimeout(() => {
                                const docSelect = document.getElementById('app-doctor');
                                const dtInput = document.getElementById('app-datetime');
                                if (docSelect) {
                                    docSelect.value = d.id;
                                    findAndRenderFreeSlots();
                                }
                                if (dtInput) {
                                    dtInput.value = slotDatetime;
                                    syncActiveSlotBadge();
                                }
                            }, 200);
                        });
                        cell.appendChild(freeDiv);
                    }
                }
                container.appendChild(cell);
            });
        });

    } else {
        const activeDoctors = doctors.filter(d => d.active === 1);
        
        container.style.gridTemplateColumns = `80px repeat(${activeDoctors.length}, 1fr)`;
        container.innerHTML = '';

        const timeHeader = document.createElement('div');
        timeHeader.className = 'calendar-header-cell';
        timeHeader.innerText = 'Orario';
        container.appendChild(timeHeader);

        activeDoctors.forEach(d => {
            const s = staff.find(st => st.id === d.staff_id);
            const docName = s ? `Dr. ${s.last_name}` : `Medico ${d.id}`;
            const headerCell = document.createElement('div');
            headerCell.className = 'calendar-header-cell';
            headerCell.innerHTML = `<div>${docName}</div><div style="font-size: 0.7rem; font-weight: normal; color: var(--text-muted);">${d.specialization}</div>`;
            container.appendChild(headerCell);
        });

        const timeSlots = [];
        const weekdays = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
        const targetDate = new Date(dateVal);
        const dayName = weekdays[targetDate.getDay()];

        // Dynamically collect all unique slot times from all active doctors' agendas for this day
        activeDoctors.forEach(d => {
            const docAgendas = agendas.filter(a => a.doctor_id === d.id);
            const activeAgenda = docAgendas.find(a => dateVal >= a.start_date && dateVal <= a.end_date && a.active_days.split(',').includes(dayName));
            if (activeAgenda) {
                const slotDur = activeAgenda.slot_duration_minutes || 30;
                const ranges = activeAgenda.time_slots || [
                    { start: activeAgenda.start_hour || '08:00', end: activeAgenda.end_hour || '14:00' }
                ];
                ranges.forEach(r => {
                    const startParts = r.start.split(':');
                    const endParts = r.end.split(':');
                    const startMin = parseInt(startParts[0]) * 60 + parseInt(startParts[1] || 0);
                    const endMin = parseInt(endParts[0]) * 60 + parseInt(endParts[1] || 0);
                    
                    let currentMinutes = startMin;
                    while (currentMinutes < endMin) {
                        const hh = Math.floor(currentMinutes / 60);
                        const mm = currentMinutes % 60;
                        const timeStr = `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
                        if (!timeSlots.includes(timeStr)) {
                            timeSlots.push(timeStr);
                        }
                        currentMinutes += slotDur;
                    }
                });
            }
        });
        
        // Sort timeSlots chronologically
        timeSlots.sort();
        
        // Fallback to standard hours if no active agendas are found
        if (timeSlots.length === 0) {
            for (let h = 8; h < 14; h++) {
                timeSlots.push(`${String(h).padStart(2, '0')}:00`);
                timeSlots.push(`${String(h).padStart(2, '0')}:30`);
            }
        }

        timeSlots.forEach(timeStr => {
            const timeCell = document.createElement('div');
            timeCell.className = 'calendar-time-cell';
            timeCell.innerText = timeStr;
            container.appendChild(timeCell);

            const slotDatetime = `${dateVal}T${timeStr}`;

            activeDoctors.forEach(d => {
                const cell = document.createElement('div');
                cell.className = 'calendar-slot-cell';

                const docAgendas = agendas.filter(a => a.doctor_id === d.id);
                const activeAgenda = docAgendas.find(a => dateVal >= a.start_date && dateVal <= a.end_date && a.active_days.split(',').includes(dayName));

                let inServiceForSlot = false;
                if (activeAgenda) {
                    const ranges = activeAgenda.time_slots || [
                        { start: activeAgenda.start_hour || '08:00', end: activeAgenda.end_hour || '14:00' }
                    ];
                    const parts = timeStr.split(':');
                    const slotMin = parseInt(parts[0]) * 60 + parseInt(parts[1] || 0);
                    
                    inServiceForSlot = ranges.some(r => {
                        const startParts = r.start.split(':');
                        const endParts = r.end.split(':');
                        const startMin = parseInt(startParts[0]) * 60 + parseInt(startParts[1] || 0);
                        const endMin = parseInt(endParts[0]) * 60 + parseInt(endParts[1] || 0);
                        return slotMin >= startMin && slotMin < endMin;
                    });
                }

                if (!activeAgenda || !inServiceForSlot) {
                    cell.classList.add('calendar-slot-inactive');
                    cell.innerText = 'Non in servizio';
                } else {
                    const cellBookings = appointments.filter(app => 
                        app.doctor_id === d.id && 
                        app.appointment_datetime === slotDatetime && 
                        ['scheduled', 'completed', 'no_show'].includes(app.status)
                    );

                    if (cellBookings.length > 0) {
                        cell.innerHTML = '';
                        const bookingsWrapper = document.createElement('div');
                        bookingsWrapper.style.display = 'flex';
                        bookingsWrapper.style.flexDirection = 'column';
                        bookingsWrapper.style.gap = '4px';
                        bookingsWrapper.style.width = '100%';
                        const isPast = new Date(slotDatetime) < new Date();
                        
                        cellBookings.forEach(booking => {
                            const p = DB.get('patients').find(pat => pat.id === booking.patient_id);
                            const pName = p ? `${p.last_name} ${p.first_name}` : 'Paziente';
                            const srvIds = appServices.filter(as => as.appointment_id === booking.id).map(as => as.service_id);
                            const bookedServices = services.filter(sv => srvIds.includes(sv.id));
                            const srvNames = bookedServices.map(s => s.name).join(', ') || 'Nessuna prestazione';
                            
                            let bgColor = 'rgba(37, 99, 235, 0.1)';
                            let borderColor = 'var(--primary)';
                            let textColor = 'var(--primary)';
                            let statusLabel = '';
                            
                            if (booking.status === 'completed') {
                                bgColor = 'rgba(16, 185, 129, 0.1)';
                                borderColor = 'var(--success)';
                                textColor = 'var(--success)';
                                statusLabel = ' (Eseguito)';
                            } else if (booking.status === 'no_show') {
                                bgColor = 'rgba(239, 68, 68, 0.1)';
                                borderColor = 'var(--danger)';
                                textColor = 'var(--danger)';
                                statusLabel = ' (No-Show)';
                            }
                            
                            const bookingDiv = document.createElement('div');
                            bookingDiv.className = 'calendar-slot-booked-card';
                            bookingDiv.style.background = bgColor;
                            bookingDiv.style.borderLeft = `3px solid ${borderColor}`;
                            bookingDiv.style.borderRadius = 'var(--radius-sm)';
                            bookingDiv.style.padding = '4px 6px';
                            bookingDiv.style.fontSize = '0.7rem';
                            bookingDiv.style.color = textColor;
                            bookingDiv.style.fontWeight = '500';
                            bookingDiv.style.cursor = 'pointer';
                            bookingDiv.style.boxShadow = 'var(--shadow-sm)';
                            
                            if (isPast) {
                                bookingDiv.style.opacity = '0.75';
                                bookingDiv.style.filter = 'grayscale(30%)';
                            }
                            
                            bookingDiv.innerHTML = `
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <strong>${pName}${statusLabel}</strong>
                                </div>
                                <div style="font-size:0.6rem; color:var(--text-secondary); text-overflow:ellipsis; overflow:hidden; white-space:nowrap;">${srvNames}</div>
                            `;
                            
                            bookingDiv.addEventListener('click', (ev) => {
                                ev.stopPropagation();
                                closeModal('modal-agendas-calendar');
                                window.openEditAppointmentModal(booking.id);
                            });
                            
                            bookingsWrapper.appendChild(bookingDiv);
                        });
                        
                        const overbookBtn = document.createElement('div');
                        overbookBtn.className = 'calendar-slot-free';
                        overbookBtn.style.padding = '2px';
                        overbookBtn.style.marginTop = '2px';
                        overbookBtn.style.fontSize = '0.65rem';
                        overbookBtn.innerHTML = '<i data-lucide="plus" style="width: 10px; height: 10px;"></i> Sovrapreprenotazione';
                        overbookBtn.addEventListener('click', (ev) => {
                            ev.stopPropagation();
                            closeModal('modal-agendas-calendar');
                            openAddAppointmentModal();
                            setTimeout(() => {
                                const docSelect = document.getElementById('app-doctor');
                                const dtInput = document.getElementById('app-datetime');
                                if (docSelect) { docSelect.value = d.id; findAndRenderFreeSlots(); }
                                if (dtInput) { dtInput.value = slotDatetime; syncActiveSlotBadge(); }
                            }, 200);
                        });
                        bookingsWrapper.appendChild(overbookBtn);
                        cell.appendChild(bookingsWrapper);
                    } else {
                        const freeDiv = document.createElement('div');
                        freeDiv.className = 'calendar-slot-free';
                        freeDiv.innerHTML = '<i data-lucide="plus" style="width: 12px; height: 12px; vertical-align: middle;"></i> Prenota';
                        freeDiv.addEventListener('click', () => {
                            closeModal('modal-agendas-calendar');
                            openAddAppointmentModal();
                            
                            setTimeout(() => {
                                const docSelect = document.getElementById('app-doctor');
                                const dtInput = document.getElementById('app-datetime');
                                if (docSelect) {
                                    docSelect.value = d.id;
                                    findAndRenderFreeSlots();
                                }
                                if (dtInput) {
                                    dtInput.value = slotDatetime;
                                    syncActiveSlotBadge();
                                }
                            }, 200);
                        });
                        cell.appendChild(freeDiv);
                    }
                }
                container.appendChild(cell);
            });
        });
    }

    if (window.lucide) window.lucide.createIcons();
};

window.getNextBarcode = function(suffix) {
    let nextNum = localStorage.getItem('nextcare_next_barcode_num');
    if (!nextNum || isNaN(parseInt(nextNum))) {
        nextNum = 10000001;
    } else {
        nextNum = parseInt(nextNum);
    }
    const progressStr = String(nextNum).padStart(8, '0');
    const barcode = progressStr + '0' + String(suffix).padStart(3, '0');
    localStorage.setItem('nextcare_next_barcode_num', nextNum + 1);
    return barcode;
};

window.guessDoseClassIdByName = function(name) {
    if (!name) return null;
    const lower = name.toLowerCase().trim();
    
    // Class 0: Ecografia, Risonanza Magnetica
    if (lower.includes('ecografia') || lower.includes('risonanza') || lower.includes(' eco ') || lower.startsWith('eco ') || lower.includes('ecocolordoppler') || lower.includes('ecocardiografia') || lower.includes('ecostress') || lower.includes('ecocardio') || /\brm\b/i.test(lower) || /\brmn\b/i.test(lower)) {
        return 1; // ID 1 = Classe 0
    }
    
    // Class IV: Interventistica, Angiografia, coronarografia, angioTC, total body, TC addome completo/totale
    if (lower.includes('interventistica') || lower.includes('angiografia') || lower.includes('coronarografia') || lower.includes('angiotc') || lower.includes('angio-tc') || lower.includes('total body') || lower.includes('completo') || lower.includes('completa') || lower.includes('totale')) {
        return 5; // ID 5 = Classe IV
    }
    
    // Class III / II for CT/TC
    if (lower.includes('tc') || lower.includes('ct') || lower.includes('tac')) {
        if (lower.includes('cranio') || lower.includes('encefalo') || lower.includes('testa') || lower.includes('orbite') || lower.includes('rocche') || lower.includes('sella')) {
            return 3; // ID 3 = Classe II
        }
        return 4; // ID 4 = Classe III
    }
    
    // Class II: RX Addome, RX Digerente
    if ((lower.includes('radiografia') || lower.includes('radiografico') || /\brx\b/i.test(lower)) && (lower.includes('addome') || lower.includes('digerente') || lower.includes('clisma') || lower.includes('uretrografia'))) {
        return 3; // ID 3 = Classe II
    }
    
    // Class I: Basic X-Ray, Opt, Mammography
    if (lower.includes('radiografia') || lower.includes('radiografico') || lower.includes('ortopantomografia') || lower.includes('telecuore') || lower.includes('mammografia') || lower.includes('mammografico') || /\brx\b/i.test(lower) || /\bopt\b/i.test(lower)) {
        return 2; // ID 2 = Classe I
    }
    
    return null;
};

window.generateBarcodeVisualHTML = function(barcodeStr) {
    let html = '';
    for (let i = 0; i < barcodeStr.length; i++) {
        const digit = parseInt(barcodeStr[i]) || 0;
        const lineCount = (digit % 3) + 1;
        for (let l = 0; l < lineCount; l++) {
            const width = (l % 2 === 0) ? '1.5px' : '3px';
            html += `<span style="display:inline-block; background:#000; width:${width}; height:8mm; margin-right:1px;"></span>`;
            html += `<span style="display:inline-block; background:transparent; width:1.5px; height:8mm; margin-right:1px;"></span>`;
        }
    }
    return html;
};

window.printLisBarcodeLabel = function(sampleId) {
    const sample = DB.get('lab_samples').find(s => s.id === parseInt(sampleId));
    if (!sample) return;
    const patient = DB.get('patients').find(p => p.id === sample.patient_id);
    if (!patient) return;
    const tests = DB.get('lab_tests').filter(t => t.sample_id === sample.id);
    const tubeTypes = DB.get('tube_types') || [];
    const matchedTube = tubeTypes.find(t => t.name === sample.sample_type);
    const suffix = matchedTube ? matchedTube.suffix : '000';
    
    const motherBarcode = sample.barcode;
    const progressStr = motherBarcode.substring(0, 8);
    
    const patientName = `${patient.last_name.toUpperCase()} ${patient.first_name}`;
    const patientBirth = new Date(patient.birth_date).toLocaleDateString('it-IT');
    const collectDate = new Date(sample.collected_at || sample.created_at).toLocaleString('it-IT');
    
    const printWindow = window.open('', '_blank');
    if (!printWindow) {
        alert("Errore: Pop-up bloccato dal browser! Consenti i pop-up per questo sito.");
        return;
    }
    
    let html = `\n        <html>\n        <head>\n            <title>Stampa Etichette LIS - ${motherBarcode}</title>\n            <style>\n                @import url('https://fonts.googleapis.com/css2?family=Libre+Barcode+2of5+Interleaved&family=Inter:wght@400;700&display=swap');\n                @page { size: 60mm 35mm; margin: 0; }\n                body { margin: 0; padding: 0; background: #fff; }\n                .lis-label-container {\n                    width: 60mm;\n                    height: 35mm;\n                    padding: 2mm 3mm;\n                    box-sizing: border-box;\n                    font-family: 'Inter', sans-serif;\n                    color: #000;\n                    display: flex;\n                    flex-direction: column;\n                    justify-content: space-between;\n                    page-break-after: always;\n                }\n                .lis-label-title {\n                    font-size: 7pt;\n                    font-weight: 700;\n                    text-transform: uppercase;\n                    border-bottom: 0.5px solid #000;\n                    padding-bottom: 0.5mm;\n                    margin: 0;\n                    letter-spacing: 0.5px;\n                }\n                .lis-label-patient {\n                    font-size: 8pt;\n                    font-weight: 700;\n                    margin: 1mm 0 0.5mm 0;\n                    white-space: nowrap;\n                    overflow: hidden;\n                    text-overflow: ellipsis;\n                }\n                .lis-label-info {\n                    font-size: 6.5pt;\n                    line-height: 1.2;\n                }\n                .lis-label-barcode-area {\n                    display: flex;\n                    flex-direction: column;\n                    align-items: center;\n                }\n                .lis-barcode-font {\n                    font-family: 'Libre Barcode 2of5 Interleaved', sans-serif;\n                    font-size: 32px;\n                    height: 10mm;\n                    line-height: 1;\n                    margin: 0;\n                }\n                .lis-label-barcode-text {\n                    font-family: monospace;\n                    font-size: 8pt;\n                    font-weight: 700;\n                    margin-top: 0.5mm;\n                    letter-spacing: 1px;\n                }\n            </style>\n        </head>\n        <body>\n    `;
    
    // Mother/Acceptance Label
    html += `\n        <div class="lis-label-container">\n            <div class="lis-label-title">NEXTCARE LIS - ACCETTAZIONE</div>\n            <div class="lis-label-patient">${patientName}</div>\n            <div class="lis-label-info">\n                Nascita: ${patientBirth} | ${sample.sample_type}<br>\n                Data/Ora: ${collectDate}\n            </div>\n            <div class="lis-label-barcode-area">\n                <div class="lis-barcode-font">{${motherBarcode}}</div>\n                <div class="lis-label-barcode-text">${motherBarcode}</div>\n            </div>\n        </div>\n    `;
    
    html += `\n            <script>\n                window.onload = function() {\n                    window.print();\n                    setTimeout(function() { window.close(); }, 500);\n                }\n            </script>\n        </body>\n        </html>\n    `;
    
    printWindow.document.write(html);
    printWindow.document.close();
};

