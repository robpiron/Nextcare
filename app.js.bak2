window.seedValidationHistory = function() {
    let samples = DB.get('lab_samples') || [];
    let tests = DB.get('lab_tests') || [];
    const seedServices = DB.get('medical_services') || [];
    
    // Seed new LIS instruments in live DB
    let liveEquipment = DB.get('equipment') || [];
    const mockInstruments = [
        {
            id: 10,
            clinic_id: 3,
            name: "Sysmex XN-1000",
            type: "LIS",
            serial_number: "SYS-XN-99812",
            status: "active",
            lis_interface_type: "file",
            lis_import_path: "C:\\Users\
\nobpiron\\.gemini\\antigravity\\scratch\\NextCareApp\\lis_import",
            lis_export_path: "C:\\Users\
\nobpiron\\.gemini\\antigravity\\scratch\\NextCareApp\\lis_export",
            lis_file_name: "sysmex_results.csv",
            lis_file_format: "csv",
            lis_socket_port: null,
            lis_socket_format: null,
            lis_transcoding: [
                { nc_type: "service", nc_code: "CBC", instrument_code: "SYS_CBC" },
                { nc_type: "parameter", nc_name: "WBC", instrument_code: "WBC" },
                { nc_type: "parameter", nc_name: "RBC", instrument_code: "RBC" },
                { nc_type: "parameter", nc_name: "HGB", instrument_code: "HGB" },
                { nc_type: "parameter", nc_name: "PLT", instrument_code: "PLT" }
            ],
            dicom_ip: null,
            dicom_port: null,
            dicom_aetitle: null,
            dicom_modality: null
        },
        {
            id: 11,
            clinic_id: 3,
            name: "Roche Cobas e411",
            type: "LIS",
            serial_number: "COB-E4-11029",
            status: "active",
            lis_interface_type: "socket",
            lis_import_path: null,
            lis_export_path: null,
            lis_file_name: null,
            lis_file_format: null,
            lis_socket_port: 6001,
            lis_socket_format: "hl7",
            lis_transcoding: [
                { nc_type: "service", nc_code: "TSH", instrument_code: "TSH" },
                { nc_type: "parameter", nc_name: "TSH", instrument_code: "TSH_VAL" },
                { nc_type: "service", nc_code: "FT4", instrument_code: "FT4" },
                { nc_type: "parameter", nc_name: "FT4", instrument_code: "FT4_VAL" }
            ],
            dicom_ip: null,
            dicom_port: null,
            dicom_aetitle: null,
            dicom_modality: null
        },
        {
            id: 12,
            clinic_id: 3,
            name: "Abbott Alinity c",
            type: "LIS",
            serial_number: "ALN-C-55421",
            status: "active",
            lis_interface_type: "file",
            lis_import_path: "C:\\Users\
\nobpiron\\.gemini\\antigravity\\scratch\\NextCareApp\\lis_import",
            lis_export_path: "C:\\Users\
\nobpiron\\.gemini\\antigravity\\scratch\\NextCareApp\\lis_export",
            lis_file_name: "alinity_results.csv",
            lis_file_format: "csv",
            lis_socket_port: null,
            lis_socket_format: null,
            lis_transcoding: [
                { nc_type: "service", nc_code: "GLU", instrument_code: "GLUCOSE" },
                { nc_type: "parameter", nc_name: "Glicemia", instrument_code: "GLU_VAL" },
                { nc_type: "service", nc_code: "CRE", instrument_code: "CREATININE" },
                { nc_type: "parameter", nc_name: "Creatinina", instrument_code: "CRE_VAL" }
            ],
            dicom_ip: null,
            dicom_port: null,
            dicom_aetitle: null,
            dicom_modality: null
        }
    ];
    let eqChanged = false;
    mockInstruments.forEach(ins => {
        const idx = liveEquipment.findIndex(eq => eq.id === ins.id);
        if (idx === -1) {
            liveEquipment.push(ins);
            eqChanged = true;
        } else if (!liveEquipment[idx].lis_interface_type) {
            liveEquipment[idx] = ins;
            eqChanged = true;
        }
    });
    if (eqChanged) {
        DB.set('equipment', liveEquipment);
    }

    // Seed default esame-strumento associations in live DB
    let liveServices = DB.get('medical_services') || [];
    let srvChanged = false;
    liveServices.forEach(srv => {
        if (typeof srv.instrument_id === 'undefined') {
            srv.instrument_id = null;
            srvChanged = true;
        }
        if (srv.id === 3 && srv.instrument_id !== 11) {
            srv.instrument_id = 11;
            srvChanged = true;
        }
        if (srv.id === 4 && srv.instrument_id !== 10) {
            srv.instrument_id = 10;
            srvChanged = true;
        }
        if (srv.id === 5 && srv.instrument_id !== 11) {
            srv.instrument_id = 11;
            srvChanged = true;
        }
    });
    if (srvChanged) {
        DB.set('medical_services', liveServices);
    }
    const findSeedServiceId = (testName) => {
        if (testName.startsWith('Emocromo (')) {
            const s = seedServices.find(srv => srv.name.toLowerCase().includes('emocromo'));
            return s ? s.id : 4;
        }
        if (testName.startsWith('Elettroforesi (')) {
            const s = seedServices.find(srv => srv.name.toLowerCase().includes('elettroforesi'));
            return s ? s.id : 111;
        }
        if (testName.startsWith('Esame Urine (')) {
            const s = seedServices.find(srv => srv.name.toLowerCase().includes('urine'));
            return s ? s.id : 8;
        }
        const s = seedServices.find(srv => srv.name.toLowerCase().replace(/\s*\(lis\)\s*/g, '') === testName.toLowerCase());
        if (s) return s.id;
        if (testName === 'Glucosio') return 3;
        if (testName === 'Colesterolo Totale') return 5;
        if (testName === 'Creatinina') return 74;
        return null;
    };

    const hasRichHistory = samples.some(s => s.barcode && s.barcode.startsWith('VAL-S-'));
    if (hasRichHistory) return;

    // Filter out old seed data to avoid duplication and clutter
    samples = samples.filter(s => !s.barcode || !s.barcode.startsWith('VAL-'));
    const cleanSampleIds = new Set(samples.map(s => s.id));
    tests = tests.filter(t => cleanSampleIds.has(t.sample_id));

    // Mario Rossi (1), Flavia Bianchi (2), Giovanni Verdi (3)
    const patients = [1, 2, 3];
    
    const biochemTemplates = [
        { name: 'Glucosio', unit: 'mg/dL', range: '70-110', values: [92, 104, 115, 88, 98, 122] },
        { name: 'Colesterolo Totale', unit: 'mg/dL', range: '< 200', values: [180, 210, 195, 220, 185, 205] },
        { name: 'Creatinina', unit: 'mg/dL', range: '0.6-1.2', values: [0.8, 1.1, 0.9, 1.3, 0.75, 1.0] },
        { name: 'Elettroforesi (Albumina)', unit: '%', range: '55.8-66.1', values: [60.2, 58.5, 61.0, 57.8, 59.5, 54.2] },
        { name: 'Elettroforesi (Gamma Globuline)', unit: '%', range: '11.1-18.8', values: [15.2, 16.0, 14.8, 15.5, 15.0, 20.2] }
    ];
    
    const hematoTemplates = [
        { name: 'Emocromo (WBC)', unit: '10^3/uL', range: '4.0-10.0', values: [6.2, 7.5, 9.8, 5.5, 6.8, 11.2] },
        { name: 'Emocromo (RBC)', unit: '10^6/uL', range: '4.5-5.9', values: [4.8, 5.1, 4.6, 5.3, 4.9, 4.2] },
        { name: 'Emocromo (Hb)', unit: 'g/dL', range: '13.5-17.5', values: [14.2, 15.1, 13.8, 15.6, 14.5, 12.1] },
        { name: 'Emocromo (PLT)', unit: '10^3/uL', range: '150-450', values: [220, 260, 190, 240, 230, 135] }
    ];
    
    const urineTemplates = [
        { name: 'Esame Urine (pH)', unit: '', range: '5.5-6.5', values: [6.0, 5.5, 6.5, 6.0, 5.8, 7.5] },
        { name: 'Esame Urine (Peso Specifico)', unit: '', range: '1.015-1.025', values: [1.020, 1.018, 1.022, 1.015, 1.020, 1.008] },
        { name: 'Esame Urine (Proteine)', unit: 'mg/dL', range: '< 15', values: [5, 8, 12, 5, 10, 45] }
    ];

    let lastSampleId = samples.length > 0 ? Math.max(...samples.map(s => s.id)) : 0;
    let lastTestId = tests.length > 0 ? Math.max(...tests.map(t => t.id)) : 0;

    const baseDate = new Date();

    patients.forEach(patId => {
        // Create 5 historical samples (completed/validated) over the last 5 weeks
        for (let i = 5; i >= 1; i--) {
            const sampleDate = new Date(baseDate.getTime() - i * 7 * 24 * 60 * 60 * 1000);
            const isoDate = sampleDate.toISOString();
            
            // 1. Siero (Biochem)
            lastSampleId++;
            let barcodeSiero = `VAL-S-${patId}-${i}`;
            samples.push({
                id: lastSampleId,
                patient_id: patId,
                barcode: barcodeSiero,
                sample_type: 'Siero',
                status: 'validated',
                collected_at: isoDate,
                created_at: isoDate,
                session_uid: `SESS-VAL-${patId}-${i}`
            });
            let sieroSampleId = lastSampleId;
            biochemTemplates.forEach(tpl => {
                lastTestId++;
                const val = tpl.values[5 - i];
                const isNormal = window.checkTestValueIsNormal(val, tpl.range);
                tests.push({
                    id: lastTestId,
                    sample_id: sieroSampleId,
                    service_id: findSeedServiceId(tpl.name),
                    test_name: tpl.name,
                    result_value: String(val),
                    unit: tpl.unit,
                    reference_range: tpl.range,
                    status: isNormal,
                    verified_by: 5,
                    verified_at: isoDate
                });
            });

            // 2. Sangue Intero (Hemato)
            lastSampleId++;
            let barcodeSangue = `VAL-B-${patId}-${i}`;
            samples.push({
                id: lastSampleId,
                patient_id: patId,
                barcode: barcodeSangue,
                sample_type: 'Sangue Intero',
                status: 'validated',
                collected_at: isoDate,
                created_at: isoDate,
                session_uid: `SESS-VAL-${patId}-${i}`
            });
            let sangueSampleId = lastSampleId;
            hematoTemplates.forEach(tpl => {
                lastTestId++;
                const val = tpl.values[5 - i];
                const isNormal = window.checkTestValueIsNormal(val, tpl.range);
                tests.push({
                    id: lastTestId,
                    sample_id: sangueSampleId,
                    service_id: findSeedServiceId(tpl.name),
                    test_name: tpl.name,
                    result_value: String(val),
                    unit: tpl.unit,
                    reference_range: tpl.range,
                    status: isNormal,
                    verified_by: 5,
                    verified_at: isoDate
                });
            });

            // 3. Urine
            lastSampleId++;
            let barcodeUrine = `VAL-U-${patId}-${i}`;
            samples.push({
                id: lastSampleId,
                patient_id: patId,
                barcode: barcodeUrine,
                sample_type: 'Urine',
                status: 'validated',
                collected_at: isoDate,
                created_at: isoDate,
                session_uid: `SESS-VAL-${patId}-${i}`
            });
            let urineSampleId = lastSampleId;
            urineTemplates.forEach(tpl => {
                lastTestId++;
                const val = tpl.values[5 - i];
                const isNormal = window.checkTestValueIsNormal(val, tpl.range);
                tests.push({
                    id: lastTestId,
                    sample_id: urineSampleId,
                    service_id: findSeedServiceId(tpl.name),
                    test_name: tpl.name,
                    result_value: String(val),
                    unit: tpl.unit,
                    reference_range: tpl.range,
                    status: isNormal,
                    verified_by: 5,
                    verified_at: isoDate
                });
            });
        }

        // Create 3 pending samples (to_validate status)
        // 1. Siero
        lastSampleId++;
        let pBarSiero = `VAL-PEND-S-${patId}`;
        samples.push({
            id: lastSampleId,
            patient_id: patId,
            barcode: pBarSiero,
            sample_type: 'Siero',
            status: 'to_validate',
            collected_at: baseDate.toISOString(),
            created_at: baseDate.toISOString(),
            session_uid: `SESS-VAL-PEND-${patId}`
        });
        let pSieroId = lastSampleId;
        biochemTemplates.forEach(tpl => {
            lastTestId++;
            const val = tpl.values[5];
            const isNormal = window.checkTestValueIsNormal(val, tpl.range);
            tests.push({
                id: lastTestId,
                sample_id: pSieroId,
                service_id: findSeedServiceId(tpl.name),
                test_name: tpl.name,
                result_value: String(val),
                unit: tpl.unit,
                reference_range: tpl.range,
                status: isNormal,
                verified_by: null,
                verified_at: null
            });
        });

        // 2. Sangue Intero
        lastSampleId++;
        let pBarSangue = `VAL-PEND-B-${patId}`;
        samples.push({
            id: lastSampleId,
            patient_id: patId,
            barcode: pBarSangue,
            sample_type: 'Sangue Intero',
            status: 'to_validate',
            collected_at: baseDate.toISOString(),
            created_at: baseDate.toISOString(),
            session_uid: `SESS-VAL-PEND-${patId}`
        });
        let pSangueId = lastSampleId;
        hematoTemplates.forEach(tpl => {
            lastTestId++;
            const val = tpl.values[5];
            const isNormal = window.checkTestValueIsNormal(val, tpl.range);
            tests.push({
                id: lastTestId,
                sample_id: pSangueId,
                service_id: findSeedServiceId(tpl.name),
                test_name: tpl.name,
                result_value: String(val),
                unit: tpl.unit,
                reference_range: tpl.range,
                status: isNormal,
                verified_by: null,
                verified_at: null
            });
        });

        // 3. Urine
        lastSampleId++;
        let pBarUrine = `VAL-PEND-U-${patId}`;
        samples.push({
            id: lastSampleId,
            patient_id: patId,
            barcode: pBarUrine,
            sample_type: 'Urine',
            status: 'to_validate',
            collected_at: baseDate.toISOString(),
            created_at: baseDate.toISOString(),
            session_uid: `SESS-VAL-PEND-${patId}`
        });
        let pUrineId = lastSampleId;
        urineTemplates.forEach(tpl => {
            lastTestId++;
            const val = tpl.values[5];
            const isNormal = window.checkTestValueIsNormal(val, tpl.range);
            tests.push({
                id: lastTestId,
                sample_id: pUrineId,
                service_id: findSeedServiceId(tpl.name),
                test_name: tpl.name,
                result_value: String(val),
                unit: tpl.unit,
                reference_range: tpl.range,
                status: isNormal,
                verified_by: null,
                verified_at: null
            });
        });
    });

    DB.set('lab_samples', samples);
    DB.set('lab_tests', tests);

    // Seed corresponding appointments, appointment_services, and lab_reports
    const appointments = DB.get('appointments') || [];
    const appServices = DB.get('appointment_services') || [];
    const labReports = DB.get('lab_reports') || [];

    // 1. Add completed appointment for RIS study 1 if not exists
    if (!appointments.some(a => a.id === 50)) {
        appointments.push({
            id: 50,
            patient_id: 1,
            doctor_id: 2,
            appointment_datetime: "2026-06-11T10:00",
            status: "completed",
            notes: "Eseguito esame radiologico RX Torace."
        });
        appServices.push({
            appointment_id: 50,
            service_id: 6
        });
    }

    // 2. Add completed appointments & reports for LIS historical samples
    samples.forEach(s => {
        if (s.session_uid && s.session_uid.startsWith('SESS-VAL-')) {
            const matchId = parseInt(s.session_uid.split('-')[3] || '0');
            const appId = 1000 + s.patient_id * 10 + matchId;
            const repId = 2000 + s.patient_id * 10 + matchId;

            // Seed completed appointment
            if (!appointments.some(a => a.id === appId)) {
                appointments.push({
                    id: appId,
                    patient_id: s.patient_id,
                    doctor_id: s.patient_id === 1 ? 1 : (s.patient_id === 2 ? 3 : 2),
                    appointment_datetime: s.collected_at || s.created_at,
                    status: "completed",
                    notes: "Accettazione storica via CUP."
                });
                appServices.push({
                    appointment_id: appId,
                    service_id: 4 // Emocromo
                });
                appServices.push({
                    appointment_id: appId,
                    service_id: 3 // Glicemia
                });
            }

            // Seed lab report
            if (!labReports.some(r => r.session_uid === s.session_uid)) {
                labReports.push({
                    id: repId,
                    session_uid: s.session_uid,
                    status: "official",
                    notes: "Esami convalidati e referto rilasciato automaticamente.",
                    released_at: s.collected_at || s.created_at,
                    released_by: 5
                });
            }
        }
    });

    DB.set('appointments', appointments);
    DB.set('appointment_services', appServices);
    DB.set('lab_reports', labReports);

    // 3. Seed new mock cases for RIS and VISITS (appointments, services, and radiology_studies)
    const radiologyStudies = DB.get('radiology_studies') || [];

    // Mock Case 1: RIS - Past Booking (Completata con Referto Torace)
    if (!appointments.some(a => a.id === 101)) {
        appointments.push({
            id: 101,
            patient_id: 2,
            doctor_id: 2,
            appointment_datetime: "2026-06-02T10:00",
            status: "completed",
            notes: "Controllo radiologico programmato."
        });
        appServices.push({ appointment_id: 101, service_id: 6 });
    }
    if (!radiologyStudies.some(s => s.id === 101)) {
        radiologyStudies.push({
            id: 101,
            patient_id: 2,
            doctor_id: 2,
            service_id: 6,
            study_type: "XRAY",
            scheduled_at: "2026-06-02T10:00",
            status: "completed",
            dicom_series_uid: "1.2.840.113619.2.201.1",
            report_text: "<h3>REFERTO RX TORACE</h3><p><b>Quesito clinico:</b> Sospetta polmonite.</p><p>Esame radiografico eseguito in due proiezioni ortogonali.</p><p><u>Riscontro diagnostico:</u> Non si evidenziano focolai di addensamento parenchimale pleuro-polmonare a carattere attivo. Seni costo-frenici liberi ed espansi. Ombra cardiaca nei limiti per età e costituzione.</p>",
            signed_by: 2,
            signed_at: "2026-06-02T11:00",
            tsrm_id: 5
        });
    }

    // Mock Case 2: VISIT - Past Booking (Completata con Referto Visita Cardiologica)
    if (!appointments.some(a => a.id === 102)) {
        appointments.push({
            id: 102,
            patient_id: 3,
            doctor_id: 1,
            appointment_datetime: "2026-06-05T09:00",
            status: "completed",
            notes: "Visita cardiologica di controllo."
        });
        appServices.push({ appointment_id: 102, service_id: 1 });
    }
    if (!radiologyStudies.some(s => s.id === 102)) {
        radiologyStudies.push({
            id: 102,
            patient_id: 3,
            doctor_id: 1,
            service_id: 1,
            study_type: "VISIT",
            scheduled_at: "2026-06-05T09:00",
            status: "completed",
            dicom_series_uid: "1.2.840.113619.2.201.2",
            report_text: "<h3>REFERTO VISITA CARDIOLOGICA</h3><p><b>Anamnesi:</b> Riferisce saltuari episodi di cardiopalmo.</p><p><b>Esame Obiettivo:</b> Toni cardiaci validi, ritmici, pause libere. Pressione Arteriosa: 120/80 mmHg.</p><p><b>ECG:</b> Ritmo sinusale a 72 bpm, normale conduzione atrio-ventricolare e intra-ventricolare, assenza di alterazioni della ripolarizzazione ventricolare in atto.</p><p><b>Conclusioni:</b> Quadro clinico e strumentale stabile. Si consiglia controllo annuale.</p>",
            signed_by: 1,
            signed_at: "2026-06-05T09:45"
        });
    }

    // Mock Case 3: RIS - No-Show Booking (Pianificata nel passato, non accettata / aperta)
    if (!appointments.some(a => a.id === 103)) {
        appointments.push({
            id: 103,
            patient_id: 1,
            doctor_id: 2,
            appointment_datetime: "2026-06-10T14:00",
            status: "scheduled",
            notes: "Risonanza magnetica encefalo."
        });
        appServices.push({ appointment_id: 103, service_id: 7 });
    }
    if (!radiologyStudies.some(s => s.id === 103)) {
        radiologyStudies.push({
            id: 103,
            patient_id: 1,
            doctor_id: 2,
            service_id: 7,
            study_type: "MRI",
            scheduled_at: "2026-06-10T14:00",
            status: "scheduled",
            dicom_series_uid: "1.2.840.113619.2.201.3",
            report_text: null,
            tsrm_id: null
        });
    }

    // Mock Case 4: VISIT - Cancelled Booking (Annullata)
    if (!appointments.some(a => a.id === 104)) {
        appointments.push({
            id: 104,
            patient_id: 2,
            doctor_id: 3,
            appointment_datetime: "2026-06-08T15:30",
            status: "cancelled",
            notes: "Consulto chirurgico programmato.",
            cancellation_reason: "Paziente impossibilitato",
            cancellation_notes: "Richiesto spostamento telefonico"
        });
        appServices.push({ appointment_id: 104, service_id: 2 });
    }

    // Mock Case 5: RIS - Future Booking (Pianificata futura, aperta)
    if (!appointments.some(a => a.id === 105)) {
        appointments.push({
            id: 105,
            patient_id: 3,
            doctor_id: 2,
            appointment_datetime: "2026-06-25T11:30",
            status: "scheduled",
            notes: "Radiografia Torace di routine."
        });
        appServices.push({ appointment_id: 105, service_id: 6 });
    }
    if (!radiologyStudies.some(s => s.id === 105)) {
        radiologyStudies.push({
            id: 105,
            patient_id: 3,
            doctor_id: 2,
            service_id: 6,
            study_type: "XRAY",
            scheduled_at: "2026-06-25T11:30",
            status: "scheduled",
            dicom_series_uid: "1.2.840.113619.2.201.5",
            report_text: null,
            tsrm_id: null
        });
    }

    // Mock Case 6: VISIT - Future Booking (Pianificata futura, aperta)
    if (!appointments.some(a => a.id === 106)) {
        appointments.push({
            id: 106,
            patient_id: 1,
            doctor_id: 1,
            appointment_datetime: "2026-06-28T09:00",
            status: "scheduled",
            notes: "Visita Cardiologica + ECG di controllo."
        });
        appServices.push({ appointment_id: 106, service_id: 1 });
    }
    if (!radiologyStudies.some(s => s.id === 106)) {
        radiologyStudies.push({
            id: 106,
            patient_id: 1,
            doctor_id: 1,
            service_id: 1,
            study_type: "VISIT",
            scheduled_at: "2026-06-28T09:00",
            status: "scheduled",
            dicom_series_uid: "1.2.840.113619.2.201.6",
            report_text: null
        });
    }

    DB.set('radiology_studies', radiologyStudies);
    DB.set('appointments', appointments);
    DB.set('appointment_services', appServices);
    DB.set('lab_reports', labReports);
};

window.drawWbcScattergram = function(patientId) {
    const canvas = document.getElementById('val-scatter-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Fill dark background
    ctx.fillStyle = '#0f172a';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // Draw axes
    ctx.strokeStyle = '#334155';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(15, 5);
    ctx.lineTo(15, canvas.height - 15);
    ctx.lineTo(canvas.width - 5, canvas.height - 15);
    ctx.stroke();
    
    // Axis labels
    ctx.fillStyle = '#64748b';
    ctx.font = '7px sans-serif';
    ctx.fillText("SSC (Complessità)", 20, 10);
    ctx.fillText("FSC (Volume)", canvas.width - 60, canvas.height - 5);
    
    // Generate cluster centers based on patient condition
    let lymPct = 32.4;
    let monoPct = 6.8;
    let neutPct = 58.2;
    let eosPct = 2.1;
    let basoPct = 0.5;
    
    if (patientId === 1) { // Mario Rossi - Normal
        lymPct = 30.5; monoPct = 7.2; neutPct = 59.8; eosPct = 2.0; basoPct = 0.5;
    } else if (patientId === 2) { // Flavia Bianchi - Lymphocytosis
        lymPct = 48.2; monoPct = 5.1; neutPct = 44.5; eosPct = 1.8; basoPct = 0.4;
    } else if (patientId === 3) { // Giovanni Verdi - Neutrophilia
        lymPct = 15.4; monoPct = 8.5; neutPct = 72.8; eosPct = 3.0; basoPct = 0.3;
    }
    
    document.getElementById('val-wbc-lym-pct').innerText = lymPct.toFixed(1) + '%';
    document.getElementById('val-wbc-mono-pct').innerText = monoPct.toFixed(1) + '%';
    document.getElementById('val-wbc-neut-pct').innerText = neutPct.toFixed(1) + '%';
    document.getElementById('val-wbc-eos-pct').innerText = eosPct.toFixed(1) + '%';
    document.getElementById('val-wbc-baso-pct').innerText = basoPct.toFixed(1) + '%';
    
    // Draw point clusters using Box-Muller transform for normal distribution
    function drawCluster(centerX, centerY, stdX, stdY, count, color) {
        ctx.fillStyle = color;
        for (let i = 0; i < count; i++) {
            let u1 = Math.random();
            let u2 = Math.random();
            if (u1 === 0) u1 = 0.0001;
            const z0 = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);
            const z1 = Math.sqrt(-2.0 * Math.log(u1)) * Math.sin(2.0 * Math.PI * u2);
            
            const x = centerX + z0 * stdX;
            const y = centerY + z1 * stdY;
            
            // Check canvas boundaries
            if (x >= 16 && x <= canvas.width - 6 && y >= 6 && y <= canvas.height - 16) {
                ctx.beginPath();
                ctx.arc(x, y, 0.8, 0, Math.PI * 2);
                ctx.fill();
            }
        }
    }
    
    // Debris/Platelets cluster (bottom-left)
    drawCluster(25, canvas.height - 20, 3, 2, 80, '#475569');
    
    // Lymphocytes (blue) - lower-left/mid-left
    let lymCount = Math.round(lymPct * 6);
    drawCluster(55, canvas.height - 40, 8, 8, lymCount, '#38bdf8');
    
    // Monocytes (green) - middle
    let monoCount = Math.round(monoPct * 6);
    drawCluster(90, canvas.height - 50, 10, 8, monoCount, '#4ade80');
    
    // Neutrophils (orange) - upper-right
    let neutCount = Math.round(neutPct * 6);
    drawCluster(135, canvas.height - 90, 15, 12, neutCount, '#f97316');
    
    // Eosinophils (yellow) - upper-mid
    let eosCount = Math.round(eosPct * 6);
    drawCluster(110, canvas.height - 110, 8, 6, eosCount, '#eab308');
    
    // Basophils (purple) - lower-right
    let basoCount = Math.round(basoPct * 6);
    drawCluster(75, canvas.height - 85, 6, 6, basoCount, '#a855f7');
};

window.selectTestForTrend = function(testName, patientId, unit, referenceRange) {
    const samples = DB.get('lab_samples') || [];
    const tests = DB.get('lab_tests') || [];
    
    const patientSamples = samples.filter(s => s.patient_id === patientId && (s.status === 'validated' || s.status === 'completed' || s.status === 'to_validate'));
    const patientSampleIds = patientSamples.map(s => s.id);
    
    const pastTests = tests.filter(t => patientSampleIds.includes(t.sample_id) && t.test_name === testName && t.result_value !== null && t.result_value !== undefined && String(t.result_value).trim() !== '');
    
    const historyData = pastTests.map(t => {
        const sam = patientSamples.find(s => s.id === t.sample_id);
        const dateStr = sam ? (sam.collected_at || sam.created_at) : null;
        return {
            date: dateStr ? new Date(dateStr) : new Date(),
            dateStr: dateStr ? new Date(dateStr).toLocaleDateString('it-IT') : '-',
            result_value: t.result_value,
            status: t.status
        };
    });
    
    historyData.sort((a, b) => a.date - b.date);
    
    const container = document.getElementById('val-trend-section');
    if (!container) return;
    
    document.getElementById('val-trend-test-title').innerText = `Storico & Andamento: ${testName}`;
    
    const listDiv = document.getElementById('val-history-list');
    if (listDiv) {
        listDiv.innerHTML = '';
        if (historyData.length === 0) {
            listDiv.innerHTML = '<span style="color: var(--text-secondary); font-style: italic;">Nessun dato storico.</span>';
        } else {
            const sortedList = [...historyData].sort((a,b) => b.date - a.date);
            let listHTML = '<table style="width:100%; border-collapse:collapse; font-size:0.72rem; text-align:left;">';
            listHTML += '<thead style="border-bottom:1px solid var(--border-color); color:var(--text-secondary);"><tr><th style="padding:2px 0;">Data</th><th style="padding:2px 0; text-align:right;">Risultato</th></tr></thead><tbody>';
            sortedList.forEach(item => {
                const valColor = item.status === 'flagged' ? 'color: var(--danger); font-weight:bold;' : 'color: var(--text-primary);';
                listHTML += `<tr style="border-bottom:1px solid var(--border-color);"><td style="padding:3px 0; color:var(--text-secondary);">${item.dateStr}</td><td style="padding:3px 0; text-align:right; ${valColor}">${item.result_value} ${unit}</td></tr>`;
            });
            listHTML += '</tbody></table>';
            listDiv.innerHTML = listHTML;
        }
    }
    
    const canvas = document.getElementById('val-trend-canvas');
    if (canvas) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width || 380;
        canvas.height = rect.height || 130;
        
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        ctx.strokeStyle = '#e2e8f0';
        ctx.lineWidth = 1;
        ctx.strokeRect(0, 0, canvas.width, canvas.height);
        
        const numericalVals = historyData.filter(pt => !isNaN(parseFloat(String(pt.result_value).replace(',', '.')))).map(pt => ({
            date: pt.date,
            dateStr: pt.dateStr,
            val: parseFloat(String(pt.result_value).replace(',', '.'))
        }));
        
        if (numericalVals.length < 2) {
            ctx.fillStyle = '#64748b';
            ctx.font = '10px sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText("Dati storici insufficienti per il grafico", canvas.width / 2, canvas.height / 2);
            ctx.textAlign = 'left';
            return;
        }
        
        const vals = numericalVals.map(d => d.val);
        let minVal = Math.min(...vals);
        let maxVal = Math.max(...vals);
        
        const range = maxVal - minVal;
        if (range === 0) {
            minVal = minVal * 0.8;
            maxVal = maxVal * 1.2;
        } else {
            minVal = minVal - range * 0.15;
            maxVal = maxVal + range * 0.15;
        }
        
        const valRange = maxVal - minVal;
        
        const paddingLeft = 35;
        const paddingRight = 15;
        const paddingTop = 15;
        const paddingBottom = 20;
        
        const graphWidth = canvas.width - paddingLeft - paddingRight;
        const graphHeight = canvas.height - paddingTop - paddingBottom;
        
        const getX = (index) => paddingLeft + (index / (numericalVals.length - 1)) * graphWidth;
        const getY = (val) => paddingTop + graphHeight - ((val - minVal) / valRange) * graphHeight;
        
        ctx.strokeStyle = '#f1f5f9';
        ctx.lineWidth = 1;
        for (let i = 0; i <= 4; i++) {
            const yVal = minVal + (i / 4) * valRange;
            const y = getY(yVal);
            ctx.beginPath();
            ctx.moveTo(paddingLeft, y);
            ctx.lineTo(canvas.width - paddingRight, y);
            ctx.stroke();
            
            ctx.fillStyle = '#64748b';
            ctx.font = '7px monospace';
            ctx.fillText(yVal.toFixed(1), 5, y + 3.5);
        }
        
        ctx.strokeStyle = '#0284c7';
        ctx.lineWidth = 2;
        ctx.beginPath();
        numericalVals.forEach((d, idx) => {
            const x = getX(idx);
            const y = getY(d.val);
            if (idx === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        });
        ctx.stroke();
        
        numericalVals.forEach((d, idx) => {
            const x = getX(idx);
            const y = getY(d.val);
            
            ctx.fillStyle = '#0284c7';
            ctx.beginPath();
            ctx.arc(x, y, 3.5, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = '#ffffff';
            ctx.beginPath();
            ctx.arc(x, y, 1.5, 0, Math.PI * 2);
            ctx.fill();
            
            const labelStr = d.dateStr.split('/')[0] + '/' + d.dateStr.split('/')[1];
            ctx.fillStyle = '#64748b';
            ctx.font = '7px sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(labelStr, x, canvas.height - 6);
        });
        ctx.textAlign = 'left';
    }

    const isEmocromo = testName.toLowerCase().includes('emocromo');
    const scatterSection = document.getElementById('val-scattergram-section');
    if (scatterSection) {
        if (isEmocromo) {
            scatterSection.style.display = 'block';
            if (typeof window.drawWbcScattergram === 'function') {
                window.drawWbcScattergram(patientId);
            }
        } else {
            scatterSection.style.display = 'none';
        }
    }
};

window.printValidationList = function() {
    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];

    const patientQuery = (document.getElementById('val-filter-patient')?.value || '').toLowerCase().trim();
    const barcodeQuery = (document.getElementById('val-filter-barcode')?.value || '').toLowerCase().trim();
    const startDate = document.getElementById('val-filter-start-date')?.value || '';
    const endDate = document.getElementById('val-filter-end-date')?.value || '';
    const statusFilter = document.getElementById('val-filter-status')?.value || 'to_validate';
    const flagsFilter = document.getElementById('val-filter-flags')?.value || 'all';

    const validStatuses = ['to_validate', 'validated', 'completed'];

    const filtered = samples.filter(sam => {
        if (!validStatuses.includes(sam.status)) return false;
        if (statusFilter !== 'all' && sam.status !== statusFilter) return false;
        if (barcodeQuery && !sam.barcode.toLowerCase().includes(barcodeQuery)) return false;
        
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const pName = `${p.first_name || ''} ${p.last_name || ''} ${p.fiscal_code || ''}`.toLowerCase();
        if (patientQuery && !pName.includes(patientQuery)) return false;
        
        if (startDate) {
            const collected = new Date(sam.collected_at || sam.created_at);
            const start = new Date(startDate);
            start.setHours(0,0,0,0);
            if (collected < start) return false;
        }
        if (endDate) {
            const collected = new Date(sam.collected_at || sam.created_at);
            const end = new Date(endDate);
            end.setHours(23,59,59,999);
            if (collected > end) return false;
        }
        
        if (flagsFilter !== 'all') {
            const samTests = tests.filter(t => t.sample_id === sam.id);
            const hasFlags = samTests.some(t => t.status === 'flagged');
            if (flagsFilter === 'has_flags' && !hasFlags) return false;
            if (flagsFilter === 'normal_only' && hasFlags) return false;
        }
        
        return true;
    });

    if (filtered.length === 0) {
        alert("Nessun campione da stampare con i filtri correnti.");
        return;
    }

    const printWindow = window.open('', '_blank');
    if (!printWindow) {
        alert("Abilita i pop-up per poter visualizzare la stampa.");
        return;
    }

    let rowsHTML = '';
    filtered.forEach(sam => {
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const pName = `${p.last_name || ''} ${p.first_name || ''}`.toUpperCase();
        const samTests = tests.filter(t => t.sample_id === sam.id);
        
        let testsListHTML = '<div style="font-size:0.75rem; color:#475569;">';
        samTests.forEach(t => {
            const isFlag = t.status === 'flagged';
            const flagText = isFlag ? ' <strong style="color:#ef4444;">[!]</strong>' : '';
            testsListHTML += `<span style="margin-right:12px; display:inline-block;">${t.test_name}: <strong>${t.result_value || '-'}</strong> ${t.unit || ''}${flagText}</span>`;
        });
        testsListHTML += '</div>';

        let statusText = 'Da Validare';
        if (sam.status === 'validated') statusText = 'Validato';
        else if (sam.status === 'completed') statusText = 'Refertato';

        const dateStr = sam.collected_at ? new Date(sam.collected_at).toLocaleDateString('it-IT') : new Date(sam.created_at).toLocaleDateString('it-IT');

        rowsHTML += `\n            <tr style="border-bottom:1px solid #e2e8f0;">\n                <td style="padding:8px; font-family:monospace; font-weight:bold;">${sam.barcode}</td>\n                <td style="padding:8px;">${dateStr}</td>\n                <td style="padding:8px; font-weight:bold;">${pName}</td>\n                <td style="padding:8px;">${sam.sample_type}</td>\n                <td style="padding:8px;">${statusText}</td>\n                <td style="padding:8px;">${testsListHTML}</td>\n            </tr>\n        `;
    });

    const filterInfo = `Filtri attivi: ${statusFilter === 'to_validate' ? 'Solo Da Validare' : statusFilter === 'validated' ? 'Solo Validati' : 'Tutti'} | Anomali: ${flagsFilter === 'has_flags' ? 'Solo Fuori Soglia' : flagsFilter === 'normal_only' ? 'Solo Normali' : 'Tutti'}`;

    printWindow.document.write(`\n        <html>\n        <head>\n            <title>NextCare LIS - Stampa Elenco Validazione</title>\n            <style>\n                body { font-family: sans-serif; color: #1e293b; padding: 20px; }\n                table { width: 100%; border-collapse: collapse; margin-top: 20px; }\n                th { background-color: #f1f5f9; text-align: left; padding: 8px; font-size: 0.8rem; text-transform: uppercase; color: #475569; border-bottom: 2px solid #cbd5e1; }\n                .header-table { width: 100%; border: none; margin-bottom: 20px; }\n                .header-table td { border: none; padding: 0; }\n                @media print {\n                    button { display: none; }\n                    body { padding: 0; }\n                }\n            </style>\n        </head>\n        <body>\n            <table class="header-table">\n                <tr>\n                    <td>\n                        <h2 style="margin:0; color:#0284c7;">NextCare - LIS</h2>\n                        <p style="margin:4px 0 0 0; font-size:0.85rem; color:#64748b;">Elenco Campioni per Validazione Clinica</p>\n                    </td>\n                    <td style="text-align:right; font-size:0.8rem; color:#64748b;">\n                        Stampato il: ${new Date().toLocaleString('it-IT')}<br>\n                        ${filterInfo}\n                    </td>\n                </tr>\n            </table>\n\n            <table>\n                <thead>\n                    <tr>\n                        <th style="width:100px;">Barcode</th>\n                        <th style="width:90px;">Data Prelievo</th>\n                        <th style="width:180px;">Paziente</th>\n                        <th style="width:100px;">Tipo</th>\n                        <th style="width:90px;">Stato</th>\n                        <th>Analisi e Risultati</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    ${rowsHTML}\n                </tbody>\n            </table>\n\n            <div style="margin-top:30px; text-align:center;">\n                <button onclick="window.print();" style="padding:8px 16px; background-color:#0284c7; color:white; border:none; border-radius:4px; font-weight:bold; cursor:pointer;">Avvia Stampa</button>\n            </div>\n            <script>\n                window.onload = function() {\n                    setTimeout(function() { window.print(); }, 300);\n                }\n            </script>\n        </body>\n        </html>\n    `);
    printWindow.document.close();
};

window.selectedValidationSampleId = null;
window.selectedValidationSampleIds = [];

window.checkTestValueIsNormal = function(resultValue, referenceRange) {
    if (resultValue === null || resultValue === undefined || String(resultValue).trim() === '') {
        return 'pending';
    }
    const cleanValStr = String(resultValue).replace(',', '.').trim();
    const val = parseFloat(cleanValStr);
    if (isNaN(val)) {
        return 'completed'; // non-numeric (e.g. "Positivo", "Tracce"), assume normal
    }
    if (!referenceRange) return 'completed';

    const cleanRange = referenceRange.trim().replace(/\s+/g, '');

    // min-max
    const hyphenMatch = cleanRange.match(/^([0-9.]+)-([0-9.]+)$/);
    if (hyphenMatch) {
        const min = parseFloat(hyphenMatch[1]);
        const max = parseFloat(hyphenMatch[2]);
        return (val >= min && val <= max) ? 'completed' : 'flagged';
    }

    // < threshold
    const lessMatch = cleanRange.match(/^<([0-9.]+)$/);
    if (lessMatch) {
        return (val < parseFloat(lessMatch[1])) ? 'completed' : 'flagged';
    }

    // > threshold
    const greaterMatch = cleanRange.match(/^>([0-9.]+)$/);
    if (greaterMatch) {
        return (val > parseFloat(greaterMatch[1])) ? 'completed' : 'flagged';
    }

    // <= threshold
    const lessEqMatch = cleanRange.match(/^<=([0-9.]+)$/);
    if (lessEqMatch) {
        return (val <= parseFloat(lessEqMatch[1])) ? 'completed' : 'flagged';
    }

    // >= threshold
    const greaterEqMatch = cleanRange.match(/^>=([0-9.]+)$/);
    if (greaterEqMatch) {
        return (val >= parseFloat(greaterEqMatch[1])) ? 'completed' : 'flagged';
    }

    return 'completed';
};

window.isValidationSampleSelected = function(sampleId) {
    return window.selectedValidationSampleIds.includes(sampleId);
};

window.toggleAllValidationSelection = function(checked) {
    const checkboxes = document.querySelectorAll('.val-sample-checkbox');
    window.selectedValidationSampleIds = [];
    checkboxes.forEach(cb => {
        cb.checked = checked;
        const sId = parseInt(cb.getAttribute('data-sample-id'));
        if (checked && sId) {
            window.selectedValidationSampleIds.push(sId);
        }
    });
    window.updateValidationSelectedCount();
};

window.updateValidationSelectedCount = function() {
    const checkboxes = document.querySelectorAll('.val-sample-checkbox');
    const checkedIds = [];
    checkboxes.forEach(cb => {
        if (cb.checked) {
            checkedIds.push(parseInt(cb.getAttribute('data-sample-id')));
        }
    });
    window.selectedValidationSampleIds = checkedIds;

    const countSpan = document.getElementById('val-selected-count');
    if (countSpan) {
        countSpan.innerText = window.selectedValidationSampleIds.length;
    }
};

window.applyLisValidationFilters = function() {
    window.renderLisValidationView();
};

window.renderLisValidationView = function() {
    if (typeof window.seedValidationHistory === 'function') {
        window.seedValidationHistory();
    }
    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];

    const patientQuery = (document.getElementById('val-filter-patient')?.value || '').toLowerCase().trim();
    const barcodeQuery = (document.getElementById('val-filter-barcode')?.value || '').toLowerCase().trim();
    const startDate = document.getElementById('val-filter-start-date')?.value || '';
    const endDate = document.getElementById('val-filter-end-date')?.value || '';
    const statusFilter = document.getElementById('val-filter-status')?.value || 'to_validate';
    const flagsFilter = document.getElementById('val-filter-flags')?.value || 'all';

    const validStatuses = ['to_validate', 'validated', 'completed'];

    const filtered = samples.filter(sam => {
        if (!validStatuses.includes(sam.status)) return false;

        const p = patients.find(pat => pat.id === sam.patient_id);
        if (!p) return false;

        if (patientQuery) {
            const fullName = `${p.last_name} ${p.first_name}`.toLowerCase();
            if (!fullName.includes(patientQuery)) return false;
        }

        if (barcodeQuery) {
            if (!sam.barcode.toLowerCase().includes(barcodeQuery)) return false;
        }

        const samDate = sam.collected_at ? sam.collected_at.substring(0, 10) : '';
        if (startDate && samDate < startDate) return false;
        if (endDate && samDate > endDate) return false;

        if (statusFilter !== 'all' && sam.status !== statusFilter) return false;

        const samTests = tests.filter(t => t.sample_id === sam.id);
        const hasFlag = samTests.some(t => t.status === 'flagged');
        
        if (flagsFilter === 'has_flags' && !hasFlag) return false;
        if (flagsFilter === 'normal_only' && hasFlag) return false;

        return true;
    });

    filtered.sort((a, b) => new Date(b.collected_at || 0) - new Date(a.collected_at || 0));

    const tbody = document.getElementById('val-samples-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';

    if (filtered.length === 0) {
        tbody.innerHTML = `\n            <tr>\n                <td colspan="3" style="padding: 30px; text-align: center; color: var(--text-secondary); font-size: 0.85rem;">\n                    Nessun campione corrisponde ai filtri selezionati.\n                </td>\n            </tr>\n        `;
        window.selectedValidationSampleId = null;
        document.getElementById('val-detail-placeholder').style.display = 'flex';
        document.getElementById('val-detail-container').style.display = 'none';
        window.updateValidationSelectedCount();
        return;
    }

    filtered.forEach(sam => {
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const pName = `${p.last_name} ${p.first_name}`;
        const formattedDate = sam.collected_at ? new Date(sam.collected_at).toLocaleDateString('it-IT') : '-';

        let statusBadge = '';
        if (sam.status === 'to_validate') {
            statusBadge = '<span class="badge badge-warning" style="background-color: #f97316; color: #fff; font-size: 0.7rem; padding: 2px 6px;">Da Validare</span>';
        } else if (sam.status === 'validated') {
            statusBadge = '<span class="badge badge-success" style="background-color: #10b981; color: #fff; font-size: 0.7rem; padding: 2px 6px;">Validato</span>';
        } else if (sam.status === 'completed') {
            statusBadge = '<span class="badge badge-info" style="background-color: #3b82f6; color: #fff; font-size: 0.7rem; padding: 2px 6px;">Refertato</span>';
        }

        const isChecked = window.isValidationSampleSelected(sam.id) ? 'checked' : '';

        const tr = document.createElement('tr');
        tr.style.cursor = 'pointer';
        tr.style.borderBottom = '1px solid var(--border-color)';
        if (window.selectedValidationSampleId === sam.id) {
            tr.style.background = 'var(--bg-base)';
        }

        tr.innerHTML = `\n            <td style="padding: 10px 12px; text-align: center;" onclick="event.stopPropagation()">\n                <input type="checkbox" class="val-sample-checkbox" data-sample-id="${sam.id}" ${isChecked} onchange="window.updateValidationSelectedCount()" style="cursor: pointer;">\n            </td>\n            <td style="padding: 10px 12px; font-size: 0.8rem;" onclick="window.selectValidationSample(${sam.id})">\n                <strong style="font-family: monospace; color: var(--text-primary);">${sam.barcode}</strong><br>\n                <span style="color: var(--text-secondary); font-weight: 500;">${pName}</span><br>\n                <span style="font-size: 0.7rem; color: var(--text-secondary);">${formattedDate} - ${sam.sample_type.split(' ')[0]}</span>\n            </td>\n            <td style="padding: 10px 12px; text-align: center; vertical-align: middle;" onclick="window.selectValidationSample(${sam.id})">\n                ${statusBadge}\n            </td>\n        `;
        tbody.appendChild(tr);
    });

    if (window.selectedValidationSampleId && filtered.some(s => s.id === window.selectedValidationSampleId)) {
        window.selectValidationSample(window.selectedValidationSampleId);
    } else {
        window.selectedValidationSampleId = null;
        document.getElementById('val-detail-placeholder').style.display = 'flex';
        document.getElementById('val-detail-container').style.display = 'none';
    }

    window.updateValidationSelectedCount();
};

window.selectValidationSample = function(sampleId) {
    window.selectedValidationSampleId = sampleId;

    const tbody = document.getElementById('val-samples-tbody');
    if (tbody) {
        const rows = tbody.querySelectorAll('tr');
        rows.forEach(r => {
            r.style.background = '';
        });
    }

    const checkboxes = document.querySelectorAll('.val-sample-checkbox');
    checkboxes.forEach(cb => {
        const sId = parseInt(cb.getAttribute('data-sample-id'));
        if (sId === sampleId) {
            const tr = cb.closest('tr');
            if (tr) tr.style.background = 'var(--bg-base)';
        }
    });

    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];
    const staff = DB.get('staff') || [];

    const sam = samples.find(s => s.id === sampleId);
    if (!sam) return;

    const p = patients.find(pat => pat.id === sam.patient_id) || {};
    const pName = `${p.last_name} ${p.first_name}`;

    document.getElementById('val-detail-patient-name').innerText = pName;
    document.getElementById('val-detail-barcode').innerText = sam.barcode;
    document.getElementById('val-detail-type').innerText = sam.sample_type;

    let statusBadge = '';
    if (sam.status === 'to_validate') {
        statusBadge = '<span class="badge badge-warning" style="background-color: #f97316; color: #fff; font-size: 0.8rem; padding: 4px 8px;">Da Validare</span>';
    } else if (sam.status === 'validated') {
        statusBadge = '<span class="badge badge-success" style="background-color: #10b981; color: #fff; font-size: 0.8rem; padding: 4px 8px;">Validato</span>';
    } else if (sam.status === 'completed') {
        statusBadge = '<span class="badge badge-info" style="background-color: #3b82f6; color: #fff; font-size: 0.8rem; padding: 4px 8px;">Refertato</span>';
    }
    document.getElementById('val-detail-status-badge').innerHTML = statusBadge;

    const samTests = tests.filter(t => t.sample_id === sampleId);
    const testsTbody = document.getElementById('val-detail-tests-tbody');
    testsTbody.innerHTML = '';

    const categories = {
        'CHIMICA CLINICA': [],
        'ELETTROFORESI PROTEICA': [],
        'EMOCROMO COMPLETO': [],
        'ESAME URINE': []
    };
    
    samTests.forEach(t => {
        let cat = 'CHIMICA CLINICA';
        let cleanName = t.test_name;
        
        if (t.test_name.startsWith('Emocromo (')) {
            cat = 'EMOCROMO COMPLETO';
            cleanName = t.test_name.replace('Emocromo (', '').replace(')', '');
        } else if (t.test_name.startsWith('Elettroforesi (')) {
            cat = 'ELETTROFORESI PROTEICA';
            cleanName = t.test_name.replace('Elettroforesi (', '').replace(')', '');
        } else if (t.test_name.startsWith('Esame Urine (')) {
            cat = 'ESAME URINE';
            cleanName = t.test_name.replace('Esame Urine (', '').replace(')', '');
        }
        
        categories[cat].push({ original: t, cleanName: cleanName });
    });

    Object.keys(categories).forEach(catName => {
        const list = categories[catName];
        if (list.length === 0) return;
        
        const headerTr = document.createElement('tr');
        headerTr.style = 'background-color: var(--bg-base); border-bottom: 1px solid var(--border-color); pointer-events: none;';
        headerTr.innerHTML = `\n            <td colspan="5" style="padding: 6px 10px; font-weight: 700; color: var(--text-secondary); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; background-color: var(--bg-base);">\n                ${catName}\n            </td>\n        `;
        testsTbody.appendChild(headerTr);
        
        list.forEach(item => {
            const t = item.original;
            const isFlagged = t.status === 'flagged';
            const isVerified = t.verified_by !== null;
            
            let rowStyle = '';
            let flagBadge = '';
            if (isFlagged) {
                rowStyle = 'background-color: #fef2f2; color: #991b1b; font-weight: 500;';
                flagBadge = '<span class="badge" style="background-color: #ef4444; color: #fff; font-size: 0.65rem; padding: 1px 4px;">FUORI SOGLIA</span>';
            } else {
                rowStyle = 'background-color: #f0fdf4; color: #166534;';
                flagBadge = '<span class="badge" style="background-color: #10b981; color: #fff; font-size: 0.65rem; padding: 1px 4px;">NORMALE</span>';
            }

            let verBadge = '';
            if (isVerified) {
                const verStaff = staff.find(s => s.id === t.verified_by) || {};
                const verName = verStaff.last_name ? `${verStaff.first_name[0]}. ${verStaff.last_name}` : 'Sist.';
                verBadge = `<span class="text-success" style="font-size: 0.7rem; font-weight: bold;"><i data-lucide="check" style="width: 12px; height: 12px; display: inline-block; vertical-align: middle; margin-right: 2px;"></i> Validato (${verName})</span>`;
            } else {
                verBadge = '<span class="text-muted" style="font-size: 0.7rem; font-style: italic;">In attesa</span>';
            }

            const tr = document.createElement('tr');
            tr.style = rowStyle + '; border-bottom: 1px solid var(--border-color); cursor: pointer; transition: all 0.15s ease;';
            tr.innerHTML = `\n                <td style="padding: 10px 10px; font-weight: 600; padding-left: 22px;">${item.cleanName}</td>\n                <td style="padding: 10px 10px; text-align: center; font-weight: bold; font-size: 0.9rem;">${t.result_value !== null ? t.result_value : '-'}</td>\n                <td style="padding: 10px 10px; font-family: monospace;">${t.unit || '-'}</td>\n                <td style="padding: 10px 10px;">${t.reference_range || 'N/A'}</td>\n                <td style="padding: 10px 10px; text-align: center;">\n                    <div style="display: flex; flex-direction: column; gap: 2px; align-items: center;">\n                        ${flagBadge}\n                        ${verBadge}\n                    </div>\n                </td>\n            `;
            tr.onclick = () => {
                const allRows = testsTbody.querySelectorAll('tr');
                allRows.forEach(r => {
                    r.style.borderLeft = '';
                    r.style.boxShadow = '';
                });
                tr.style.borderLeft = '4px solid var(--primary-color)';
                tr.style.boxShadow = 'inset 4px 0 0 var(--primary-color)';
                window.selectTestForTrend(t.test_name, sam.patient_id, t.unit || '', t.reference_range || '');
            };
            testsTbody.appendChild(tr);
        });
    });

    if (window.lucide) window.lucide.createIcons();

    document.getElementById('val-detail-placeholder').style.display = 'none';
    document.getElementById('val-detail-container').style.display = 'flex';

    if (samTests.length > 0) {
        const firstParamRow = Array.from(testsTbody.querySelectorAll('tr')).find(r => r.style.cursor === 'pointer');
        if (firstParamRow) {
            firstParamRow.click();
        }
    }

    const btnVal = document.getElementById('btn-val-detail-validate');
    if (btnVal) {
        if (sam.status === 'to_validate') {
            btnVal.disabled = false;
            btnVal.style.opacity = '1';
            btnVal.style.cursor = 'pointer';
        } else {
            btnVal.disabled = true;
            btnVal.style.opacity = '0.5';
            btnVal.style.cursor = 'not-allowed';
        }
    }
};

window.validateCurrentSample = function() {
    if (!window.selectedValidationSampleId) return;

    if (!window.isUserAuthorizedToValidate()) {
        alert("Errore di autorizzazione: Solo l'amministratore, il biologo o un medico abilitato alla validazione possono convalidare esami.");
        return;
    }
    
    if (!confirm("Confermi la validazione dei risultati per questo campione?")) return;

    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const currentStaffId = loggedUser.id || 5;

    const sampleId = window.selectedValidationSampleId;
    const tests = DB.get('lab_tests') || [];
    const timestamp = new Date().toISOString();
    
    tests.forEach(t => {
        if (t.sample_id === sampleId) {
            t.verified_by = currentStaffId;
            t.verified_at = timestamp;
        }
    });
    DB.set('lab_tests', tests);

    const updatedSample = DB.update('lab_samples', sampleId, { status: 'validated' });
    DB.logAudit(currentStaffId, "LAB_VALIDATE_SAMPLE", "lab_samples", sampleId, { validated_by: currentStaffId });

    if (updatedSample && updatedSample.session_uid) {
        window.checkAndAutoReportAcceptance(updatedSample.session_uid);
    }

    alert("Campione validato con successo!");
    window.renderLisValidationView();
};

window.editResultsFromValidation = function() {
    if (!window.selectedValidationSampleId) return;
    window.openResultsModal(window.selectedValidationSampleId, true);
};

window.validateSelectedSamples = function() {
    if (!window.isUserAuthorizedToValidate()) {
        alert("Errore di autorizzazione: Solo l'amministratore, il biologo o un medico abilitato alla validazione possono convalidare esami.");
        return;
    }

    if (window.selectedValidationSampleIds.length === 0) {
        alert("Seleziona almeno un campione da validare.");
        return;
    }

    if (!confirm(`Confermi la validazione di ${window.selectedValidationSampleIds.length} campioni selezionati?`)) return;

    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const currentStaffId = loggedUser.id || 5;

    const samples = DB.get('lab_samples') || [];
    const tests = DB.get('lab_tests') || [];
    const timestamp = new Date().toISOString();

    let count = 0;
    window.selectedValidationSampleIds.forEach(id => {
        const sam = samples.find(s => s.id === id);
        if (sam && sam.status === 'to_validate') {
            sam.status = 'validated';
            tests.forEach(t => {
                if (t.sample_id === id) {
                    t.verified_by = currentStaffId;
                    t.verified_at = timestamp;
                }
            });
            DB.logAudit(currentStaffId, "LAB_VALIDATE_SAMPLE", "lab_samples", id, { validated_by: currentStaffId });
            count++;
        }
    });

    const validatedSessionUids = new Set();
    window.selectedValidationSampleIds.forEach(id => {
        const sam = samples.find(s => s.id === id);
        if (sam && sam.status === 'validated' && sam.session_uid) {
            validatedSessionUids.add(sam.session_uid);
        }
    });

    DB.set('lab_samples', samples);
    DB.set('lab_tests', tests);

    validatedSessionUids.forEach(uid => {
        window.checkAndAutoReportAcceptance(uid);
    });

    alert(`Validati con successo ${count} campioni.`);
    window.selectedValidationSampleIds = [];
    window.renderLisValidationView();
};

window.validateSelectedAcceptances = function() {
    if (!window.isUserAuthorizedToValidate()) {
        alert("Errore di autorizzazione: Solo l'amministratore, il biologo o un medico abilitato alla validazione possono convalidare esami.");
        return;
    }

    if (window.selectedValidationSampleIds.length === 0) {
        alert("Seleziona almeno un campione per individuare le accettazioni da validare.");
        return;
    }

    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const currentStaffId = loggedUser.id || 5;

    const samples = DB.get('lab_samples') || [];
    const selectedSamples = samples.filter(s => window.selectedValidationSampleIds.includes(s.id));
    
    const sessionKeys = new Set();
    selectedSamples.forEach(sam => {
        const key = sam.session_uid || `LEGACY-${sam.patient_id}-${(sam.collected_at || sam.created_at || '').substring(0, 13)}`;
        sessionKeys.add(key);
    });

    if (!confirm(`Confermi la validazione di tutte le accettazioni/sessioni collegate (${sessionKeys.size} sessioni)?`)) return;

    const tests = DB.get('lab_tests') || [];
    const timestamp = new Date().toISOString();
    let sampleCount = 0;

    samples.forEach(sam => {
        const key = sam.session_uid || `LEGACY-${sam.patient_id}-${(sam.collected_at || sam.created_at || '').substring(0, 13)}`;
        if (sessionKeys.has(key)) {
            if (sam.status === 'to_validate') {
                sam.status = 'validated';
                tests.forEach(t => {
                    if (t.sample_id === sam.id) {
                        t.verified_by = currentStaffId;
                        t.verified_at = timestamp;
                    }
                });
                DB.logAudit(currentStaffId, "LAB_VALIDATE_SAMPLE", "lab_samples", sam.id, { validated_by: currentStaffId });
                sampleCount++;
            }
        }
    });

    DB.set('lab_samples', samples);
    DB.set('lab_tests', tests);

    sessionKeys.forEach(key => {
        if (key && !key.startsWith('LEGACY-')) {
            window.checkAndAutoReportAcceptance(key);
        }
    });

    alert(`Validazione completata per le sessioni selezionate. Validati ${sampleCount} campioni.`);
    window.selectedValidationSampleIds = [];
    window.renderLisValidationView();
};

window.autoValidateNormalFiltered = function() {
    if (!window.isUserAuthorizedToValidate()) {
        alert("Errore di autorizzazione: Solo l'amministratore, il biologo o un medico abilitato alla validazione possono eseguire la validazione.");
        return;
    }

    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];

    const patientQuery = (document.getElementById('val-filter-patient')?.value || '').toLowerCase().trim();
    const barcodeQuery = (document.getElementById('val-filter-barcode')?.value || '').toLowerCase().trim();
    const startDate = document.getElementById('val-filter-start-date')?.value || '';
    const endDate = document.getElementById('val-filter-end-date')?.value || '';
    const statusFilter = document.getElementById('val-filter-status')?.value || 'to_validate';
    const flagsFilter = document.getElementById('val-filter-flags')?.value || 'all';

    const validStatuses = ['to_validate'];

    const filtered = samples.filter(sam => {
        if (!validStatuses.includes(sam.status)) return false;

        const p = patients.find(pat => pat.id === sam.patient_id);
        if (!p) return false;

        if (patientQuery) {
            const fullName = `${p.last_name} ${p.first_name}`.toLowerCase();
            if (!fullName.includes(patientQuery)) return false;
        }

        if (barcodeQuery) {
            if (!sam.barcode.toLowerCase().includes(barcodeQuery)) return false;
        }

        const samDate = sam.collected_at ? sam.collected_at.substring(0, 10) : '';
        if (startDate && samDate < startDate) return false;
        if (endDate && samDate > endDate) return false;

        if (statusFilter !== 'all' && sam.status !== statusFilter) return false;

        const samTests = tests.filter(t => t.sample_id === sam.id);
        const hasFlag = samTests.some(t => t.status === 'flagged');
        
        if (flagsFilter === 'has_flags' && !hasFlag) return false;
        if (flagsFilter === 'normal_only' && hasFlag) return false;

        return true;
    });

    if (filtered.length === 0) {
        alert("Nessun campione in attesa corrisponde ai filtri selezionati.");
        return;
    }

    if (!confirm(`Confermi la validazione automatica delle analisi NORMALI nei ${filtered.length} campioni filtrati? I risultati fuori soglia rimarranno in sospeso.`)) return;

    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const currentStaffId = loggedUser.id || 5;

    const timestamp = new Date().toISOString();
    let validatedTestsCount = 0;
    let validatedSamplesCount = 0;

    filtered.forEach(sam => {
        const samTests = tests.filter(t => t.sample_id === sam.id);
        
        samTests.forEach(t => {
            if (t.status === 'completed' && t.verified_by === null) {
                t.verified_by = currentStaffId;
                t.verified_at = timestamp;
                validatedTestsCount++;
            }
        });

        const allValidated = samTests.every(t => t.verified_by !== null);
        if (allValidated) {
            sam.status = 'validated';
            validatedSamplesCount++;
            DB.logAudit(currentStaffId, "LAB_VALIDATE_SAMPLE", "lab_samples", sam.id, { validated_by: currentStaffId, auto: true });
        }
    });

    DB.set('lab_tests', tests);
    DB.set('lab_samples', samples);

    alert(`Auto-validazione completata!\n\n- Analisi normali convalidate: ${validatedTestsCount}\n\n- Campioni interamente convalidati: ${validatedSamplesCount}/${filtered.length}`);
    window.renderLisValidationView();
};

window.printDivContent = function(elementOrId) {
    const el = (typeof elementOrId === 'string') ? document.getElementById(elementOrId) : elementOrId;
    if (!el) return;
    
    let iframe = document.getElementById('nextcare-print-iframe');
    if (!iframe) {
        iframe = document.createElement('iframe');
        iframe.id = 'nextcare-print-iframe';
        iframe.style.position = 'absolute';
        iframe.style.width = '0px';
        iframe.style.height = '0px';
        iframe.style.border = 'none';
        document.body.appendChild(iframe);
    }
    
    const doc = iframe.contentWindow.document;
    doc.open();
    doc.write('<html><head><title>Stampa Documento</title>');
    
    const links = document.querySelectorAll('link[rel="stylesheet"], style');
    links.forEach(l => {
        doc.write(l.outerHTML);
    });
    
    doc.write(`\n        <style>\n            body { background: white !important; color: black !important; padding: 20px !important; font-family: 'Inter', -apple-system, sans-serif; }\n            .report-print-container { box-shadow: none !important; border: none !important; padding: 0 !important; margin: 0 !important; max-width: 100% !important; width: 100% !important; pointer-events: none !important; }\n            @media print {\n                body { padding: 0 !important; }\n            }\n        </style>\n        </head>\n        <body>\n            <div class="report-print-container">\n                ${el.innerHTML}\n            </div>\n            <script>\n                window.onload = function() {\n                    window.focus();\n                    setTimeout(function() {\n                        window.print();\n                    }, 250);\n                };\n            </script>\n        </body>\n        </html>\n    `);
    doc.close();
};

window.printActiveModalReport = function() {
    const activeOverlay = document.querySelector('.modal-overlay.active');
    if (activeOverlay) {
        const printContainer = activeOverlay.querySelector('.report-print-container');
        if (printContainer) {
            window.printDivContent(printContainer);
            return;
        }
    }
    window.print();
};

window.drawLisTrendChart = function(data, testName, unit) {
    const chartContainer = document.getElementById('lis-chart-container');
    const canvas = document.getElementById('lis-trend-canvas');
    if (!canvas || !chartContainer) return;
    
    chartContainer.style.display = 'block';
    
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.strokeStyle = '#e2e8f0';
    ctx.lineWidth = 1;
    ctx.strokeRect(0, 0, canvas.width, canvas.height);
    
    ctx.fillStyle = '#1e293b';
    ctx.font = 'bold 10px sans-serif';
    ctx.fillText(`${testName} (${unit})`, 10, 15);
    
    const vals = data.map(d => d.val);
    const minVal = Math.min(...vals) * 0.9;
    const maxVal = Math.max(...vals) * 1.1;
    const valRange = maxVal - minVal || 1;
    
    const paddingLeft = 35;
    const paddingRight = 15;
    const paddingTop = 30;
    const paddingBottom = 25;
    
    const graphWidth = canvas.width - paddingLeft - paddingRight;
    const graphHeight = canvas.height - paddingTop - paddingBottom;
    
    const getX = (index) => paddingLeft + (index / (data.length - 1)) * graphWidth;
    const getY = (val) => paddingTop + graphHeight - ((val - minVal) / valRange) * graphHeight;
    
    ctx.strokeStyle = '#f1f5f9';
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
        const yVal = minVal + (i / 4) * valRange;
        const y = getY(yVal);
        ctx.beginPath();
        ctx.moveTo(paddingLeft, y);
        ctx.lineTo(canvas.width - paddingRight, y);
        ctx.stroke();
        
        ctx.fillStyle = '#64748b';
        ctx.font = '8px monospace';
        ctx.fillText(yVal.toFixed(1), 5, y + 3);
    }
    
    ctx.strokeStyle = '#8b5cf6';
    ctx.lineWidth = 2;
    ctx.beginPath();
    data.forEach((d, idx) => {
        const x = getX(idx);
        const y = getY(d.val);
        if (idx === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    });
    ctx.stroke();
    
    data.forEach((d, idx) => {
        const x = getX(idx);
        const y = getY(d.val);
        
        ctx.fillStyle = '#8b5cf6';
        ctx.beginPath();
        ctx.arc(x, y, 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(x, y, 2, 0, Math.PI * 2);
        ctx.fill();
        
        const dateObj = new Date(d.date);
        const dateStr = `${dateObj.getDate()}/${dateObj.getMonth() + 1}`;
        ctx.fillStyle = '#64748b';
        ctx.font = '8px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(dateStr, x, canvas.height - 8);
    });
    ctx.textAlign = 'left';
};

window.openEditAppointmentModal = function(appId) {
    const appointments = DB.get('appointments') || [];
    const app = appointments.find(a => a.id === appId);
    if (!app) return;
    
    openAddAppointmentModal();
    
    document.getElementById('app-edit-id').value = app.id;
    window.setPatientSelectValue('app-patient', app.patient_id);
    document.getElementById('app-doctor').value = app.doctor_id || '';
    document.getElementById('app-datetime').value = app.appointment_datetime;
    document.getElementById('app-notes').value = app.notes || '';
    document.getElementById('app-duration').value = app.duration_minutes || 30;
    
    const appServices = DB.get('appointment_services') || [];
    selectedCupServiceIds = appServices.filter(as => as.appointment_id === appId).map(as => as.service_id);
    renderSelectedCupTags();
    
    document.querySelector('#modal-add-appointment h2').innerText = "Riprogramma / Modifica Prenotazione";
    document.querySelector('#form-add-appointment button[type="submit"]').innerText = "Salva Modifiche";
};

window.openCancelAppointmentModal = function(appId) {
    document.getElementById('cancel-app-id').value = appId;
    document.getElementById('cancel-reason').value = '';
    document.getElementById('cancel-notes').value = '';
    openModal('modal-cancel-appointment');
};

window.handleCancelAppointmentSubmit = function(e) {
    e.preventDefault();
    const appId = parseInt(document.getElementById('cancel-app-id').value);
    const reason = document.getElementById('cancel-reason').value;
    const notes = document.getElementById('cancel-notes').value;
    
    if (!reason) {
        alert("Selezionare il motivo dell'annullamento.");
        return;
    }
    
    const app = DB.get('appointments').find(a => a.id === appId);
    
    DB.update('appointments', appId, {
        status: 'cancelled',
        cancellation_reason: reason,
        cancellation_notes: notes
    });
    DB.logAudit(6, "CANCEL_APPOINTMENT", "appointments", appId, { reason, notes });

    // Send cancellation email
    const patient = app ? DB.get('patients').find(p => p.id === app.patient_id) : null;
    const appServices = DB.get('appointment_services') || [];
    const services = DB.get('medical_services') || [];
    const linkedServices = appServices.filter(as => as.appointment_id === appId).map(as => services.find(s => s.id === as.service_id)).filter(Boolean);
    const serviceNames = linkedServices.map(s => s.name).join(', ') || 'Prestazione';
    const appDateStr = app ? new Date(app.appointment_datetime).toLocaleString('it-IT') : 'N/A';

    if (patient) {
        const pName = `${patient.first_name} ${patient.last_name}`;
        const detail = `Motivo: ${reason}. Note: ${notes || 'Nessuna nota aggiuntiva'}`;
        window.sendSimulatedEmail(patient.id, 'cancel_appointment', {
            paziente: pName,
            data: appDateStr,
            prestazione: serviceNames,
            dettaglio: detail
        });
    }
    
    closeModal('modal-cancel-appointment');
    renderAppointments();
};

window.runPacsQueryRetrieve = function() {
    const queryName = document.getElementById('pacs-query-name').value.trim().toLowerCase();
    const queryModality = document.getElementById('pacs-query-modality').value;
    
    const log = document.getElementById('pacs-results-log');
    log.style.display = 'block';
    log.innerHTML = 'Avvio C-FIND RQ sul server PACS...<br>Stabilisco associazione DICOM... OK<br>Ricerca per parametri in corso...<br>';
    
    setTimeout(() => {
        const dummyStudies = [
            { id: 101, patientName: "Mario Rossi", birthDate: "1980-01-01", studyDate: "2026-06-11", modality: "CR", desc: "RX Torace Standard", dicom_uid: "1.2.840.113619.2.134.1" },
            { id: 102, patientName: "Mario Rossi", birthDate: "1980-01-01", studyDate: "2026-05-10", modality: "MR", desc: "Risonanza Encefalo", dicom_uid: "1.2.840.113619.2.134.2" },
            { id: 103, patientName: "Flavia Bianchi", birthDate: "1992-06-15", studyDate: "2026-06-02", modality: "US", desc: "Ecografia Addome", dicom_uid: "1.2.840.113619.2.134.3" }
        ];
        
        const filtered = dummyStudies.filter(s => {
            if (queryName && !s.patientName.toLowerCase().includes(queryName)) return false;
            if (queryModality && s.modality !== queryModality) return false;
            return true;
        });
        
        log.innerHTML += `C-FIND RSP Ricevuto. Trovati ${filtered.length} studi.<br>Rilascio associazione DICOM.`;
        
        const resultsDiv = document.getElementById('pacs-study-list');
        resultsDiv.innerHTML = '';
        
        if (filtered.length === 0) {
            resultsDiv.innerHTML = '<span class="text-muted" style="font-size:0.75rem; padding: 5px;">Nessun record corrispondente sul PACS</span>';
        } else {
            filtered.forEach(s => {
                resultsDiv.innerHTML += `\n                    <div style="display:flex; justify-content:space-between; align-items:center; padding:6px; background:var(--bg-base); border:1px solid var(--border-color); border-radius:4px; font-size:0.75rem; margin-bottom: 4px;">\n                        <div>\n                            <strong>${s.patientName}</strong> (${s.modality})<br>\n                            <span style="font-size:0.65rem; color:var(--text-secondary);">${s.desc} - ${s.studyDate}</span>\n                        </div>\n                        <button type="button" class="btn btn-secondary btn-sm" onclick="window.retrievePacsStudy('${s.dicom_uid}', '${s.patientName}', '${s.desc}')" style="padding:2px 6px; font-size:0.65rem;">C-GET</button>\n                    </div>\n                `;
            });
        }
    }, 1000);
};

window.retrievePacsStudy = function(uid, patName, desc) {
    document.getElementById('dicom-pat-id').innerText = "PACS-" + uid.split('.').pop();
    document.getElementById('dicom-pat-name').innerText = patName.toUpperCase();
    document.getElementById('dicom-study-type').innerText = desc;
    currentDicomImage = 'chest';
    drawDicomImage();
    alert(`[PACS INTEGRATION] Studio ${uid} recuperato con successo tramite C-GET. Caricato nel Visualizzatore DICOM.`);
};

window.sendDicomWorklist = function(studyId, eqId) {
    const studies = DB.get('radiology_studies') || [];
    const study = studies.find(s => s.id === studyId);
    if (!study) return;
    
    const equipments = DB.get('equipment') || [];
    const eq = equipments.find(e => e.id === eqId);
    if (!eq) return;
    
    const p = DB.get('patients').find(pat => pat.id === study.patient_id);
    const pName = p ? `${p.last_name} ${p.first_name}` : 'Paziente';
    
    alert(`[MWL DISPATCH SIMULATOR]\nInvio record Modality Worklist (C-FIND RSP):\n- Strumento: ${eq.name} (AE: ${eq.dicom_aetitle || 'EC_ROOM1'})\n- Indirizzo: ${eq.dicom_ip || '192.168.1.150'}:${eq.dicom_port || '104'}\n- Paziente: ${pName}\n- Esame: UID ${study.dicom_series_uid}\n- Stato: Inviato con successo al Modality Worklist!`);
};

window.initLisSimulator = function() {
    window.renderLisLogsAndSimulators();
    
    // Setup interval for logs polling
    if (!window.lisLogsInterval) {
        window.lisLogsInterval = setInterval(() => {
            if (currentTab === 'lis-logs') {
                window.pollInstrumentsLogsAndStatus();
            }
        }, 3000);
    }
};

window.renderLisLogsAndSimulators = function() {
    const grid = document.getElementById('lis-instruments-logs-grid');
    if (!grid) return;
    
    // Check if the current user role is admin
    const roleSelect = document.getElementById('user-role-select');
    const currentRole = roleSelect ? roleSelect.value : 'admin';
    if (currentRole !== 'admin') {
        grid.innerHTML = `\n            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-secondary);">\n                <i data-lucide="shield-alert" style="width: 48px; height: 48px; margin: 0 auto 15px; display: block; color: var(--danger);"></i>\n                <h3 style="margin: 0 0 10px 0; color: var(--text-primary);">Accesso Riservato</h3>\n                <p style="margin: 0;">Questa sezione di monitoraggio e simulazione è accessibile solo agli utenti amministratori.</p>\n            </div>\n        `;
        if (typeof lucide !== 'undefined') lucide.createIcons();
        return;
    }
    
    const equipments = DB.get('equipment') || [];
    const lisEquipments = equipments.filter(e => e.type === 'LIS' && e.status === 'active');
    
    if (lisEquipments.length === 0) {
        grid.innerHTML = `\n            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-secondary);">\n                <i data-lucide="info" style="width: 48px; height: 48px; margin: 0 auto 15px; display: block; color: var(--primary);"></i>\n                <h3 style="margin: 0 0 10px 0; color: var(--text-primary);">Nessun Analizzatore LIS Attivo</h3>\n                <p style="margin: 0;">Configura o attiva uno strumento di tipo LIS nelle impostazioni dell'applicazione per monitorarlo qui.</p>\n            </div>\n        `;
        if (typeof lucide !== 'undefined') lucide.createIcons();
        return;
    }
    
    let html = '';
    lisEquipments.forEach(e => {
        const isSimActive = !!e.lis_simulator_active;
        const connectionType = e.lis_interface_type || 'none';
        const protocol = (connectionType === 'socket' ? e.lis_socket_format : e.lis_file_format) || 'csv';
        const detailInfo = connectionType === 'socket' 
            ? `TCP Socket - Port: ${e.lis_socket_port || 6001} (${protocol.toUpperCase()})`
            : `File Folder - ${protocol.toUpperCase()}`;
            
        html += `
            <div class="card" id="card-sim-inst-${e.id}" style="display: flex; flex-direction: column; height: 500px; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); overflow: hidden;">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; padding: 12px 15px; border-bottom: 1px solid var(--border-color); background: rgba(0,0,0,0.05);">
                    <div>
                        <h3 style="margin: 0; font-size: 1rem; font-weight: 600; display: flex; align-items: center; gap: 8px; color: var(--primary);">
                            <i data-lucide="cpu" style="width: 18px; height: 18px;"></i>
                            ${e.name}
                        </h3>
                        <span style="font-size: 0.75rem; color: var(--text-secondary); font-weight: 500;">${detailInfo}</span>
                    </div>
                    <div style="display: flex; gap: 5px;">
                        <button class="btn btn-secondary btn-xs" onclick="window.clearInstrumentLogs(${e.id})" style="font-size: 0.7rem; padding: 4px 8px; display: flex; align-items: center; gap: 4px;">
                            <i data-lucide="trash-2" style="width: 12px; height: 12px;"></i> Cancella Log
                        </button>
                        <button class="btn btn-secondary btn-xs" onclick="window.pollInstrumentsLogsAndStatus()" style="font-size: 0.7rem; padding: 4px 8px; display: flex; align-items: center; gap: 4px;">
                            <i data-lucide="refresh-cw" style="width: 12px; height: 12px;"></i> Aggiorna
                        </button>
                    </div>
                </div>
                <div class="card-body" style="padding: 15px; display: flex; flex-direction: column; flex-grow: 1; min-height: 0; gap: 15px;">
                    <div style="display: flex; flex-direction: column; flex-grow: 1; min-height: 0;">
                        <span style="font-size: 0.8rem; font-weight: 600; color: var(--primary); margin-bottom: 6px; display: flex; align-items: center; gap: 5px;">
                            <i data-lucide="terminal" style="width: 14px; height: 14px;"></i> Console Interfacciamento Real-time (TX/RX Log)
                        </span>
                        <div id="logs-console-${e.id}" style="font-family: 'Courier New', Courier, monospace; background: #0b0f19; color: #38bdf8; padding: 12px; border-radius: var(--radius-sm); flex-grow: 1; overflow-y: auto; font-size: 0.75rem; border: 1px solid var(--border-color); line-height: 1.4; white-space: pre-wrap; word-break: break-all;">
                            <span style="color: #64748b;">Caricamento log in corso...</span>
                        </div>
                    </div>
                    <div style="padding: 10px; background: rgba(0,0,0,0.1); border: 1px solid var(--border-color); border-radius: var(--radius-sm); display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <span style="font-size: 0.8rem; font-weight: 600; display: block; color: var(--text-main);">Simulatore Strumento Integrato</span>
                            <span style="font-size: 0.72rem; color: var(--text-secondary);">Genera ed invia risultati fittizi per i campioni in accettazione</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span class="badge" id="badge-sim-status-${e.id}" style="padding: 4px 8px; font-weight: 700; font-size: 0.7rem; border-radius: 4px; background-color: ${isSimActive ? '#10b981' : '#64748b'}; color: white; display: inline-block; text-align: center;">
                                ${isSimActive ? 'ATTIVO' : 'SPENTO'}
                            </span>
                            <button class="btn ${isSimActive ? 'btn-danger' : 'btn-primary'} btn-sm" id="btn-toggle-sim-${e.id}" onclick="window.toggleInstrumentSimulator(${e.id})" style="padding: 4px 10px; font-size: 0.75rem; font-weight: 600;">
                                ${isSimActive ? 'Disattiva' : 'Attiva'}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;
    });
    
    grid.innerHTML = html;
    if (typeof lucide !== 'undefined') lucide.createIcons();
    
    // Fetch logs immediately
    window.pollInstrumentsLogsAndStatus();
};

window.toggleInstrumentSimulator = function(eqId) {
    const equipments = DB.get('equipment') || [];
    const eqIndex = equipments.findIndex(e => e.id === eqId);
    if (eqIndex === -1) return;
    
    const currentActiveStatus = !!equipments[eqIndex].lis_simulator_active;
    const newActiveStatus = !currentActiveStatus;
    
    apiCall('/api/toggle-lis-simulator', { equipment_id: eqId, active: newActiveStatus }, (res) => {
        if (res && res.success) {
            equipments[eqIndex].lis_simulator_active = newActiveStatus ? 1 : 0;
            DB.set('equipment', equipments);
            
            // Re-render to update classes/UI
            window.renderLisLogsAndSimulators();
        } else {
            alert("Errore durante il cambio di stato del simulatore LIS");
        }
    });
};

window.clearInstrumentLogs = function(eqId) {
    if (!confirm("Sei sicuro di voler cancellare i log per questo analizzatore?")) return;
    
    apiCall('/api/clear-equipment-logs', { equipment_id: eqId }, (res) => {
        if (res && res.success) {
            const consoleDiv = document.getElementById(`logs-console-${eqId}`);
            if (consoleDiv) {
                consoleDiv.innerHTML = '<span style="color: #64748b;">Nessun pacchetto o log trasmesso / ricevuto per questo strumento.</span>';
            }
        } else {
            alert("Errore durante la cancellazione dei log");
        }
    });
};

window.pollInstrumentsLogsAndStatus = function() {
    const equipments = DB.get('equipment') || [];
    const lisEquipments = equipments.filter(e => e.type === 'LIS' && e.status === 'active');
    
    lisEquipments.forEach(e => {
        // Fetch simulator status from backend
        apiCall('/api/get-lis-simulator-status', { equipment_id: e.id }, (res) => {
            if (res && res.success) {
                const isSimActive = !!res.active;
                const badge = document.getElementById(`badge-sim-status-${e.id}`);
                const btn = document.getElementById(`btn-toggle-sim-${e.id}`);
                
                if (badge && btn) {
                    if (isSimActive) {
                        badge.innerText = "Simulatore Attivo";
                        badge.style.backgroundColor = "#10b981";
                        badge.style.color = "white";
                        btn.innerText = "Disattiva";
                        btn.className = "btn btn-danger btn-sm";
                    } else {
                        badge.innerText = "Simulatore Spento";
                        badge.style.backgroundColor = "#64748b";
                        badge.style.color = "white";
                        btn.innerText = "Attiva";
                        btn.className = "btn btn-primary btn-sm";
                    }
                }
                
                // Keep local storage active state updated in-memory (no set to avoid trigger sync loops)
                e.lis_simulator_active = isSimActive ? 1 : 0;
            }
        });
        
        // Fetch logs
        const consoleDiv = document.getElementById(`logs-console-${e.id}`);
        if (consoleDiv) {
            apiCall('/api/get-equipment-logs', { equipment_id: e.id }, (res) => {
                if (res && res.success && res.logs) {
                    if (res.logs.length === 0) {
                        consoleDiv.innerHTML = '<span style="color: #64748b;">Nessun pacchetto o log trasmesso / ricevuto per questo strumento.</span>';
                        return;
                    }
                    
                    let logHTML = "";
                    res.logs.forEach(log => {
                        const dirColor = log.direction === 'TX' ? '#38bdf8' : '#f43f5e';
                        const dirLabel = log.direction === 'TX' ? 'TX (Invio)' : 'RX (Ricezione)';
                        const formatLabel = log.message_type || 'RAW';
                        
                        // Escape HTML characters
                        const safeContent = log.content
                            .replace(/&/g, "&amp;")
                            .replace(/</g, "&lt;")
                            .replace(/>/g, "&gt;")
                            .replace(/"/g, "&quot;")
                            .replace(/'/g, "&#039;")
                            .replace(/\n\n/g, "\
\n")
                            .replace(/\x0b/g, "&lt;VT&gt;")
                            .replace(/\x1c/g, "&lt;FS&gt;")
                            .replace(/\x0d/g, "&lt;CR&gt;");
                        
                        logHTML += `<div style="margin-bottom: 12px; border-bottom: 1px dashed #334155; padding-bottom: 8px;">\n                            <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 0.7rem; color: #94a3b8; margin-bottom: 4px;">\n                                <span>[${log.timestamp}] <span style="color: ${dirColor};">${dirLabel}</span> (${formatLabel})</span>\n                            </div>\n                            <div style="background: #020617; padding: 8px; border-radius: 4px; border: 1px solid #1e293b; overflow-x: auto; font-family: monospace;">${safeContent}</div>\n                        </div>`;
                    });
                    
                    if (consoleDiv.innerHTML !== logHTML) {
                        consoleDiv.innerHTML = logHTML;
                    }
                } else {
                    consoleDiv.innerHTML = '<span style="color: #f43f5e;">Errore nel caricamento dei log di comunicazione dello strumento.</span>';
                }
            });
        }
    });
};

// ============================================================================

// ============================================================================
// --- 23. REPORTING SERVICES AND ACCEPTANCES IMPLEMENTATION ---
// ============================================================================

window.safeFormatDate = function(dateStr) {
    if (!dateStr) return '--';
    try {
        const d = new Date(dateStr);
        if (isNaN(d.getTime())) return '--';
        return d.toLocaleString('it-IT', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch (e) {
        return '--';
    }
};

window.renderReportingServices = function() {
    try {
        const appointments = (DB.get('appointments') || []).filter(Boolean);
        const appServices = (DB.get('appointment_services') || []).filter(Boolean);
        const services = (DB.get('medical_services') || []).filter(Boolean);
        const patients = (DB.get('patients') || []).filter(Boolean);
        const staff = (DB.get('staff') || []).filter(Boolean);
        const invoices = (DB.get('invoices') || []).filter(Boolean);
        const labTests = (DB.get('lab_tests') || []).filter(Boolean);
        const labSamples = (DB.get('lab_samples') || []).filter(Boolean);
        const radiologyStudies = (DB.get('radiology_studies') || []).filter(Boolean);
        const priceListItems = (DB.get('price_list_items') || []).filter(Boolean);

        // Dynamically populate branch select options
        const branchSelect = document.getElementById('rep-srv-filter-branch');
        if (branchSelect && branchSelect.options.length <= 1) {
            const branches = [...new Set(services.map(s => s.branch).filter(Boolean))];
            branches.forEach(b => {
                const opt = document.createElement('option');
                opt.value = b;
                opt.innerText = b;
                branchSelect.appendChild(opt);
            });
        }

        // Read filters
        const typeVal = document.getElementById('rep-srv-filter-type').value;
        const statusVal = document.getElementById('rep-srv-filter-status').value;
        const startVal = document.getElementById('rep-srv-filter-start').value;
        const endVal = document.getElementById('rep-srv-filter-end').value;
        const branchVal = document.getElementById('rep-srv-filter-branch').value;
        const searchVal = document.getElementById('rep-srv-filter-search').value.toLowerCase().trim();

        const formatReportingCurrency = (val) => {
            const num = Number(val) || 0;
            return num < 0 ? `-€ ${Math.abs(num).toFixed(2)}` : `€ ${num.toFixed(2)}`;
        };

        let list = [];

        // 1. Gather LIS performances from lab_tests
        labTests.forEach(test => {
            const sample = labSamples.find(s => s.id === test.sample_id);
            if (!sample) return;
            
            const patient = patients.find(p => p.id === sample.patient_id);
            const srv = services.find(s => s.id === test.service_id) || { name: test.test_name, type: 'lis', code: '', price: 0, branch: 'Laboratorio' };

            // Resolve verifier doctor
            let docName = '--';
            if (test.verified_by) {
                const st = staff.find(s => s.id === test.verified_by);
                if (st) docName = `Dott. ${st.last_name}`;
            }

            // Determine status
            let status = 'in_progress';
            if (test.status === 'completed' || test.status === 'flagged') {
                status = 'completed';
            }

            // Resolve pricing from invoice
            const invoice = invoices.find(i => i.sample_id === sample.id && !i.is_insurance_invoice);
            let gross = Number(srv.price) || 0;
            let discount = 0;

            if (invoice) {
                if (invoice.custom_rates && invoice.custom_rates[srv.id] !== undefined) {
                    gross = Number(invoice.custom_rates[srv.id]) || 0;
                } else {
                    const listItem = priceListItems.find(pl => pl.price_list_id === invoice.price_list_id && pl.service_id === srv.id);
                    gross = Number(listItem ? listItem.price : gross) || 0;
                }
                const discount_value = Number(invoice.discount_value) || 0;
                const discount_amount = Number(invoice.discount_amount) || 0;
                const subtotal = Number(invoice.subtotal) || 0;
                if (invoice.discount_type === 'percentage') {
                    discount = gross * (discount_value / 100);
                } else if (invoice.discount_type === 'flat' && subtotal > 0) {
                    discount = discount_amount * (gross / subtotal);
                }
            }
            discount = Number(discount) || 0;
            let net = gross - discount;

            list.push({
                date: sample.collected_at,
                patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno',
                patient_tax_code: patient ? patient.tax_code : '',
                service_name: srv.name,
                service_code: srv.code || '',
                doctor_name: docName,
                type: 'lis',
                branch: srv.branch || 'Laboratorio',
                gross: gross,
                discount: discount,
                net: net,
                status: status
            });
        });

        // 2. Gather RIS and Visit performances from radiology_studies
        radiologyStudies.forEach(study => {
            const patient = patients.find(p => p.id === study.patient_id);
            const srv = services.find(s => s.id === study.service_id) || { name: study.study_type === 'VISIT' ? 'Visita Specialistica' : 'Esame RIS', type: study.study_type === 'VISIT' ? 'visita' : 'ris', code: '', price: 0, branch: 'Diagnostica per immagini' };

            // Resolve doctor
            let docName = '--';
            const docStaffId = study.signed_by || study.doctor_id;
            if (docStaffId) {
                const st = staff.find(s => s.id === docStaffId);
                if (st) docName = `Dott. ${st.last_name}`;
            }

            // Determine status
            let status = 'in_progress';
            if (study.status === 'completed' || study.signed_at) {
                status = 'completed';
            }

            // Resolve pricing from invoice
            const invoice = invoices.find(i => (i.study_id === study.id || (i.appointment_id && appointments.some(a => a.id === i.appointment_id && a.patient_id === study.patient_id && a.appointment_datetime === study.scheduled_at))) && !i.is_insurance_invoice);
            let gross = Number(srv.price) || 0;
            let discount = 0;

            if (invoice) {
                if (invoice.custom_rates && invoice.custom_rates[srv.id] !== undefined) {
                    gross = Number(invoice.custom_rates[srv.id]) || 0;
                } else {
                    const listItem = priceListItems.find(pl => pl.price_list_id === invoice.price_list_id && pl.service_id === srv.id);
                    gross = Number(listItem ? listItem.price : gross) || 0;
                }
                const discount_value = Number(invoice.discount_value) || 0;
                const discount_amount = Number(invoice.discount_amount) || 0;
                const subtotal = Number(invoice.subtotal) || 0;
                if (invoice.discount_type === 'percentage') {
                    discount = gross * (discount_value / 100);
                } else if (invoice.discount_type === 'flat' && subtotal > 0) {
                    discount = discount_amount * (gross / subtotal);
                }
            }
            discount = Number(discount) || 0;
            let net = gross - discount;

            list.push({
                date: study.scheduled_at,
                patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno',
                patient_tax_code: patient ? patient.tax_code : '',
                service_name: srv.name,
                service_code: srv.code || '',
                doctor_name: docName,
                type: study.study_type === 'VISIT' ? 'visita' : 'ris',
                branch: srv.branch || (study.study_type === 'VISIT' ? 'Visita' : 'Radiologia'),
                gross: gross,
                discount: discount,
                net: net,
                status: status
            });
        });

        // 3. Gather scheduled appointments that have not been checked in yet (avoiding duplicates)
        appointments.forEach(app => {
            if (app.status !== 'scheduled') return; // completed/cancelled are handled via studies or skipped

            const patient = patients.find(p => p.id === app.patient_id);
            const srvIds = appServices.filter(as => as.appointment_id === app.id).map(as => as.service_id);
            const bookedServices = services.filter(s => srvIds.includes(s.id));

            // Resolve doctor
            let docName = '--';
            if (app.doctor_id) {
                const doc = DB.get('doctors').find(d => d.id === app.doctor_id);
                const st = doc ? staff.find(s => s.id === doc.staff_id) : null;
                if (st) docName = `Dott. ${st.last_name}`;
            }

            bookedServices.forEach(srv => {
                list.push({
                    date: app.appointment_datetime,
                    patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente',
                    patient_tax_code: patient ? patient.tax_code : '',
                    service_name: srv.name,
                    service_code: srv.code || '',
                    doctor_name: docName,
                    type: srv.type,
                    branch: srv.branch || 'Generale',
                    gross: Number(srv.price) || 0,
                    discount: 0,
                    net: Number(srv.price) || 0,
                    status: 'scheduled'
                });
            });
        });

        // 4. Gather Credit Notes (storni) from invoices
        invoices.forEach(inv => {
            const isCN = !!inv.is_credit_note || (inv.invoice_number && inv.invoice_number.startsWith('NDC-'));
            if (!isCN) return;

            let patient = null;
            if (inv.admission_id) {
                const adm = appointments.find(a => a.id === inv.admission_id);
                patient = adm ? patients.find(pat => pat.id === adm.patient_id) : null;
            } else if (inv.appointment_id) {
                const app = appointments.find(a => a.id === inv.appointment_id);
                patient = app ? patients.find(pat => pat.id === app.patient_id) : null;
            } else if (inv.sample_id) {
                const sam = labSamples.find(s => s.id === inv.sample_id);
                patient = sam ? patients.find(pat => pat.id === sam.patient_id) : null;
            } else if (inv.study_id) {
                const st = radiologyStudies.find(s => s.id === inv.study_id);
                patient = st ? patients.find(pat => pat.id === st.patient_id) : null;
            }

            const pName = patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno';
            const pTax = patient ? patient.tax_code : '';

            // Check for stornati services in custom_rates
            const stornati = inv.custom_rates?.stornati_services;
            if (Array.isArray(stornati) && stornati.length > 0) {
                stornati.forEach(srv => {
                    list.push({
                        date: inv.issue_date + "T00:00",
                        patient_name: pName,
                        patient_tax_code: pTax,
                        service_name: `${srv.name} (Stornato)`,
                        service_code: srv.code || '',
                        doctor_name: '--',
                        type: srv.type === 'lis' ? 'lis' : (srv.type === 'VISIT' || srv.type === 'visita' ? 'visita' : 'ris'),
                        branch: srv.branch || (srv.type === 'lis' ? 'Laboratorio' : (srv.type === 'VISIT' || srv.type === 'visita' ? 'Visita' : 'Radiologia')),
                        gross: -Math.abs(srv.price),
                        discount: 0,
                        net: -Math.abs(srv.price),
                        status: 'stornata'
                    });
                });
            } else {
                // Fallback: representing the credit note as a single negative entry
                list.push({
                    date: inv.issue_date + "T00:00",
                    patient_name: pName,
                    patient_tax_code: pTax,
                    service_name: `Storno / Rimborso (${inv.invoice_number})`,
                    service_code: '',
                    doctor_name: '--',
                    type: 'storno',
                    branch: 'Amministrazione',
                    gross: -Math.abs(Number(inv.subtotal) || 0),
                    discount: 0,
                    net: -Math.abs(Number(inv.amount_due) || 0),
                    status: 'stornata'
                });
            }
        });

        const aiSearchVal = document.getElementById('rep-srv-filter-ai-search')?.value || '';
        let aiFilter = null;
        if (aiSearchVal) {
            aiFilter = window.parseNaturalLanguageQuery(aiSearchVal, 'rep_srv');
        }

        // Apply filtering
        const filtered = list.filter(item => {
            if (typeVal && item.type !== typeVal) return false;
            if (branchVal && item.branch !== branchVal) return false;

            if (aiFilter?.serviceType) {
                if (aiFilter.serviceType === 'visita' && item.type !== 'visita') return false;
                if (aiFilter.serviceType === 'lis' && item.type !== 'lis') return false;
                if (aiFilter.serviceType === 'ris' && item.type !== 'ris') return false;
            }

            const dateStr = item.date ? item.date.substring(0, 10) : '';
            if (startVal && dateStr < startVal) return false;
            if (aiFilter?.startDate && dateStr < aiFilter.startDate) return false;

            if (endVal && dateStr > endVal) return false;
            if (aiFilter?.endDate && dateStr > aiFilter.endDate) return false;

            if (statusVal && item.status !== statusVal) return false;
            if (aiFilter?.status) {
                if (aiFilter.status === 'scheduled' && item.status !== 'scheduled') return false;
                if (aiFilter.status === 'completed' && item.status !== 'completed') return false;
                if (aiFilter.status === 'in_progress' && item.status !== 'in_progress') return false;
                if (aiFilter.status === 'stornata' && item.status !== 'stornata') return false;
            }

            if (aiFilter?.doctorName) {
                if (!item.doctor_name.toLowerCase().includes(aiFilter.doctorName)) return false;
            }

            const searchQuery = (aiFilter ? aiFilter.textQuery : searchVal).toLowerCase().trim();
            if (searchQuery) {
                const pName = item.patient_name.toLowerCase();
                const pTax = item.patient_tax_code.toLowerCase();
                const dName = item.doctor_name.toLowerCase();
                const sName = item.service_name.toLowerCase();
                if (!pName.includes(searchQuery) && !pTax.includes(searchQuery) && !dName.includes(searchQuery) && !sName.includes(searchQuery)) {
                    return false;
                }
            }
            return true;
        });

        // Render table rows
        const tbody = document.querySelector('#reporting-services-table tbody');
        if (tbody) {
            tbody.innerHTML = '';
            
            const paginated = window.setupTablePagination('reporting-services-table', filtered, () => window.renderReportingServices());

            if (filtered.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;" class="text-muted">Nessuna prestazione erogata per i filtri selezionati</td></tr>`;
            } else {
                paginated.forEach(item => {
                    const tr = document.createElement('tr');
                    let statusBadge = '';
                    if (item.status === 'scheduled') statusBadge = '<span class="badge badge-info">Prenotata</span>';
                    else if (item.status === 'in_progress') statusBadge = '<span class="badge badge-warning">Accettata</span>';
                    else if (item.status === 'stornata') statusBadge = '<span class="badge badge-danger">Stornata</span>';
                    else statusBadge = '<span class="badge badge-success">Refertata</span>';

                    const displayDate = window.safeFormatDate(item.date);

                    const gVal = Number(item.gross) || 0;
                    const dVal = Number(item.discount) || 0;
                    const nVal = Number(item.net) || 0;

                    tr.innerHTML = `\n                        <td>${displayDate}</td>\n                        <td><strong>${item.patient_name}</strong><br><span style="font-size:0.7rem; color:var(--text-secondary); font-family:monospace;">${item.patient_tax_code}</span></td>\n                        <td>${item.service_name} ${item.service_code ? `<br><code style="font-size:0.75rem;">(${item.service_code})</code>` : ''}</td>\n                        <td>${item.doctor_name}</td>\n                        <td><span style="font-size:0.75rem; text-transform:uppercase; font-weight:600;">${item.type}</span> / <span class="text-muted" style="font-size:0.75rem;">${item.branch}</span></td>\n                        <td>${formatReportingCurrency(gVal)}</td>\n                        <td><span class="${dVal > 0 ? 'text-danger' : 'text-muted'}">${formatReportingCurrency(dVal)}</span></td>\n                        <td><strong>${formatReportingCurrency(nVal)}</strong></td>\n                        <td>${statusBadge}</td>\n                    `;
                    tbody.appendChild(tr);
                });
            }
        }

        // Update KPIs
        let totalGross = 0;
        let totalDiscount = 0;
        let totalNet = 0;

        filtered.forEach(item => {
            totalGross += Number(item.gross) || 0;
            totalDiscount += Number(item.discount) || 0;
            totalNet += Number(item.net) || 0;
        });

        const countKpi = document.getElementById('rep-srv-kpi-count');
        const revenueKpi = document.getElementById('rep-srv-kpi-revenue');
        const discountKpi = document.getElementById('rep-srv-kpi-discount');
        const netKpi = document.getElementById('rep-srv-kpi-net');

        if (countKpi) countKpi.innerText = filtered.length;
        if (revenueKpi) revenueKpi.innerText = formatReportingCurrency(totalGross);
        if (discountKpi) discountKpi.innerText = formatReportingCurrency(totalDiscount);
        if (netKpi) netKpi.innerText = formatReportingCurrency(totalNet);
    } catch (error) {
        console.error("Errore in renderReportingServices:", error);
        const tbody = document.querySelector('#reporting-services-table tbody');
        if (tbody) {
            tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; color: var(--danger-color);" class="text-danger">\n                <strong>Errore nel rendering delle prestazioni:</strong><br>${error.message}\n            </td></tr>`;
        }
    }
};

window.printReportingServices = function() {
    const tbody = document.querySelector('#reporting-services-table tbody');
    if (!tbody) return;
    
    // Create print container
    const printDiv = document.createElement('div');
    printDiv.innerHTML = `\n        <div style="text-align: center; border-bottom: 2px solid #3b82f6; padding-bottom: 10px; margin-bottom: 20px;">\n            <h1 style="margin: 0; color: #1e3a8a; font-size: 1.6rem;">NextCare Clinical Management Platform</h1>\n            <p style="margin: 3px 0 0 0; font-size: 0.85rem; color: #475569;">Report Analitico Prestazioni ed Esami Erogati</p>\n            <p style="margin: 2px 0 0 0; font-size: 0.75rem; color: #64748b;">Generato il: ${new Date().toLocaleString('it-IT')}</p>\n        </div>\n        \n        <div style="display: flex; gap: 15px; margin-bottom: 20px;">\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Totale Prestazioni</span><br>\n                <strong style="font-size:1.3rem; color:#1e3a8a;">${document.getElementById('rep-srv-kpi-count').innerText}</strong>\n            </div>\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Fatturato Lordo</span><br>\n                <strong style="font-size:1.3rem; color:#10b981;">${document.getElementById('rep-srv-kpi-revenue').innerText}</strong>\n            </div>\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Sconti Applicati</span><br>\n                <strong style="font-size:1.3rem; color:#ef4444;">${document.getElementById('rep-srv-kpi-discount').innerText}</strong>\n            </div>\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Fatturato Netto</span><br>\n                <strong style="font-size:1.3rem; color:#8b5cf6;">${document.getElementById('rep-srv-kpi-net').innerText}</strong>\n            </div>\n        </div>\n\n        <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">\n            <thead>\n                <tr style="background-color: #f1f5f9; border-bottom: 2px solid #cbd5e1;">\n                    <th style="padding: 8px; text-align: left; border: 1px solid #e2e8f0;">Data / Ora</th>\n                    <th style="padding: 8px; text-align: left; border: 1px solid #e2e8f0;">Paziente</th>\n                    <th style="padding: 8px; text-align: left; border: 1px solid #e2e8f0;">Prestazione</th>\n                    <th style="padding: 8px; text-align: left; border: 1px solid #e2e8f0;">Medico</th>\n                    <th style="padding: 8px; text-align: left; border: 1px solid #e2e8f0;">Tipo/Branca</th>\n                    <th style="padding: 8px; text-align: right; border: 1px solid #e2e8f0;">Lordo</th>\n                    <th style="padding: 8px; text-align: right; border: 1px solid #e2e8f0;">Sconto</th>\n                    <th style="padding: 8px; text-align: right; border: 1px solid #e2e8f0;">Netto</th>\n                    <th style="padding: 8px; text-align: center; border: 1px solid #e2e8f0;">Stato</th>\n                </tr>\n            </thead>\n            <tbody>\n                ${tbody.innerHTML}\n            </tbody>\n        </table>\n        \n        <div style="margin-top: 30px; text-align: right; font-size: 0.75rem; color: #64748b;">\n            <p>Direzione Amministrativa NextCare</p>\n        </div>\n    `;
    
    // Call print utility
    window.printDivContent(printDiv);
};

window.exportReportingServicesCSV = function() {
    const tbody = document.querySelector('#reporting-services-table tbody');
    if (!tbody) return;
    
    const rows = tbody.querySelectorAll('tr');
    if (rows.length === 0 || (rows.length === 1 && rows[0].innerText.includes('Nessuna'))) {
        alert("Nessun dato da esportare.");
        return;
    }

    let csv = [];
    // Header
    csv.push('"Data/Ora";"Paziente";"Codice Fiscale";"Prestazione";"Codice Prestazione";"Medico";"Tipo";"Branca";"Lordo";"Sconto";"Netto";"Stato"');

    rows.forEach(tr => {
        const cols = tr.querySelectorAll('td');
        if (cols.length < 9) return;

        // Parse date
        const date = cols[0].innerText.trim();
        // Parse patient and tax code
        const pLines = cols[1].innerHTML.split('<br>');
        const patient = pLines[0].replace(/<\/?strong>/g, '').trim();
        const taxCode = pLines[1] ? pLines[1].replace(/<[^>]*>/g, '').trim() : '';
        // Parse service name and code
        const sLines = cols[2].innerHTML.split('<br>');
        const service = sLines[0].trim();
        const code = sLines[1] ? sLines[1].replace(/[()]/g, '').replace(/<[^>]*>/g, '').trim() : '';
        
        const doctor = cols[3].innerText.trim();
        
        // Parse type/branch
        const tbParts = cols[4].innerText.split('/');
        const type = tbParts[0] ? tbParts[0].trim() : '';
        const branch = tbParts[1] ? tbParts[1].trim() : '';
        
        // Prices
        const gross = cols[5].innerText.replace('€', '').trim();
        const discount = cols[6].innerText.replace('€', '').trim();
        const net = cols[7].innerText.replace('€', '').trim();
        const status = cols[8].innerText.trim();

        csv.push(`"${date}";"${patient}";"${taxCode}";"${service}";"${code}";"${doctor}";"${type}";"${branch}";"${gross}";"${discount}";"${net}";"${status}"`);
    });

    const csvString = csv.join("\n\n");
    const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
    const filename = `nextcare_report_prestazioni_${new Date().toISOString().split('T')[0]}.csv`;
    
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", filename);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
};

window.renderReportingAcceptances = function() {
    try {
        const invoices = (DB.get('invoices') || []).filter(Boolean);
        const admissions = (DB.get('admissions') || []).filter(Boolean);
        const appointments = (DB.get('appointments') || []).filter(Boolean);
        const labSamples = (DB.get('lab_samples') || []).filter(Boolean);
        const patients = (DB.get('patients') || []).filter(Boolean);
        const insurances = (DB.get('insurances') || []).filter(Boolean);
        const patientClaims = (DB.get('patient_claims') || []).filter(Boolean);
        const priceLists = (DB.get('price_lists') || []).filter(Boolean);
        const appServices = (DB.get('appointment_services') || []).filter(Boolean);
        const labTests = (DB.get('lab_tests') || []).filter(Boolean);
        const services = (DB.get('medical_services') || []).filter(Boolean);
        const radiologyStudies = (DB.get('radiology_studies') || []).filter(Boolean);

        // Populate price lists select
        const listinoSelect = document.getElementById('rep-acc-filter-listino');
        if (listinoSelect && listinoSelect.options.length <= 1) {
            priceLists.forEach(pl => {
                const opt = document.createElement('option');
                opt.value = pl.id;
                opt.innerText = pl.name;
                listinoSelect.appendChild(opt);
            });
        }

        // Read filters
        const typeVal = document.getElementById('rep-acc-filter-type').value;
        const startVal = document.getElementById('rep-acc-filter-start').value;
        const endVal = document.getElementById('rep-acc-filter-end').value;
        const listinoVal = document.getElementById('rep-acc-filter-listino').value;
        const paymentVal = document.getElementById('rep-acc-filter-payment').value;
        const searchVal = document.getElementById('rep-acc-filter-search').value.toLowerCase().trim();

        const formatReportingCurrency = (val) => {
            const num = Number(val) || 0;
            return num < 0 ? `-€ ${Math.abs(num).toFixed(2)}` : `€ ${num.toFixed(2)}`;
        };

        const episodes = [];

        // 1. Gather LIS episodes (grouped by session_uid or fallback)
        const lisGroups = {};
        labSamples.forEach(sam => {
            const sessionUid = sam.session_uid || ('LIS-FALLBACK-' + sam.patient_id + '-' + sam.collected_at);
            if (!lisGroups[sessionUid]) {
                lisGroups[sessionUid] = [];
            }
            lisGroups[sessionUid].push(sam);
        });

        Object.entries(lisGroups).forEach(([sessionUid, groupSamples]) => {
            const firstSam = groupSamples[0];
            const patient = patients.find(p => p.id === firstSam.patient_id);
            const dateStr = firstSam.collected_at || '';
            const sampleIds = groupSamples.map(s => s.id);
            const groupTests = labTests.filter(t => sampleIds.includes(t.sample_id));
            const codes = [...new Set(groupTests.map(t => {
                const srv = services.find(sv => sv.id === t.service_id);
                return srv ? (srv.code || 'NOCODE') : 'NOCODE';
            }))];

            // Find matching invoices
            const matchingInvoices = invoices.filter(inv => inv.sample_id && sampleIds.includes(inv.sample_id));

            // Calculate economics
            let grossPrice = 0;
            let patientQuota = 0;
            let insuranceQuota = 0;
            let claimId = null;
            let priceListId = null;
            const statusParts = [];

            if (matchingInvoices.length > 0) {
                matchingInvoices.forEach(inv => {
                    if (!claimId && inv.claim_id) claimId = inv.claim_id;
                    if (!priceListId && inv.price_list_id) priceListId = inv.price_list_id;

                    if (inv.is_insurance_invoice) {
                        insuranceQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                    } else {
                        patientQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                        if (inv.insurance_covered_amount) {
                            insuranceQuota += Number(inv.insurance_covered_amount) || 0;
                        }
                    }
                    const isCN = !!inv.is_credit_note || (inv.invoice_number && inv.invoice_number.startsWith('NDC-'));
                    const typeLabel = isCN ? 'NDC' : (inv.is_insurance_invoice ? 'Ass' : 'Paz');
                    const payLabel = inv.payment_status === 'paid' ? 'Pagata' : (inv.payment_status === 'unpaid' ? 'Non Pagata' : inv.payment_status);
                    statusParts.push(`${typeLabel}: ${inv.invoice_number} (${payLabel})`);
                });
            } else {
                // Fallback: calculate price from tests
                groupTests.forEach(t => {
                    const srv = services.find(sv => sv.id === t.service_id);
                    if (srv) grossPrice += Number(srv.price) || 0;
                });
                patientQuota = grossPrice;
                statusParts.push('Non Fatturata');
            }

            // Resolve listino
            const listino = priceLists.find(pl => pl.id === priceListId);
            const plName = listino ? listino.name : 'Nessuno';

            // Resolve insurance
            let insName = 'Privato (Nessuna)';
            if (claimId) {
                const claim = patientClaims.find(c => c.id === claimId);
                const ins = claim ? insurances.find(i => i.id === claim.insurance_id) : null;
                if (ins) insName = ins.name;
            }

            const isPaid = matchingInvoices.length > 0 && matchingInvoices.filter(i => !i.is_insurance_invoice).every(i => i.payment_status === 'paid');

            episodes.push({
                date: dateStr,
                patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno',
                patient_tax_code: patient ? patient.tax_code : '',
                type: 'LIS',
                service_codes: codes.join(', ') || 'Nessuno',
                insurance: insName,
                price_list_id: priceListId,
                price_list_name: plName,
                total_price: grossPrice,
                insurance_quota: insuranceQuota,
                patient_quota: patientQuota,
                invoice_status: statusParts.join(', '),
                is_paid: isPaid
            });
        });

        // 2. Gather RIS and VISIT episodes
        radiologyStudies.forEach(study => {
            const patient = patients.find(p => p.id === study.patient_id);
            const dateStr = study.scheduled_at || '';
            const epType = study.study_type === 'VISIT' ? 'VISIT' : 'RIS';
            const srv = services.find(s => s.id === study.service_id);
            const codes = srv ? [srv.code || 'NOCODE'] : [];

            // Find matching invoices
            const matchingInvoices = invoices.filter(inv => {
                if (inv.study_id === study.id) return true;
                if (study.appointment_id && inv.appointment_id === study.appointment_id) return true;
                return false;
            });

            // Calculate economics
            let grossPrice = 0;
            let patientQuota = 0;
            let insuranceQuota = 0;
            let claimId = null;
            let priceListId = null;
            const statusParts = [];

            if (matchingInvoices.length > 0) {
                matchingInvoices.forEach(inv => {
                    if (!claimId && inv.claim_id) claimId = inv.claim_id;
                    if (!priceListId && inv.price_list_id) priceListId = inv.price_list_id;

                    if (inv.is_insurance_invoice) {
                        insuranceQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                    } else {
                        patientQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                        if (inv.insurance_covered_amount) {
                            insuranceQuota += Number(inv.insurance_covered_amount) || 0;
                        }
                    }
                    const isCN = !!inv.is_credit_note || (inv.invoice_number && inv.invoice_number.startsWith('NDC-'));
                    const typeLabel = isCN ? 'NDC' : (inv.is_insurance_invoice ? 'Ass' : 'Paz');
                    const payLabel = inv.payment_status === 'paid' ? 'Pagata' : (inv.payment_status === 'unpaid' ? 'Non Pagata' : inv.payment_status);
                    statusParts.push(`${typeLabel}: ${inv.invoice_number} (${payLabel})`);
                });
            } else {
                // Fallback: calculate price from service
                if (srv) grossPrice = Number(srv.price) || 0;
                patientQuota = grossPrice;
                statusParts.push('Non Fatturata');
            }

            // Resolve listino
            const listino = priceLists.find(pl => pl.id === priceListId);
            const plName = listino ? listino.name : 'Nessuno';

            // Resolve insurance
            let insName = 'Privato (Nessuna)';
            if (claimId) {
                const claim = patientClaims.find(c => c.id === claimId);
                const ins = claim ? insurances.find(i => i.id === claim.insurance_id) : null;
                if (ins) insName = ins.name;
            }

            const isPaid = matchingInvoices.length > 0 && matchingInvoices.filter(i => !i.is_insurance_invoice).every(i => i.payment_status === 'paid');

            episodes.push({
                date: dateStr,
                patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno',
                patient_tax_code: patient ? patient.tax_code : '',
                type: epType,
                service_codes: codes.join(', ') || 'Nessuno',
                insurance: insName,
                price_list_id: priceListId,
                price_list_name: plName,
                total_price: grossPrice,
                insurance_quota: insuranceQuota,
                patient_quota: patientQuota,
                invoice_status: statusParts.join(', '),
                is_paid: isPaid
            });
        });

        // 3. Gather RICOVERO episodes
        admissions.forEach(adm => {
            const patient = patients.find(p => p.id === adm.patient_id);
            const dateStr = adm.admission_date || '';
            const codes = ['TICKET_RICOVERO'];

            // Find matching invoices
            const matchingInvoices = invoices.filter(inv => inv.admission_id === adm.id);

            // Calculate economics
            let grossPrice = 0;
            let patientQuota = 0;
            let insuranceQuota = 0;
            let claimId = null;
            let priceListId = null;
            const statusParts = [];

            if (matchingInvoices.length > 0) {
                matchingInvoices.forEach(inv => {
                    if (!claimId && inv.claim_id) claimId = inv.claim_id;
                    if (!priceListId && inv.price_list_id) priceListId = inv.price_list_id;

                    if (inv.is_insurance_invoice) {
                        insuranceQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                    } else {
                        patientQuota += Number(inv.amount_due) || 0;
                        grossPrice += Number(inv.subtotal) || 0;
                        if (inv.insurance_covered_amount) {
                            insuranceQuota += Number(inv.insurance_covered_amount) || 0;
                        }
                    }
                    const isCN = !!inv.is_credit_note || (inv.invoice_number && inv.invoice_number.startsWith('NDC-'));
                    const typeLabel = isCN ? 'NDC' : (inv.is_insurance_invoice ? 'Ass' : 'Paz');
                    const payLabel = inv.payment_status === 'paid' ? 'Pagata' : (inv.payment_status === 'unpaid' ? 'Non Pagata' : inv.payment_status);
                    statusParts.push(`${typeLabel}: ${inv.invoice_number} (${payLabel})`);
                });
            } else {
                statusParts.push('Non Fatturata');
            }

            // Resolve listino
            const listino = priceLists.find(pl => pl.id === priceListId);
            const plName = listino ? listino.name : 'Nessuno';

            // Resolve insurance
            let insName = 'Privato (Nessuna)';
            if (claimId) {
                const claim = patientClaims.find(c => c.id === claimId);
                const ins = claim ? insurances.find(i => i.id === claim.insurance_id) : null;
                if (ins) insName = ins.name;
            }

            const isPaid = matchingInvoices.length > 0 && matchingInvoices.filter(i => !i.is_insurance_invoice).every(i => i.payment_status === 'paid');

            episodes.push({
                date: dateStr,
                patient_name: patient ? `${patient.last_name} ${patient.first_name}` : 'Paziente Esterno',
                patient_tax_code: patient ? patient.tax_code : '',
                type: 'RICOVERO',
                service_codes: codes.join(', ') || 'Nessuno',
                insurance: insName,
                price_list_id: priceListId,
                price_list_name: plName,
                total_price: grossPrice,
                insurance_quota: insuranceQuota,
                patient_quota: patientQuota,
                invoice_status: statusParts.join(', '),
                is_paid: isPaid
            });
        });

        const aiSearchVal = document.getElementById('rep-acc-filter-ai-search')?.value || '';
        let aiFilter = null;
        if (aiSearchVal) {
            aiFilter = window.parseNaturalLanguageQuery(aiSearchVal, 'rep_acc');
        }

        // Apply filtering
        const filtered = episodes.filter(ep => {
            if (typeVal && ep.type !== typeVal) return false;
            if (listinoVal && ep.price_list_id !== parseInt(listinoVal)) return false;

            if (aiFilter?.serviceType) {
                const epTypeLower = ep.type.toLowerCase();
                if (aiFilter.serviceType === 'visita' && epTypeLower !== 'visit' && epTypeLower !== 'visita') return false;
                if (aiFilter.serviceType === 'lis' && epTypeLower !== 'lis') return false;
                if (aiFilter.serviceType === 'ris' && epTypeLower !== 'ris') return false;
            }

            const dateStr = ep.date ? ep.date.substring(0, 10) : '';
            if (startVal && dateStr < startVal) return false;
            if (aiFilter?.startDate && dateStr < aiFilter.startDate) return false;

            if (endVal && dateStr > endVal) return false;
            if (aiFilter?.endDate && dateStr > aiFilter.endDate) return false;

            if (paymentVal && (paymentVal === 'paid' ? !ep.is_paid : ep.is_paid)) return false;
            if (aiFilter?.status) {
                if (aiFilter.status === 'completed' && !ep.is_paid) return false;
                if (aiFilter.status === 'unpaid' && ep.is_paid) return false;
            }

            const searchQuery = (aiFilter ? aiFilter.textQuery : searchVal).toLowerCase().trim();
            if (searchQuery) {
                const pName = ep.patient_name.toLowerCase();
                const pTax = ep.patient_tax_code.toLowerCase();
                if (!pName.includes(searchQuery) && !pTax.includes(searchQuery)) return false;
            }
            return true;
        });

        // Render table
        const tbody = document.querySelector('#reporting-acceptances-table tbody');
        if (tbody) {
            tbody.innerHTML = '';

            const paginated = window.setupTablePagination('reporting-acceptances-table', filtered, () => window.renderReportingAcceptances());

            if (filtered.length === 0) {
                tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;" class="text-muted">Nessun episodio di accettazione registrato per i filtri selezionati</td></tr>`;
            } else {
                paginated.forEach(ep => {
                    const tr = document.createElement('tr');
                    const displayDate = window.safeFormatDate(ep.date);

                    const tVal = Number(ep.total_price) || 0;
                    const iVal = Number(ep.insurance_quota) || 0;
                    const pVal = Number(ep.patient_quota) || 0;

                    tr.innerHTML = `\n                        <td>${displayDate}</td>\n                        <td><strong>${ep.patient_name}</strong><br><span style="font-size:0.7rem; color:var(--text-secondary); font-family:monospace;">${ep.patient_tax_code}</span></td>\n                        <td><span class="badge badge-secondary">${ep.type}</span></td>\n                        <td style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${ep.service_codes}"><code>${ep.service_codes}</code></td>\n                        <td>${ep.insurance}</td>\n                        <td style="font-size:0.75rem;">${ep.price_list_name}</td>\n                        <td><strong>${formatReportingCurrency(tVal)}</strong></td>\n                        <td style="color:#059669;">${formatReportingCurrency(iVal)}</td>\n                        <td style="color:#2563eb;">${formatReportingCurrency(pVal)}</td>\n                        <td style="font-size:0.75rem; max-width:200px; white-space:normal; overflow:visible;">${ep.invoice_status}</td>\n                    `;
                    tbody.appendChild(tr);
                });
            }
        }

        // Update KPIs
        let totalRev = 0;
        let totalIns = 0;
        filtered.forEach(ep => {
            totalRev += Number(ep.total_price) || 0;
            totalIns += Number(ep.insurance_quota) || 0;
        });

        const countKpi = document.getElementById('rep-acc-kpi-count');
        const revKpi = document.getElementById('rep-acc-kpi-revenue');
        const insKpi = document.getElementById('rep-acc-kpi-insurance');

        if (countKpi) countKpi.innerText = filtered.length;
        if (revKpi) revKpi.innerText = formatReportingCurrency(totalRev);
        if (insKpi) insKpi.innerText = formatReportingCurrency(totalIns);
    } catch (error) {
        console.error("Errore in renderReportingAcceptances:", error);
        const tbody = document.querySelector('#reporting-acceptances-table tbody');
        if (tbody) {
            tbody.innerHTML = `<tr><td colspan="10" style="text-align:center; color: var(--danger-color);" class="text-danger">\n                <strong>Errore nel rendering delle accettazioni:</strong><br>${error.message}\n            </td></tr>`;
        }
    }
};


window.printReportingAcceptances = function() {
    const tbody = document.querySelector('#reporting-acceptances-table tbody');
    if (!tbody) return;
    
    const printDiv = document.createElement('div');
    printDiv.innerHTML = `\n        <div style="text-align: center; border-bottom: 2px solid #3b82f6; padding-bottom: 10px; margin-bottom: 20px;">\n            <h1 style="margin: 0; color: #1e3a8a; font-size: 1.6rem;">NextCare Clinical Management Platform</h1>\n            <p style="margin: 3px 0 0 0; font-size: 0.85rem; color: #475569;">Registro Centrale Accettazioni ed Episodi di Ricovero</p>\n            <p style="margin: 2px 0 0 0; font-size: 0.75rem; color: #64748b;">Generato il: ${new Date().toLocaleString('it-IT')}</p>\n        </div>\n        \n        <div style="display: flex; gap: 15px; margin-bottom: 20px;">\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Episodi Accettati</span><br>\n                <strong style="font-size:1.3rem; color:#1e3a8a;">${document.getElementById('rep-acc-kpi-count').innerText}</strong>\n            </div>\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Totale Fatturato</span><br>\n                <strong style="font-size:1.3rem; color:#10b981;">${document.getElementById('rep-acc-kpi-revenue').innerText}</strong>\n            </div>\n            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px; text-align: center;">\n                <span style="font-size:0.75rem; color:#64748b; text-transform:uppercase;">Coperto da Convenzioni</span><br>\n                <strong style="font-size:1.3rem; color:#8b5cf6;">${document.getElementById('rep-acc-kpi-insurance').innerText}</strong>\n            </div>\n        </div>\n\n        <table style="width: 100%; border-collapse: collapse; font-size: 0.7rem;">\n            <thead>\n                <tr style="background-color: #f1f5f9; border-bottom: 2px solid #cbd5e1;">\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Data Accettazione</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Paziente</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Tipo</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Codici Prestazioni</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Convenzione / Assicurazione</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Listino</th>\n                    <th style="padding: 6px; text-align: right; border: 1px solid #e2e8f0;">Totale</th>\n                    <th style="padding: 6px; text-align: right; border: 1px solid #e2e8f0;">Quota Ass.</th>\n                    <th style="padding: 6px; text-align: right; border: 1px solid #e2e8f0;">Quota Paz.</th>\n                    <th style="padding: 6px; text-align: left; border: 1px solid #e2e8f0;">Fatture (Stato)</th>\n                </tr>\n            </thead>\n            <tbody>\n                ${tbody.innerHTML}\n            </tbody>\n        </table>\n        \n        <div style="margin-top: 30px; text-align: right; font-size: 0.75rem; color: #64748b;">\n            <p>Direzione Amministrativa NextCare</p>\n        </div>\n    `;
    
    window.printDivContent(printDiv);
};

window.exportReportingAcceptancesCSV = function() {
    const tbody = document.querySelector('#reporting-acceptances-table tbody');
    if (!tbody) return;
    
    const rows = tbody.querySelectorAll('tr');
    if (rows.length === 0 || (rows.length === 1 && rows[0].innerText.includes('Nessun'))) {
        alert("Nessun dato da esportare.");
        return;
    }

    let csv = [];
    csv.push('"Data Accettazione";"Paziente";"Codice Fiscale";"Tipo Accettazione";"Codici Prestazioni";"Assicurazione";"Listino";"Prezzo Totale";"Quota Assicurazione";"Quota Paziente";"Stato Fattura"');

    rows.forEach(tr => {
        const cols = tr.querySelectorAll('td');
        if (cols.length < 10) return;

        const date = cols[0].innerText.trim();
        const pLines = cols[1].innerHTML.split('<br>');
        const patient = pLines[0].replace(/<\/?strong>/g, '').trim();
        const taxCode = pLines[1] ? pLines[1].replace(/<[^>]*>/g, '').trim() : '';
        const type = cols[2].innerText.trim();
        const codes = cols[3].innerText.trim();
        const insurance = cols[4].innerText.trim();
        const listino = cols[5].innerText.trim();
        const total = cols[6].innerText.replace('€', '').trim();
        const insShare = cols[7].innerText.replace('€', '').trim();
        const patShare = cols[8].innerText.replace('€', '').trim();
        const invoiceStatus = cols[9].innerText.trim();

        csv.push(`"${date}";"${patient}";"${taxCode}";"${type}";"${codes}";"${insurance}";"${listino}";"${total}";"${insShare}";"${patShare}";"${invoiceStatus}"`);
    });

    const csvString = csv.join("\n\n");
    const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
    const filename = `nextcare_report_accettazioni_${new Date().toISOString().split('T')[0]}.csv`;
    
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", filename);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
};

window.exportLisRequestsXml = function(e) {
    if (e) e.preventDefault();

    const statusVal = document.getElementById('export-xml-status')?.value || 'pending_all';
    const startDateVal = document.getElementById('export-xml-start-date')?.value || '';
    const endDateVal = document.getElementById('export-xml-end-date')?.value || '';

    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];
    const services = DB.get('medical_services') || [];

    // Filter samples based on user selection
    const filteredSamples = samples.filter(sam => {
        // Status filter
        if (statusVal === 'pending_all') {
            if (sam.status !== 'collected' && sam.status !== 'processing') return false;
        } else if (statusVal !== 'all') {
            if (sam.status !== statusVal) return false;
        }

        // Date filter
        const samDate = new Date(sam.collected_at || sam.created_at);
        if (startDateVal) {
            const startDate = new Date(startDateVal);
            startDate.setHours(0,0,0,0);
            if (samDate < startDate) return false;
        }
        if (endDateVal) {
            const endDate = new Date(endDateVal);
            endDate.setHours(23,59,59,999);
            if (samDate > endDate) return false;
        }

        return true;
    });

    if (filteredSamples.length === 0) {
        alert("Nessuna richiesta LIS corrispondente ai filtri selezionati da esportare.");
        return;
    }

    const requestsPayload = filteredSamples.map(sam => {
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const samTests = tests.filter(t => t.sample_id === sam.id);
        
        // Find unique services for this sample
        const serviceIds = [...new Set(samTests.map(t => t.service_id))];
        const analyses = serviceIds.map(sid => {
            const srv = services.find(s => s.id === sid) || {};
            return {
                code: srv.code || String(srv.id),
                material: srv.biological_material || ''
            };
        });

        const d = new Date(sam.collected_at || sam.created_at || new Date());
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const dd = String(d.getDate()).padStart(2, '0');
        const dateStr = `${yyyy}-${mm}-${dd}`;

        // Convert birth_date to standard YYYY-MM-DD
        let birthDateStr = '';
        if (p.birth_date) {
            const bd = new Date(p.birth_date);
            if (!isNaN(bd.getTime())) {
                const bYyyy = bd.getFullYear();
                const bMm = String(bd.getMonth() + 1).padStart(2, '0');
                const bDd = String(bd.getDate()).padStart(2, '0');
                birthDateStr = `${bYyyy}-${bMm}-${bDd}`;
            }
        }

        return {
            last_name: p.last_name || '',
            first_name: p.first_name || '',
            barcode: sam.barcode,
            gender: p.gender === 'M' || p.gender === 'Maschio' ? 'M' : (p.gender === 'F' || p.gender === 'Femmina' ? 'F' : 'M'),
            birth_date: birthDateStr,
            date: dateStr,
            tax_code: p.tax_code || '',
            analyses: analyses
        };
    });

    fetch('/api/export-lis-requests', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ requests: requestsPayload })
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            // Update status of exported samples from collected to processing
            let updatedCount = 0;
            filteredSamples.forEach(sam => {
                if (sam.status === 'collected') {
                    DB.update('lab_samples', sam.id, { status: 'processing' });
                    updatedCount++;
                }
                DB.logAudit(4, "SAMPLE_EXPORT_LIS", "lab_samples", sam.id, { barcode: sam.barcode });
            });

            // Trigger client side download of XML
            const blob = new Blob([res.data.xml], { type: 'text/xml' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = res.data.filename || 'export.xml';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);

            closeModal('modal-export-lis-xml-filters');
            document.getElementById('form-export-lis-xml')?.reset();

            renderSamples();
            renderLisAcceptances();
            alert(`Esportazione completata! Creato file XML con ${requestsPayload.length} richieste.\n\n${updatedCount} campioni impostati in stato 'In Corso'.`);
        } else {
            alert("Errore durante l'esportazione: " + res.error);
        }
    })
    .catch(err => {
        console.error(err);
        alert("Errore di connessione al server: " + err.message);
    });
};

window.importLisResultsXml = function() {
    fetch('/api/import-lis-results', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({})
    })
    .then(res => res.json())
    .then(res => {
        if (!res.success) {
            alert("Errore durante l'importazione: " + res.error);
            return;
        }

        const data = res.data;
        if (!data.results || data.results.length === 0) {
            alert(data.message || "Nessun risultato da importare.");
            return;
        }

        const samples = DB.get('lab_samples') || [];
        const tests = DB.get('lab_tests') || [];
        const services = DB.get('medical_services') || [];

        let successCount = 0;
        let matchedTestsCount = 0;
        let missingBarcodes = [];

        data.results.forEach(importRes => {
            // Find corresponding sample
            const sample = samples.find(s => s.barcode === importRes.barcode);
            if (!sample) {
                missingBarcodes.push(importRes.barcode);
                return;
            }

            const samTests = tests.filter(t => t.sample_id === sample.id);
            let sampleMatchedAny = false;

            importRes.analyses.forEach(analysis => {
                // Find medical service by code or id
                const service = services.find(s => s.code === analysis.service_code || String(s.id) === analysis.service_code);
                const serviceTests = samTests.filter(t => t.service_id === (service ? service.id : null));

                analysis.tests.forEach(pRes => {
                    let matchedTest = null;

                    // 1. Match by exact name
                    matchedTest = serviceTests.find(t => t.test_name.toLowerCase() === pRes.parameter_name.toLowerCase());

                    // 2. Match by substring
                    if (!matchedTest) {
                        matchedTest = serviceTests.find(t => 
                            t.test_name.toLowerCase().includes(pRes.parameter_name.toLowerCase()) || 
                            pRes.parameter_name.toLowerCase().includes(t.test_name.toLowerCase())
                        );
                    }

                    // 3. Match by parameter code in test name
                    if (!matchedTest && pRes.parameter_code) {
                        matchedTest = serviceTests.find(t => 
                            t.test_name.toLowerCase().includes(pRes.parameter_code.toLowerCase())
                        );
                    }

                    // 4. Positional fallback if only one test is under this service
                    if (!matchedTest && serviceTests.length === 1) {
                        matchedTest = serviceTests[0];
                    }

                    // 5. Global fallback match in all sample tests (if service_code mapping was slightly off)
                    if (!matchedTest) {
                        matchedTest = samTests.find(t => 
                            t.test_name.toLowerCase() === pRes.parameter_name.toLowerCase() ||
                            t.test_name.toLowerCase().includes(pRes.parameter_name.toLowerCase())
                        );
                    }

                    if (matchedTest) {
                        matchedTest.result_value = pRes.value;
                        matchedTest.unit = pRes.unit || matchedTest.unit;
                        
                        // Set reference range if available in import
                        if (pRes.limit_inf || pRes.limit_sup) {
                            if (pRes.limit_inf && pRes.limit_sup) {
                                matchedTest.reference_range = `${pRes.limit_inf}-${pRes.limit_sup}`;
                            } else {
                                matchedTest.reference_range = pRes.limit_inf || pRes.limit_sup;
                            }
                        }

                        // Determine out of bounds status
                        matchedTest.status = pRes.out_of_bounds ? 'flagged' : 'completed';
                        matchedTest.verified_by = 5; // System User
                        matchedTest.verified_at = new Date().toISOString();

                        matchedTestsCount++;
                        sampleMatchedAny = true;
                    }
                });
            });

            if (sampleMatchedAny) {
                // Change sample status to 'to_validate'
                DB.update('lab_samples', sample.id, { status: 'to_validate' });
                DB.logAudit(5, "LAB_IMPORT_RESULTS", "lab_samples", sample.id, { barcode: sample.barcode, source: 'XML' });
                successCount++;
            }
        });

        // Save updated tests database
        DB.set('lab_tests', tests);
        renderSamples();

        let msg = `Importazione completata con successo!\n\n- File elaborati: ${data.message}\n\n- Campioni aggiornati: ${successCount}\n\n- Parametri registrati: ${matchedTestsCount}`;
        if (missingBarcodes.length > 0) {
            msg += `\n\n\n\nAttenzione: I seguenti barcode non sono stati trovati nel sistema: ${missingBarcodes.join(', ')}`;
        }
        alert(msg);
    })
    .catch(err => {
        console.error(err);
        alert("Errore di connessione al server: " + err.message);
    });
};

// --- 30. SUB-TABS NAVIGATION FOR SERVICES CONFIGURATION ---
window.switchServicesSubTab = function(tabName) {
    const tabListBtn = document.getElementById('sub-tab-srv-list');
    const tabTubesBtn = document.getElementById('sub-tab-tubes');
    const tabWorksheetsBtn = document.getElementById('sub-tab-worksheets');
    const tabSampleColBtn = document.getElementById('sub-tab-sample-collection');
    const tabDoseBtn = document.getElementById('sub-tab-dose');
    const contentList = document.getElementById('sub-content-services-list');
    const contentTubes = document.getElementById('sub-content-tubes-config');
    const contentWorksheets = document.getElementById('sub-content-worksheets-config');
    const contentSampleCol = document.getElementById('sub-content-sample-collection-config');
    const contentDose = document.getElementById('sub-content-dose-config');
    
    if (!tabListBtn || !tabTubesBtn || !tabWorksheetsBtn || !contentList || !contentTubes || !contentWorksheets) return;

    tabListBtn.classList.remove('active');
    tabTubesBtn.classList.remove('active');
    tabWorksheetsBtn.classList.remove('active');
    if (tabSampleColBtn) tabSampleColBtn.classList.remove('active');
    if (tabDoseBtn) tabDoseBtn.classList.remove('active');
    
    contentList.style.display = 'none';
    contentTubes.style.display = 'none';
    contentWorksheets.style.display = 'none';
    if (contentSampleCol) contentSampleCol.style.display = 'none';
    if (contentDose) contentDose.style.display = 'none';

    if (tabName === 'services-list') {
        tabListBtn.classList.add('active');
        contentList.style.display = 'block';
    } else if (tabName === 'tubes-config') {
        tabTubesBtn.classList.add('active');
        contentTubes.style.display = 'block';
        window.renderServicesTubesTable();
    } else if (tabName === 'worksheets-config') {
        tabWorksheetsBtn.classList.add('active');
        contentWorksheets.style.display = 'block';
        renderWorksheetsTable();
    } else if (tabName === 'sample-collection-config') {
        if (tabSampleColBtn) tabSampleColBtn.classList.add('active');
        if (contentSampleCol) contentSampleCol.style.display = 'block';
        window.renderSampleCollectionTable();
    } else if (tabName === 'dose-config') {
        if (tabDoseBtn) tabDoseBtn.classList.add('active');
        if (contentDose) contentDose.style.display = 'block';
        window.renderDoseConfigTable();
    }
};

window.renderDoseConfigTable = function() {
    const tbody = document.getElementById('dose-config-table-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';

    const services = DB.get('medical_services') || [];
    const risServices = services.filter(s => s.type === 'ris');
    const doseClasses = DB.get('dose_classes') || [];

    if (risServices.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: var(--text-secondary); padding: 20px;">Nessuna prestazione di tipo RIS (Diagnostica per Immagini) configurata.</td></tr>';
        return;
    }

    risServices.forEach(s => {
        const tr = document.createElement('tr');
        
        let selectHtml = `<select class="form-control srv-dose-select" data-service-id="${s.id}" style="width: 100%; max-width: 300px; padding: 4px 8px; font-size: 0.85rem;">`;
        selectHtml += `<option value="">-- Nessuna Classe --</option>`;
        doseClasses.forEach(dc => {
            const selected = (s.dose_class_id == dc.id) ? 'selected' : '';
            selectHtml += `<option value="${dc.id}" ${selected}>Classe ${dc.code} (${dc.range_msv}) - ${dc.description}</option>`;
        });
        selectHtml += `</select>`;

        tr.innerHTML = `\n            <td><code>${s.code || '-'}</code></td>\n            <td><strong>${s.name}</strong></td>\n            <td><span class="badge badge-info" style="font-size: 0.8rem;">${s.branch || 'RIS'}</span></td>\n            <td>${selectHtml}</td>\n            <td style="text-align: right;">\n                <button class="btn btn-primary btn-sm btn-save-dose" data-service-id="${s.id}" style="padding: 2px 8px; font-size: 0.75rem;">\n                    <i data-lucide="save" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Salva\n                </button>\n            </td>\n        `;
        tbody.appendChild(tr);
    });

    // Add event listeners to the save buttons
    tbody.querySelectorAll('.btn-save-dose').forEach(btn => {
        btn.addEventListener('click', function() {
            const srvId = parseInt(this.getAttribute('data-service-id'));
            const selectEl = tbody.querySelector(`.srv-dose-select[data-service-id="${srvId}"]`);
            const doseClassVal = selectEl.value;
            const doseClassId = doseClassVal ? parseInt(doseClassVal) : null;

            const targetSrv = services.find(srv => srv.id === srvId);
            if (targetSrv) {
                targetSrv.dose_class_id = doseClassId;
                DB.update('medical_services', srvId, targetSrv);
                
                // Show a temporary success style or notice
                this.classList.remove('btn-primary');
                this.classList.add('btn-success');
                this.innerHTML = '<i data-lucide="check" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Salvato';
                if (window.lucide) window.lucide.createIcons();

                setTimeout(() => {
                    this.classList.remove('btn-success');
                    this.classList.add('btn-primary');
                    this.innerHTML = '<i data-lucide="save" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Salva';
                    if (window.lucide) window.lucide.createIcons();
                }, 1500);

                DB.logAudit(6, "UPDATE_SERVICE_DOSE_CLASS", "medical_services", srvId, { name: targetSrv.name, dose_class_id: doseClassId });
            }
        });
    });

    if (window.lucide) window.lucide.createIcons();
};

// --- 31. LIS TUBE TYPES CRUD LOGIC ---
window.renderServicesTubesTable = function() {
    const tbody = document.getElementById('tubes-table-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';
    
    const tubes = DB.get('tube_types') || [];
    if (tubes.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Nessun tipo provetta registrato.</td></tr>';
        return;
    }
    
    tubes.forEach(t => {
        const tr = document.createElement('tr');
        tr.innerHTML = `\n            <td><code>${t.id}</code></td>\n            <td><strong>${t.name}</strong></td>\n            <td><span class="badge badge-secondary" style="font-family: monospace; font-size: 0.85rem; padding: 4px 8px;">${t.suffix}</span></td>\n            <td>\n                <button class="btn btn-secondary btn-sm" onclick="openEditTubeModal(${t.id})" style="padding: 2px 8px; font-size: 0.75rem;">\n                    <i data-lucide="edit-2" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Modifica\n                </button>\n                <button class="btn btn-danger btn-sm" onclick="window.deleteServicesTubeType(${t.id})" style="padding: 2px 8px; font-size: 0.75rem; margin-left: 5px;">\n                    <i data-lucide="trash-2" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Elimina\n                </button>\n            </td>\n        `;
        tbody.appendChild(tr);
    });
    lucide.createIcons();
};

window.openAddTubeModal = function() {
    document.getElementById('form-add-tube').reset();
    document.getElementById('tube-id').value = '';
    document.getElementById('modal-tube-title').innerText = 'Aggiungi Nuovo Tipo Provetta LIS';
    document.getElementById('btn-save-tube').innerText = 'Salva Provetta';
    openModal('modal-add-tube');
};

window.openEditTubeModal = function(id) {
    const tubes = DB.get('tube_types') || [];
    const tube = tubes.find(t => t.id === id);
    if (!tube) return;
    
    document.getElementById('tube-id').value = tube.id;
    document.getElementById('tube-name').value = tube.name;
    document.getElementById('tube-suffix').value = tube.suffix;
    document.getElementById('modal-tube-title').innerText = 'Modifica Tipo Provetta LIS';
    document.getElementById('btn-save-tube').innerText = 'Aggiorna Provetta';
    openModal('modal-add-tube');
};

window.handleTubeSubmit = function(e) {
    e.preventDefault();
    const idVal = document.getElementById('tube-id').value;
    const name = document.getElementById('tube-name').value.trim();
    const suffix = document.getElementById('tube-suffix').value.trim();
    
    const tubes = DB.get('tube_types') || [];
    
    // Verify suffix uniqueness
    const suffixDuplicate = tubes.find(t => t.suffix === suffix && (!idVal || t.id !== parseInt(idVal)));
    if (suffixDuplicate) {
        alert(`Errore: Il suffisso '${suffix}' è già in uso dalla provetta '${suffixDuplicate.name}'.`);
        return;
    }
    
    if (idVal) {
        const id = parseInt(idVal);
        DB.update('tube_types', id, { name, suffix });
        DB.logAudit(4, "UPDATE_TUBE_TYPE", "tube_types", id, { name, suffix });
    } else {
        const newTube = DB.insert('tube_types', { name, suffix });
        DB.logAudit(4, "CREATE_TUBE_TYPE", "tube_types", newTube.id, { name, suffix });
    }
    
    closeModal('modal-add-tube');
    window.renderServicesTubesTable();
    
    // Sync change dropdowns
    populateTubeTypesDropdown('srv-sample');
};

window.deleteServicesTubeType = function(id) {
    if (!confirm("Sei sicuro di voler eliminare questo tipo di provetta? I campioni esistenti associati rimarranno inalterati, ma non sarà più possibile selezionare questa provetta per nuovi esami.")) return;
    DB.delete('tube_types', id);
    DB.logAudit(4, "DELETE_TUBE_TYPE", "tube_types", id, {});
    window.renderServicesTubesTable();
    
    // Sync change dropdowns
    populateTubeTypesDropdown('srv-sample');
};

// --- 31b. LIS SAMPLE COLLECTION TYPES CRUD & BULK LINK LOGIC ---
window.populateSampleCollectionTypesDropdown = function(selectId, addDefaultOption = true, defaultText = "-- Seleziona Tipo Prelievo --") {
    const el = document.getElementById(selectId);
    if (!el) return;
    const types = DB.get('sample_collection_types') || [];
    el.innerHTML = '';
    if (addDefaultOption) {
        el.innerHTML += `<option value="">${defaultText}</option>`;
    }
    types.forEach(t => {
        el.innerHTML += `<option value="${t.id}">${t.name}</option>`;
    });
};

window.renderSampleCollectionTable = function() {
    const tbody = document.getElementById('sample-collection-table-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';
    
    const types = DB.get('sample_collection_types') || [];
    const services = DB.get('medical_services') || [];
    
    if (types.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Nessun tipo prelievo registrato.</td></tr>';
        return;
    }
    
    types.forEach(t => {
        const linkedServices = services.filter(s => s.type === 'lis' && s.sample_collection_type_id == t.id);
        
        let servicesHtml = '';
        if (linkedServices.length > 0) {
            servicesHtml = linkedServices.map(s => `<span class="badge badge-purple" style="margin-right: 4px; margin-bottom: 4px; display: inline-block;">${s.code ? `[${s.code}] ` : ''}${s.name}</span>`).join('');
        } else {
            servicesHtml = '<span class="text-muted" style="font-size: 0.85rem;">Nessun esame associato</span>';
        }
        
        const tr = document.createElement('tr');
        tr.innerHTML = `\n            <td><code>${t.id}</code></td>\n            <td><strong>${t.name}</strong></td>\n            <td><div style="max-height: 120px; overflow-y: auto; display: flex; flex-wrap: wrap; gap: 4px; padding: 4px 0;">${servicesHtml}</div></td>\n            <td style="text-align: right;">\n                <button class="btn btn-secondary btn-sm" onclick="window.openLinkCollectionServicesModal(${t.id})" style="padding: 2px 8px; font-size: 0.75rem;">\n                    <i data-lucide="link" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Associa Esami\n                </button>\n                <button class="btn btn-secondary btn-sm" onclick="window.openEditSampleCollectionModal(${t.id})" style="padding: 2px 8px; font-size: 0.75rem; margin-left: 5px;">\n                    <i data-lucide="edit-2" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Modifica\n                </button>\n                <button class="btn btn-danger btn-sm" onclick="window.deleteSampleCollection(${t.id})" style="padding: 2px 8px; font-size: 0.75rem; margin-left: 5px;">\n                    <i data-lucide="trash-2" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Elimina\n                </button>\n            </td>\n        `;
        tbody.appendChild(tr);
    });
    if (window.lucide) window.lucide.createIcons();
};

window.openAddSampleCollectionModal = function() {
    const form = document.getElementById('form-add-sample-collection');
    if (form) form.reset();
    document.getElementById('sc-edit-id').value = '';
    document.getElementById('sample-collection-modal-title').innerText = 'Aggiungi Nuovo Tipo Prelievo LIS';
    openModal('modal-add-sample-collection');
};

window.openEditSampleCollectionModal = function(id) {
    const types = DB.get('sample_collection_types') || [];
    const type = types.find(t => t.id === id);
    if (!type) return;
    
    document.getElementById('sc-edit-id').value = type.id;
    document.getElementById('sc-name').value = type.name;
    document.getElementById('sample-collection-modal-title').innerText = 'Modifica Tipo Prelievo LIS';
    openModal('modal-add-sample-collection');
};

window.handleSampleCollectionSubmit = function(e) {
    e.preventDefault();
    const idVal = document.getElementById('sc-edit-id').value;
    const name = document.getElementById('sc-name').value.trim();
    
    if (!name) return;
    
    const types = DB.get('sample_collection_types') || [];
    
    if (idVal) {
        const id = parseInt(idVal);
        DB.update('sample_collection_types', id, { name });
        DB.logAudit(6, "UPDATE_SAMPLE_COLLECTION_TYPE", "sample_collection_types", id, { name });
    } else {
        const newType = DB.insert('sample_collection_types', { name });
        DB.logAudit(6, "CREATE_SAMPLE_COLLECTION_TYPE", "sample_collection_types", newType.id, { name });
    }
    
    closeModal('modal-add-sample-collection');
    window.renderSampleCollectionTable();
    
    // Populate dropdowns that display sample collection types
    window.populateSampleCollectionTypesDropdown('srv-sample-collection-type');
    window.populateSampleCollectionTypesDropdown('bulk-srv-sample-collection-type', true, "-- Nessuna modifica --");
};

window.deleteSampleCollection = function(id) {
    if (!confirm("Sei sicuro di voler eliminare questo tipo di prelievo? Le prestazioni LIS collegate verranno scollegate (impostate a Null).")) return;
    
    // First update any associated services
    const services = DB.get('medical_services') || [];
    let modified = false;
    services.forEach(s => {
        if (s.type === 'lis' && s.sample_collection_type_id == id) {
            s.sample_collection_type_id = null;
            modified = true;
        }
    });
    if (modified) {
        DB.set('medical_services', services);
    }
    
    DB.delete('sample_collection_types', id);
    DB.logAudit(6, "DELETE_SAMPLE_COLLECTION_TYPE", "sample_collection_types", id, {});
    
    window.renderSampleCollectionTable();
    window.populateSampleCollectionTypesDropdown('srv-sample-collection-type');
    window.populateSampleCollectionTypesDropdown('bulk-srv-sample-collection-type', true, "-- Nessuna modifica --");
};

window.openLinkCollectionServicesModal = function(id) {
    const types = DB.get('sample_collection_types') || [];
    const type = types.find(t => t.id === id);
    if (!type) return;
    
    document.getElementById('link-sc-id').value = type.id;
    document.getElementById('link-sc-title').innerText = type.name;
    document.getElementById('link-sc-search').value = '';
    
    window.filterLinkScServices();
    openModal('modal-link-collection-services');
};

window.filterLinkScServices = function() {
    const typeId = document.getElementById('link-sc-id').value;
    const searchVal = document.getElementById('link-sc-search').value.toLowerCase().trim();
    
    const services = DB.get('medical_services') || [];
    const lisServices = services.filter(s => s.type === 'lis');
    
    const listContainer = document.getElementById('link-sc-services-list');
    if (!listContainer) return;
    listContainer.innerHTML = '';
    
    const filtered = lisServices.filter(s => s.name.toLowerCase().includes(searchVal) || (s.code && s.code.toLowerCase().includes(searchVal)));
    
    if (filtered.length === 0) {
        listContainer.innerHTML = '<div class="text-muted" style="text-align: center; padding: 15px;">Nessun esame LIS corrispondente</div>';
        return;
    }
    
    filtered.forEach(s => {
        const isChecked = s.sample_collection_type_id == typeId ? 'checked' : '';
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.alignItems = 'center';
        div.style.padding = '8px 5px';
        div.style.borderBottom = '1px solid var(--border-color)';
        div.innerHTML = `\n            <input type="checkbox" id="link-chk-${s.id}" class="link-sc-chk" data-service-id="${s.id}" ${isChecked} style="margin-right: 10px; cursor: pointer;">\n            <label for="link-chk-${s.id}" style="margin: 0; cursor: pointer; flex: 1; font-size: 0.85rem;">\n                <code style="font-weight:700; margin-right: 5px;">${s.code || '-'}</code> ${s.name}\n            </label>\n        `;
        listContainer.appendChild(div);
    });
};

window.saveBulkCollectionServicesLink = function() {
    const typeId = document.getElementById('link-sc-id').value;
    if (!typeId) return;
    
    const services = DB.get('medical_services') || [];
    
    // Gather all currently rendered service checkboxes
    const checkboxes = document.querySelectorAll('.link-sc-chk');
    const checkedIds = new Set();
    const uncheckedIds = new Set();
    
    checkboxes.forEach(chk => {
        const srvId = parseInt(chk.getAttribute('data-service-id'));
        if (chk.checked) {
            checkedIds.add(srvId);
        } else {
            uncheckedIds.add(srvId);
        }
    });
    
    // Update database
    services.forEach(s => {
        if (s.type === 'lis') {
            if (checkedIds.has(s.id)) {
                s.sample_collection_type_id = parseInt(typeId);
            } else if (uncheckedIds.has(s.id) && s.sample_collection_type_id == typeId) {
                s.sample_collection_type_id = null;
            }
        }
    });
    
    DB.set('medical_services', services);
    DB.logAudit(6, "BULK_ASSOCIATE_SAMPLE_COLLECTION", "medical_services", parseInt(typeId), {
        associated_count: checkedIds.size
    });
    
    closeModal('modal-link-collection-services');
    window.renderSampleCollectionTable();
    if (typeof renderServices === 'function') renderServices();
};

// --- 32. FAQ ACCORDION & FILTERING LOGIC ---
window.toggleFaq = function(header) {
    const answer = header.nextElementSibling;
    const icon = header.querySelector('i');
    if (!answer) return;
    if (answer.style.display === 'none' || !answer.style.display) {
        answer.style.display = 'block';
        if (icon) icon.style.transform = 'rotate(180deg)';
    } else {
        answer.style.display = 'none';
        if (icon) icon.style.transform = 'rotate(0deg)';
    }
};

window.filterFaq = function() {
    const query = document.getElementById('faq-search').value.toLowerCase();
    const items = document.querySelectorAll('.faq-item');
    items.forEach(item => {
        const text = item.innerText.toLowerCase();
        if (text.includes(query)) {
            item.style.display = 'block';
        } else {
            item.style.display = 'none';
        }
    });
};

// --- 33. LIS WORKSHEETS CRUD CONFIGURATION LOGIC ---
window.renderWorksheetsTable = function() {
    const worksheets = DB.get('lis_worksheets') || [];
    const services = DB.get('medical_services') || [];
    const tbody = document.getElementById('worksheets-table-tbody');
    if (!tbody) return;
    
    tbody.innerHTML = '';
    
    if (worksheets.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;" class="text-muted">Nessun foglio di lavoro configurato</td></tr>`;
        return;
    }
    
    worksheets.forEach(w => {
        let srvNames = [];
        try {
            const sids = window.safeParseJsonArray(w.service_ids);
            sids.forEach(sid => {
                const srv = services.find(s => s.id === parseInt(sid));
                if (srv) srvNames.push(srv.name);
            });
        } catch (e) {
            console.error(e);
        }
        const srvNamesStr = srvNames.join(', ') || '<span class="text-muted">Nessun esame</span>';
        
        tbody.innerHTML += `\n            <tr>\n                <td><code>${w.id}</code></td>\n                <td><strong>${w.name}</strong></td>\n                <td><span style="font-size: 0.8rem;" class="text-secondary">${srvNamesStr}</span></td>\n                <td>\n                    <div class="row-actions">\n                        <button class="btn btn-secondary btn-sm" onclick="window.openEditWorksheetModal(${w.id})" style="padding: 2px 8px; font-size: 0.75rem;">\n                            <i data-lucide="edit" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Modifica\n                        </button>\n                        <button class="btn btn-danger btn-sm" onclick="window.deleteWorksheet(${w.id})" style="padding: 2px 8px; font-size: 0.75rem; margin-left: 5px;">\n                            <i data-lucide="trash-2" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Elimina\n                        </button>\n                    </div>\n                </td>\n            </tr>\n        `;
    });
    
    if (window.lucide) window.lucide.createIcons();
};

window.populateWorksheetServicesChecklist = function(checkedIds = []) {
    const container = document.getElementById('worksheet-services-container');
    if (!container) return;
    container.innerHTML = '';
    
    const services = DB.get('medical_services') || [];
    const lisServices = services.filter(s => s.type === 'lis');
    
    if (lisServices.length === 0) {
        container.innerHTML = `<span class="text-muted" style="font-size:0.85rem; padding: 10px;">Nessun esame LIS configurato nel sistema.</span>`;
        return;
    }
    
    lisServices.forEach(s => {
        const isChecked = checkedIds.includes(s.id) ? 'checked' : '';
        container.innerHTML += `\n            <label style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 500; color: var(--text-primary); cursor: pointer; padding: 4px 8px; border-radius: var(--radius-sm); transition: background 0.15s;" onmouseover="this.style.background='var(--bg-surface)'" onmouseout="this.style.background='transparent'">\n                <input type="checkbox" name="worksheet-selected-services" value="${s.id}" ${isChecked} style="width: auto; margin: 0; cursor: pointer;">\n                <span><code>${s.code || 'LIS'}</code> - ${s.name}</span>\n            </label>\n        `;
    });
};

window.filterWorksheetServicesChecklist = function() {
    const query = (document.getElementById('worksheet-service-search')?.value || '').toLowerCase();
    const items = document.querySelectorAll('#worksheet-services-container label');
    items.forEach(item => {
        const text = item.innerText.toLowerCase();
        if (text.includes(query)) {
            item.style.display = 'flex';
        } else {
            item.style.display = 'none';
        }
    });
};

window.openAddWorksheetModal = function() {
    document.getElementById('modal-worksheet-title').innerText = "Aggiungi Nuovo Foglio di Lavoro LIS";
    document.getElementById('worksheet-id').value = "";
    document.getElementById('worksheet-name').value = "";
    const searchInput = document.getElementById('worksheet-service-search');
    if (searchInput) searchInput.value = "";
    window.populateWorksheetServicesChecklist([]);
    openModal('modal-add-worksheet');
};

window.openEditWorksheetModal = function(id) {
    const worksheets = DB.get('lis_worksheets') || [];
    const w = worksheets.find(item => item.id === parseInt(id));
    if (!w) return;
    
    document.getElementById('modal-worksheet-title').innerText = "Modifica Foglio di Lavoro LIS";
    document.getElementById('worksheet-id').value = w.id;
    document.getElementById('worksheet-name').value = w.name;
    const searchInput = document.getElementById('worksheet-service-search');
    if (searchInput) searchInput.value = "";
    
    let sids = window.safeParseJsonArray(w.service_ids);
    
    window.populateWorksheetServicesChecklist(sids.map(Number));
    openModal('modal-add-worksheet');
};

window.handleWorksheetSubmit = function(e) {
    if (e) e.preventDefault();
    
    const idVal = document.getElementById('worksheet-id').value;
    const nameVal = document.getElementById('worksheet-name').value.trim();
    
    const checkboxes = document.querySelectorAll('input[name="worksheet-selected-services"]:checked');
    const selectedIds = Array.from(checkboxes).map(cb => parseInt(cb.value));
    
    if (!nameVal) {
        alert("Inserire il nome del foglio di lavoro.");
        return;
    }
    if (selectedIds.length === 0) {
        alert("Selezionare almeno un esame LIS da includere.");
        return;
    }
    
    const worksheets = DB.get('lis_worksheets') || [];
    
    if (idVal) {
        // Edit mode
        const wId = parseInt(idVal);
        const worksheetIdx = worksheets.findIndex(w => w.id === wId);
        if (worksheetIdx !== -1) {
            worksheets[worksheetIdx].name = nameVal;
            worksheets[worksheetIdx].service_ids = selectedIds; // Save directly as array
            DB.set('lis_worksheets', worksheets);
            DB.logAudit(4, "WORKSHEET_UPDATED", "lis_worksheets", wId, { name: nameVal });
        }
    } else {
        // Create mode
        const newId = worksheets.length > 0 ? Math.max(...worksheets.map(w => w.id)) + 1 : 1;
        const newWorksheet = {
            id: newId,
            name: nameVal,
            service_ids: selectedIds // Save directly as array
        };
        worksheets.push(newWorksheet);
        DB.set('lis_worksheets', worksheets);
        DB.logAudit(4, "WORKSHEET_CREATED", "lis_worksheets", newId, { name: nameVal });
    }
    
    closeModal('modal-add-worksheet');
    window.renderWorksheetsTable();
    
    // Refresh LIS dropdown too!
    if (typeof window.populateLisWorksheetsDropdown === 'function') {
        window.populateLisWorksheetsDropdown();
    }
    alert("Foglio di lavoro salvato con successo!");
};

window.deleteWorksheet = function(id) {
    if (!confirm("Sei sicuro di voler eliminare questo foglio di lavoro?")) return;
    
    const worksheets = DB.get('lis_worksheets') || [];
    const filtered = worksheets.filter(w => w.id !== parseInt(id));
    DB.set('lis_worksheets', filtered);
    DB.logAudit(4, "WORKSHEET_DELETED", "lis_worksheets", parseInt(id), {});
    
    window.renderWorksheetsTable();
    if (typeof window.populateLisWorksheetsDropdown === 'function') {
        window.populateLisWorksheetsDropdown();
    }
    alert("Foglio di lavoro eliminato.");
};

window.safeParseJsonArray = function(val) {
    if (!val) return [];
    if (Array.isArray(val)) return val.map(Number);
    try {
        const parsed = typeof val === 'string' ? JSON.parse(val) : val;
        if (Array.isArray(parsed)) return parsed.map(Number);
        if (parsed !== null && parsed !== undefined && !isNaN(parsed)) return [Number(parsed)];
    } catch (e) {
        console.error("Error parsing JSON array:", e);
    }
    return [];
};

// --- 34. LIS WORKSHEETS DATA ENTRY INTERFACE LOGIC ---
window.populateLisWorksheetsDropdown = function() {
    const select = document.getElementById('lis-worksheet-select');
    if (!select) return;
    
    const worksheets = DB.get('lis_worksheets') || [];
    select.innerHTML = '<option value="">-- Seleziona Foglio di lavoro --</option>';
    worksheets.forEach(w => {
        select.innerHTML += `<option value="${w.id}">${w.name}</option>`;
    });
};

window.renderLisWorksheetView = function() {
    const select = document.getElementById('lis-worksheet-select');
    const tbody = document.getElementById('lis-worksheets-data-tbody');
    if (!select || !tbody) return;
    
    const wIdVal = select.value;
    if (!wIdVal) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Seleziona un foglio di lavoro per visualizzare i campioni.</td></tr>`;
        return;
    }
    
    const worksheets = DB.get('lis_worksheets') || [];
    const activeW = worksheets.find(w => w.id === parseInt(wIdVal));
    if (!activeW) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Foglio di lavoro non trovato.</td></tr>`;
        return;
    }
    
    let serviceIds = window.safeParseJsonArray(activeW.service_ids);
    
    if (serviceIds.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Questo foglio di lavoro non contiene esami associati. Configurali nella sezione Impostazioni.</td></tr>`;
        return;
    }
    
    const startDateVal = document.getElementById('lis-worksheet-start-date')?.value || '';
    const endDateVal = document.getElementById('lis-worksheet-end-date')?.value || '';
    
    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];
    
    const aiSearchVal = document.getElementById('lis-worksheet-ai-search')?.value || '';
    let aiFilter = null;
    if (aiSearchVal) {
        aiFilter = window.parseNaturalLanguageQuery(aiSearchVal, 'lis_worksheet');
    }

    // Filter samples within date range & AI parameters
    const filteredSamples = samples.filter(sam => {
        const samDate = new Date(sam.collected_at || sam.created_at);
        if (startDateVal) {
            const sd = new Date(startDateVal);
            sd.setHours(0, 0, 0, 0);
            if (samDate < sd) return false;
        }
        if (aiFilter?.startDate) {
            const sd = new Date(aiFilter.startDate);
            sd.setHours(0, 0, 0, 0);
            if (samDate < sd) return false;
        }
        if (endDateVal) {
            const ed = new Date(endDateVal);
            ed.setHours(23, 59, 59, 999);
            if (samDate > ed) return false;
        }
        if (aiFilter?.endDate) {
            const ed = new Date(aiFilter.endDate);
            ed.setHours(23, 59, 59, 999);
            if (samDate > ed) return false;
        }
        
        // Sample must have at least one test matching the worksheet service IDs
        const matchingTests = tests.filter(t => t.sample_id === sam.id && serviceIds.includes(parseInt(t.service_id)));
        if (matchingTests.length === 0) return false;

        // Apply AI filters on tests status
        if (aiFilter?.status) {
            const statusMatch = matchingTests.some(t => {
                if (aiFilter.status === 'completed' && t.status === 'completed') return true;
                if (aiFilter.status === 'scheduled' && t.status === 'pending') return true;
                return false;
            });
            if (!statusMatch) return false;
        }

        if (aiFilter?.isOutRange) {
            const hasOutOfRange = matchingTests.some(t => t.status === 'flagged');
            if (!hasOutOfRange) return false;
        }

        // Apply text query search
        const p = patients.find(pat => pat.id === sam.patient_id);
        const pName = p ? `${p.last_name} ${p.first_name}`.toLowerCase() : '';
        const taxCode = p ? (p.tax_code || '').toLowerCase() : '';

        const searchQuery = (aiFilter ? aiFilter.textQuery : '').toLowerCase().trim();
        if (searchQuery) {
            const matchesPatient = pName.includes(searchQuery) || taxCode.includes(searchQuery) || sam.barcode.toLowerCase().includes(searchQuery);
            const matchesTests = matchingTests.some(t => t.test_name.toLowerCase().includes(searchQuery));
            if (!matchesPatient && !matchesTests) return false;
        }

        return true;
    });
    
    tbody.innerHTML = '';
    
    if (filteredSamples.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 20px;">Nessun campione trovato per i filtri selezionati.</td></tr>`;
        return;
    }
    
    // Sort samples newest first
    filteredSamples.sort((a, b) => new Date(b.collected_at || b.created_at) - new Date(a.collected_at || a.created_at));
    
    filteredSamples.forEach(sam => {
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const pName = p ? `${p.last_name} ${p.first_name}` : 'Sconosciuto';
        
        let genderIcon = '';
        if (p) {
            const g = (p.gender || '').toUpperCase();
            if (g === 'M' || g === 'MASCHIO') {
                genderIcon = ` <i data-lucide="mars" style="color: #2563eb; width: 14px; height: 14px; vertical-align: middle; margin-left: 4px;" title="Maschio"></i>`;
            } else if (g === 'F' || g === 'FEMMINA') {
                genderIcon = ` <i data-lucide="venus" style="color: #db2777; width: 14px; height: 14px; vertical-align: middle; margin-left: 4px;" title="Femmina"></i>`;
            } else {
                genderIcon = ` <i data-lucide="user" style="color: #64748b; width: 14px; height: 14px; vertical-align: middle; margin-left: 4px;" title="Altro"></i>`;
            }
        }
        const formattedPName = `<strong>${pName}</strong>${genderIcon}`;
        
        // Find tests of this sample that belong to this worksheet
        const matchingTests = tests.filter(t => t.sample_id === sam.id && serviceIds.includes(parseInt(t.service_id)));
        
        matchingTests.forEach((t, index) => {
            const tr = document.createElement('tr');
            
            if (index === 0) {
                // Render spanned cells
                tr.innerHTML = `\n                    <td rowspan="${matchingTests.length}">\n                        <strong>${sam.barcode}</strong><br>\n                        <span class="text-secondary" style="font-size:0.75rem;">${window.safeFormatDate(sam.collected_at || sam.created_at)}</span>\n                    </td>\n                    <td rowspan="${matchingTests.length}">\n                        ${formattedPName}<br>\n                        <span class="text-secondary" style="font-size:0.75rem;">${p.tax_code || ''}</span>\n                    </td>\n                `;
            }
            
            const isFlagged = t.status === 'flagged' ? 'style="border-color: #ef4444; background: #fef2f2; color: #b91c1c;"' : '';
            const refStr = t.reference_range ? `(Rif: ${t.reference_range} ${t.unit || ''})` : '';
            
            tr.innerHTML += `\n                <td><strong>${t.test_name}</strong></td>\n                <td>\n                    <div style="display: flex; align-items: center; gap: 8px;">\n                        <input type="text" class="form-input inline-result-input" data-test-id="${t.id}" value="${t.result_value || ''}" placeholder="Risultato..." ${isFlagged} style="max-width: 110px; padding: 4px 8px; font-size: 0.85rem; font-weight: bold; text-align: center; border: 1px solid var(--border-color); border-radius: var(--radius-sm);" onchange="window.updateLisWorksheetResultValue(${t.id}, this.value)">\n                        <span style="font-size: 0.75rem; color: var(--text-secondary);">${refStr}</span>\n                        ${t.status === 'flagged' ? '<span class="badge badge-danger" style="font-size: 0.65rem; padding: 2px 4px;">FLAG</span>' : ''}\n                    </div>\n                </td>\n            `;
            
            tbody.appendChild(tr);
        });
    });
    
    if (window.lucide) window.lucide.createIcons();
};

window.updateLisWorksheetResultValue = function(testId, val) {
    const tests = DB.get('lab_tests') || [];
    const testIdx = tests.findIndex(t => t.id === parseInt(testId));
    if (testIdx === -1) return;
    
    const t = tests[testIdx];
    val = val.trim();
    t.result_value = val;
    
    let testStatus = 'completed';
    if (val === '') {
        testStatus = 'pending';
    } else {
        const range = t.reference_range ? t.reference_range.split('-') : [];
        if (range.length === 2) {
            const min = parseFloat(range[0]);
            const max = parseFloat(range[1]);
            const numericVal = parseFloat(val);
            if (!isNaN(numericVal) && (numericVal < min || numericVal > max)) {
                testStatus = 'flagged';
            }
        }
    }
    
    t.status = testStatus;
    t.verified_by = 5;
    t.verified_at = new Date().toISOString();
    
    DB.set('lab_tests', tests);
    
    // Automatically transition matching sample status to 'to_validate' if it is in 'collected' or 'processing'
    const samples = DB.get('lab_samples') || [];
    const sam = samples.find(s => s.id === t.sample_id);
    if (sam && (sam.status === 'collected' || sam.status === 'processing')) {
        DB.update('lab_samples', sam.id, { status: 'to_validate' });
    }
    
    DB.logAudit(5, "LAB_ENTER_RESULTS_WORKSHEET", "lab_tests", testId, { result: val, status: testStatus });
    
    // Re-render sheet to show flags/borders
    window.renderLisWorksheetView();
};

window.printLisWorksheet = function() {
    const select = document.getElementById('lis-worksheet-select');
    if (!select) return;
    
    const wIdVal = select.value;
    if (!wIdVal) {
        alert("Seleziona prima un foglio di lavoro da stampare.");
        return;
    }
    
    const worksheets = DB.get('lis_worksheets') || [];
    const activeW = worksheets.find(w => w.id === parseInt(wIdVal));
    if (!activeW) {
        alert("Foglio di lavoro non trovato.");
        return;
    }
    
    let serviceIds = window.safeParseJsonArray(activeW.service_ids);
    
    if (serviceIds.length === 0) {
        alert("Questo foglio di lavoro non contiene esami associati.");
        return;
    }
    
    const startDateVal = document.getElementById('lis-worksheet-start-date')?.value || '';
    const endDateVal = document.getElementById('lis-worksheet-end-date')?.value || '';
    
    const samples = DB.get('lab_samples') || [];
    const patients = DB.get('patients') || [];
    const tests = DB.get('lab_tests') || [];
    
    const filteredSamples = samples.filter(sam => {
        const samDate = new Date(sam.collected_at || sam.created_at);
        if (startDateVal) {
            const sd = new Date(startDateVal);
            sd.setHours(0, 0, 0, 0);
            if (samDate < sd) return false;
        }
        if (endDateVal) {
            const ed = new Date(endDateVal);
            ed.setHours(23, 59, 59, 999);
            if (samDate > ed) return false;
        }
        
        const hasMatchingTest = tests.some(t => t.sample_id === sam.id && serviceIds.includes(parseInt(t.service_id)));
        return hasMatchingTest;
    });
    
    if (filteredSamples.length === 0) {
        alert("Nessun campione da stampare per questo foglio di lavoro con i filtri correnti.");
        return;
    }
    
    filteredSamples.sort((a, b) => new Date(b.collected_at || b.created_at) - new Date(a.collected_at || a.created_at));
    
    const printWindow = window.open('', '_blank');
    if (!printWindow) {
        alert("Consenti i pop-up per poter visualizzare la stampa del foglio di lavoro.");
        return;
    }
    
    let rowsHtml = '';
    filteredSamples.forEach(sam => {
        const p = patients.find(pat => pat.id === sam.patient_id) || {};
        const pName = p ? `${p.last_name} ${p.first_name}` : 'Sconosciuto';
        const samDateStr = window.safeFormatDate(sam.collected_at || sam.created_at);
        
        const matchingTests = tests.filter(t => t.sample_id === sam.id && serviceIds.includes(parseInt(t.service_id)));
        
        matchingTests.forEach((t, index) => {
            let spannedCells = '';
            if (index === 0) {
                spannedCells = `\n                    <td rowspan="${matchingTests.length}" style="padding: 10px; border: 1px solid #cbd5e1; font-family: monospace; font-weight: bold; background: #fff; vertical-align: middle;">\n                        ${sam.barcode}<br>\n                        <span style="font-size: 0.75rem; color: #64748b; font-weight: normal;">${samDateStr}</span>\n                    </td>\n                    <td rowspan="${matchingTests.length}" style="padding: 10px; border: 1px solid #cbd5e1; background: #fff; vertical-align: middle;">\n                        <strong>${pName}</strong><br>\n                        <span style="font-size: 0.75rem; color: #64748b;">${p.tax_code || ''}</span>\n                    </td>\n                `;
            }
            
            const isFlagged = t.status === 'flagged';
            const flagBadge = isFlagged ? '<span style="display: inline-block; padding: 2px 6px; border-radius: 4px; color: white; background: #ef4444; font-size: 0.65rem; font-weight: 700; margin-left: 8px;">FLAG</span>' : '';
            const valStyle = isFlagged ? 'color: #b91c1c; font-weight: bold;' : 'font-weight: bold;';
            const refStr = t.reference_range ? `(Rif: ${t.reference_range} ${t.unit || ''})` : '';
            
            rowsHtml += `\n                <tr style="background: #ffffff;">\n                    ${spannedCells}\n                    <td style="padding: 10px; border: 1px solid #cbd5e1; vertical-align: middle;"><strong>${t.test_name}</strong></td>\n                    <td style="padding: 10px; border: 1px solid #cbd5e1; min-width: 250px; vertical-align: middle;">\n                        <span style="${valStyle}">${t.result_value || '____________'}</span>\n                        <span style="font-size: 0.75rem; color: #64748b; margin-left: 8px;">${refStr}</span>\n                        ${flagBadge}\n                    </td>\n                </tr>\n            `;
        });
    });
    
    let dateFilterDesc = 'Tutti i campioni';
    if (startDateVal && endDateVal) {
        dateFilterDesc = `Periodo: dal ${startDateVal} al ${endDateVal}`;
    } else if (startDateVal) {
        dateFilterDesc = `Periodo: dal ${startDateVal}`;
    } else if (endDateVal) {
        dateFilterDesc = `Periodo: fino al ${endDateVal}`;
    }
    
    printWindow.document.write(`\n        <html>\n        <head>\n            <title>Foglio di Lavoro LIS - ${activeW.name}</title>\n            <style>\n                body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; padding: 25px; color: #1e293b; background: white; }\n                table { width: 100%; border-collapse: collapse; margin-top: 25px; }\n                th { text-align: left; padding: 12px 10px; background: #f1f5f9; border: 1px solid #cbd5e1; font-size: 0.85rem; text-transform: uppercase; color: #475569; }\n                h1 { font-size: 1.6rem; margin-bottom: 4px; color: #0f172a; }\n                p { font-size: 0.9rem; color: #64748b; margin-top: 0; }\n                @media print {\n                    body { padding: 0; }\n                    table { page-break-inside: auto; }\n                    tr { page-break-inside: avoid; page-break-after: auto; }\n                }\n            </style>\n        </head>\n        <body>\n            <div style="border-bottom: 2px solid #0f172a; padding-bottom: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: flex-end;">\n                <div>\n                    <h1>Foglio di Lavoro LIS: ${activeW.name}</h1>\n                    <p style="margin-bottom: 0;">${dateFilterDesc}</p>\n                </div>\n                <div style="text-align: right;">\n                    <p style="margin-bottom: 0; font-size: 0.8rem; color: #94a3b8;">Stampato il ${new Date().toLocaleString('it-IT')}</p>\n                </div>\n            </div>\n            <table>\n                <thead>\n                    <tr>\n                        <th style="width: 140px;">Barcode / Data</th>\n                        <th style="width: 180px;">Paziente</th>\n                        <th>Esame LIS</th>\n                        <th>Risultato / Valore Riferimento</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    ${rowsHtml}\n                </tbody>\n            </table>\n            <script>\n                window.onload = function() {\n                    window.print();\n                    window.close();\n                }\n            </script>\n        </body>\n        </html>\n    `);
    printWindow.document.close();
};

window.switchRisSubTab = function(tabName) {
    const btnExams = document.getElementById('btn-sub-ris-exams');
    const btnTsrm = document.getElementById('btn-sub-ris-tsrm');
    const btnDose = document.getElementById('btn-sub-ris-dose');
    const btnTemplates = document.getElementById('btn-sub-ris-templates');
    const contentExams = document.getElementById('sub-content-ris-exams');
    const contentTsrm = document.getElementById('sub-content-ris-tsrm');
    const contentDose = document.getElementById('sub-content-ris-dose');
    const contentTemplates = document.getElementById('sub-content-ris-templates');
    
    // Reset all
    if (btnExams) {
        btnExams.classList.remove('active');
        btnExams.style.color = 'var(--text-secondary)';
        btnExams.style.borderBottom = 'none';
    }
    if (btnTsrm) {
        btnTsrm.classList.remove('active');
        btnTsrm.style.color = 'var(--text-secondary)';
        btnTsrm.style.borderBottom = 'none';
    }
    if (btnDose) {
        btnDose.classList.remove('active');
        btnDose.style.color = 'var(--text-secondary)';
        btnDose.style.borderBottom = 'none';
    }
    if (btnTemplates) {
        btnTemplates.classList.remove('active');
        btnTemplates.style.color = 'var(--text-secondary)';
        btnTemplates.style.borderBottom = 'none';
    }
    if (contentExams) contentExams.style.display = 'none';
    if (contentTsrm) contentTsrm.style.display = 'none';
    if (contentDose) contentDose.style.display = 'none';
    if (contentTemplates) contentTemplates.style.display = 'none';

    if (tabName === 'exams') {
        if (btnExams) {
            btnExams.classList.add('active');
            btnExams.style.color = 'var(--primary)';
            btnExams.style.borderBottom = '2px solid var(--primary)';
        }
        if (contentExams) contentExams.style.display = 'block';
        window.renderRisStudies();
    } else if (tabName === 'tsrm') {
        if (btnTsrm) {
            btnTsrm.classList.add('active');
            btnTsrm.style.color = 'var(--primary)';
            btnTsrm.style.borderBottom = '2px solid var(--primary)';
        }
        if (contentTsrm) contentTsrm.style.display = 'block';
        window.renderRisTsrmView();
    } else if (tabName === 'dose') {
        if (btnDose) {
            btnDose.classList.add('active');
            btnDose.style.color = 'var(--primary)';
            btnDose.style.borderBottom = '2px solid var(--primary)';
        }
        if (contentDose) contentDose.style.display = 'block';
        window.renderRisDoseReport();
    } else if (tabName === 'templates') {
        if (btnTemplates) {
            btnTemplates.classList.add('active');
            btnTemplates.style.color = 'var(--primary)';
            btnTemplates.style.borderBottom = '2px solid var(--primary)';
        }
        if (contentTemplates) contentTemplates.style.display = 'block';
        if (typeof window.renderRisTemplatesTable === 'function') window.renderRisTemplatesTable();
    }
    if (window.lucide) window.lucide.createIcons();
};

window.renderRisDoseReport = function() {
    const studies = DB.get('radiology_studies') || [];
    const patients = DB.get('patients') || [];
    const services = DB.get('medical_services') || [];
    const doseClasses = DB.get('dose_classes') || [];
    const tbody = document.getElementById('ris-dose-tbody');
    if (!tbody) return;
    
    tbody.innerHTML = '';
    
    // Filters
    const patientQuery = (document.getElementById('dose-filter-patient')?.value || '').toLowerCase().trim();
    const classQuery = document.getElementById('dose-filter-class')?.value || '';
    const startDateVal = document.getElementById('dose-filter-start')?.value || '';
    const endDateVal = document.getElementById('dose-filter-end')?.value || '';
    
    // Filter studies
    const radStudies = studies.filter(st => {
        // Exclude visits
        if (st.study_type === 'VISIT') return false;
        
        const p = patients.find(pat => pat.id === st.patient_id);
        if (!p) return false;
        
        const srv = services.find(sv => sv.id === st.service_id);
        
        // Filter by patient
        if (patientQuery) {
            const pName = `${p.first_name} ${p.last_name}`.toLowerCase();
            const pTax = p.tax_code.toLowerCase();
            if (!pName.includes(patientQuery) && !pTax.includes(patientQuery)) {
                return false;
            }
        }
        
        // Filter by Dose Class
        if (classQuery) {
            if (classQuery === '0') {
                if (srv && srv.dose_class_id) {
                    const dc = doseClasses.find(c => c.id === srv.dose_class_id);
                    if (dc && dc.code !== '0') return false;
                } else {
                    return false; // if no class assigned, we don't assume class 0 unless explicitly none
                }
            } else {
                if (!srv || !srv.dose_class_id) return false;
                const dc = doseClasses.find(c => c.id === srv.dose_class_id);
                if (!dc || dc.code !== classQuery) return false;
            }
        }
        
        // Filter by date range
        const studyDate = st.scheduled_at ? st.scheduled_at.substring(0, 10) : '';
        if (startDateVal && studyDate < startDateVal) return false;
        if (endDateVal && studyDate > endDateVal) return false;
        
        return true;
    });
    
    // Calculate stats
    let totalDose = 0;
    let countWithDose = 0;
    radStudies.forEach(st => {
        if (st.dose_value_msv !== undefined && st.dose_value_msv !== null && st.dose_value_msv !== '') {
            const val = parseFloat(st.dose_value_msv);
            if (!isNaN(val)) {
                totalDose += val;
                countWithDose++;
            }
        }
    });
    
    const avgDose = countWithDose > 0 ? (totalDose / countWithDose) : 0;
    
    const cumEl = document.getElementById('dose-stats-cumulative');
    const avgEl = document.getElementById('dose-stats-average');
    const totEl = document.getElementById('dose-stats-total');
    
    if (cumEl) cumEl.innerText = `${totalDose.toFixed(4)} mSv`;
    if (avgEl) avgEl.innerText = `${avgDose.toFixed(4)} mSv`;
    if (totEl) totEl.innerText = countWithDose.toString();
    
    // Sort by date descending
    radStudies.sort((a, b) => new Date(b.scheduled_at) - new Date(a.scheduled_at));
    
    // Setup pagination
    const paginated = window.setupTablePagination('ris-dose-table', radStudies, () => window.renderRisDoseReport());
    
    if (radStudies.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" style="text-align: center;" class="text-muted">Nessuna esposizione trovata con i filtri selezionati</td></tr>`;
        return;
    }
    
    paginated.forEach(st => {
        const p = patients.find(pat => pat.id === st.patient_id);
        const srv = services.find(sv => sv.id === st.service_id);
        const examDate = new Date(st.scheduled_at).toLocaleString('it-IT', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        
        let age = '';
        if (p.birth_date) {
            age = `${new Date().getFullYear() - new Date(p.birth_date).getFullYear()} anni`;
        }
        
        let dcCode = 'N/A';
        let dcDesc = 'Classe di dose non assegnata';
        let dcBadgeClass = 'badge-secondary';
        
        if (srv && srv.dose_class_id) {
            const dc = doseClasses.find(c => c.id === srv.dose_class_id);
            if (dc) {
                dcCode = `Classe ${dc.code}`;
                dcDesc = `${dc.range_msv} - ${dc.description}`;
                if (dc.code === '0') dcBadgeClass = 'badge-secondary';
                else if (dc.code === 'I') dcBadgeClass = 'badge-info';
                else if (dc.code === 'II') dcBadgeClass = 'badge-warning';
                else if (dc.code === 'III') dcBadgeClass = 'badge-danger';
                else if (dc.code === 'IV') dcBadgeClass = 'badge-danger';
            }
        }
        
        const doseVal = st.dose_value_msv !== undefined && st.dose_value_msv !== null ? st.dose_value_msv : '';
        
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><strong>${p.last_name.toUpperCase()} ${p.first_name}</strong><br><span style="font-size: 0.72rem; color: var(--text-secondary);">${p.tax_code}</span></td>
            <td>${p.gender} / ${age}</td>
            <td>${examDate}</td>
            <td><span class="badge badge-success">${srv ? srv.name : st.study_type}</span></td>
            <td><span class="badge ${dcBadgeClass}" title="${dcDesc}">${dcCode}</span></td>
            <td>
                <div style="display: flex; gap: 6px; align-items: center;">
                    <input type="number" step="0.0001" min="0" value="${doseVal}" id="inline-dose-input-${st.id}" style="width: 90px; padding: 4px 8px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 0.8rem;" placeholder="mSv">
                    <button class="btn btn-primary btn-sm" onclick="window.updateStudyDoseInline(${st.id})" style="padding: 4px 8px;" title="Salva"><i data-lucide="check" style="width: 12px; height: 12px;"></i></button>
                </div>
            </td>
            <td>
                <button class="btn btn-secondary btn-sm" onclick="openRisReportView(${st.id})" ${st.status !== 'completed' ? 'disabled' : ''} style="display: inline-flex; align-items: center; gap: 4px;"><i data-lucide="file-text" style="width: 12px; height: 12px;"></i> Referto</button>
            </td>
        `;
        tbody.appendChild(tr);
    });
    if (window.lucide) window.lucide.createIcons();
};

window.updateStudyDoseInline = function(studyId) {
    const input = document.getElementById(`inline-dose-input-${studyId}`);
    if (!input) return;
    
    let val = input.value.trim();
    let parsedVal = null;
    if (val !== '') {
        parsedVal = parseFloat(val);
        if (isNaN(parsedVal) || parsedVal < 0) {
            alert("Inserire un valore numerico valido e maggiore o uguale a 0 per la dose.");
            return;
        }
    }
    
    DB.update('radiology_studies', studyId, { dose_value_msv: parsedVal });
    
    // Log Audit
    const userRole = document.getElementById('user-role-select')?.value || 'admin';
    DB.logAudit(1, "RIS_DOSE_UPDATE_INLINE", "radiology_studies", studyId, { dose_value_msv: parsedVal, updated_by_role: userRole });
    
    // Re-render
    window.renderRisDoseReport();
    
    // Show alert
    alert("Dose salvata correttamente e sincronizzata.");
};

window.renderRisTsrmView = function() {
    const tbody = document.getElementById('ris-tsrm-tbody');
    if (!tbody) return;

    const studies = DB.get('radiology_studies') || [];
    const patients = DB.get('patients') || [];
    const services = DB.get('medical_services') || [];
    const staff = DB.get('staff') || [];
    
    const query = (document.getElementById('ris-tsrm-search')?.value || '').toLowerCase().trim();
    const statusFilter = document.getElementById('ris-tsrm-status-filter')?.value || 'all';

    const filtered = studies.filter(st => {
        if (st.study_type === 'VISIT') return false; // Visits don't require TSRM execution
        
        const p = patients.find(pat => pat.id === st.patient_id);
        const srv = services.find(s => s.id === st.service_id);
        
        // Status filtering
        if (statusFilter !== 'all' && st.status !== statusFilter) return false;
        
        // Search filtering
        if (query) {
            const pName = p ? `${p.first_name} ${p.last_name}`.toLowerCase() : '';
            const sName = srv ? srv.name.toLowerCase() : '';
            if (!pName.includes(query) && !sName.includes(query)) return false;
        }
        return true;
    });

    tbody.innerHTML = '';

    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: var(--text-secondary); padding: 20px;">Nessuno studio radiologico in attesa per i filtri selezionati.</td></tr>';
        return;
    }

    // Sort studies newest first
    filtered.sort((a, b) => new Date(b.scheduled_at) - new Date(a.scheduled_at));

    filtered.forEach(st => {
        const p = patients.find(pat => pat.id === st.patient_id) || {};
        const srv = services.find(s => s.id === st.service_id) || {};
        const tsrmStaff = staff.find(s => s.id === st.tsrm_id) || {};
        
        const pName = `${p.last_name} ${p.first_name}`;
        const tsrmName = tsrmStaff.last_name ? `${tsrmStaff.first_name} ${tsrmStaff.last_name}` : 'Non assegnato';
        const formattedDate = new Date(st.scheduled_at).toLocaleString('it-IT', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });

        let statusBadge = '';
        let actionBtn = '';

        if (st.status === 'scheduled') {
            statusBadge = '<span class="badge badge-warning" style="background-color: #eab308; color: #fff;">Attesa Erogazione</span>';
            actionBtn = `<button class="btn btn-primary btn-sm" onclick="window.erogaRisStudy(${st.id})">Eroga Studio</button> <button class="btn btn-secondary btn-sm" onclick="window.addClinicalQuery(${st.id})" style="margin-left: 4px;"><i data-lucide="edit" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 2px;"></i> Quesito</button>`;
        } else if (st.status === 'executed') {
            statusBadge = '<span class="badge badge-info" style="background-color: #06b6d4; color: #fff;">Erogato</span>';
            actionBtn = '<span class="text-success" style="font-size: 0.8rem; font-weight: bold;"><i data-lucide="check" style="width: 14px; height: 14px; display: inline-block; vertical-align: middle; margin-right: 2px;"></i> Erogato</span>';
        } else if (st.status === 'in_progress') {
            statusBadge = '<span class="badge badge-warning">In Esecuzione</span>';
            actionBtn = '<span class="text-success" style="font-size: 0.8rem; font-weight: bold;"><i data-lucide="check" style="width: 14px; height: 14px; display: inline-block; vertical-align: middle; margin-right: 2px;"></i> Erogato</span>';
        } else if (st.status === 'completed') {
            statusBadge = '<span class="badge badge-success">Refertato</span>';
            actionBtn = '<span class="text-muted" style="font-size: 0.8rem;">Refertato</span>';
        }

        actionBtn += ` <button class="btn btn-secondary btn-sm" onclick="window.printRisBarcodeLabel(${st.id})" title="Stampa Barcode Cartellina" style="margin-left: 2px;"><i data-lucide="barcode" style="width: 12px; height: 12px; vertical-align: middle; margin-right: 4px;"></i> Barcode</button>`;

        const tr = document.createElement('tr');
        tr.innerHTML = `\n            <td><strong>${pName}</strong></td>\n            <td><span class="badge badge-success">${srv.name || 'Studio Radiologico'}</span></td>\n            <td>${tsrmName}</td>\n            <td>${formattedDate}</td>\n            <td>${statusBadge}</td>\n            <td><div class="row-actions">${actionBtn}</div></td>\n        `;
        tbody.appendChild(tr);
    });

    if (window.lucide) window.lucide.createIcons();
};

window.erogaRisStudy = function(studyId) {
    if (!confirm("Confermi l'erogazione di questo studio radiologico? Le immagini DICOM verranno caricate e inviate al radiologo.")) return;

    DB.update('radiology_studies', studyId, { status: 'executed' });
    DB.logAudit(6, "EROGA_RIS_STUDY", "radiology_studies", studyId, { status: 'executed' });

    window.renderRisStudies();
    window.renderRisTsrmView();
    
    alert("Studio radiologico erogato con successo! Le immagini sono state trasmesse ed è ora pronto per la refertazione medica.");
};

window.addClinicalQuery = function(studyId) {
    const studies = DB.get('radiology_studies') || [];
    const study = studies.find(s => s.id === studyId);
    if (!study) return;
    
    document.getElementById('clinical-query-study-id').value = studyId;
    document.getElementById('clinical-query-rich-editor').innerHTML = study.clinical_query || '';
    
    const fileInfo = document.getElementById('clinical-query-file-info');
    const removeBtn = document.getElementById('btn-remove-clinical-query-file');
    const fileInput = document.getElementById('clinical-query-file-input');
    
    fileInput.value = '';
    
    if (study.attachment_name) {
        fileInfo.innerText = study.attachment_name;
        removeBtn.style.display = 'inline-block';
        fileInput.dataset.fileName = study.attachment_name;
        fileInput.dataset.fileData = study.attachment_data;
    } else {
        fileInfo.innerText = "Nessun file allegato";
        removeBtn.style.display = 'none';
        fileInput.dataset.fileName = '';
        fileInput.dataset.fileData = '';
    }
    
    openModal('modal-clinical-query');
    if (window.lucide) window.lucide.createIcons();
};

window.handleClinicalQueryFileUpload = function(input) {
    const file = input.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = function(e) {
        input.dataset.fileName = file.name;
        input.dataset.fileData = e.target.result;
        
        document.getElementById('clinical-query-file-info').innerText = file.name;
        document.getElementById('btn-remove-clinical-query-file').style.display = 'inline-block';
    };
    reader.readAsDataURL(file);
};

window.clearClinicalQueryFile = function() {
    const fileInput = document.getElementById('clinical-query-file-input');
    fileInput.value = '';
    fileInput.dataset.fileName = '';
    fileInput.dataset.fileData = '';
    
    document.getElementById('clinical-query-file-info').innerText = "Nessun file allegato";
    document.getElementById('btn-remove-clinical-query-file').style.display = 'none';
};

window.saveClinicalQueryModal = function() {
    const studyId = parseInt(document.getElementById('clinical-query-study-id').value);
    const textContent = document.getElementById('clinical-query-rich-editor').innerHTML.trim();
    
    const fileInput = document.getElementById('clinical-query-file-input');
    const attachmentName = fileInput.dataset.fileName || null;
    const attachmentData = fileInput.dataset.fileData || null;
    
    DB.update('radiology_studies', studyId, {
        clinical_query: textContent,
        attachment_name: attachmentName,
        attachment_data: attachmentData
    });
    
    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const staffId = loggedUser.id || 6;
    DB.logAudit(staffId, "ADD_CLINICAL_QUERY", "radiology_studies", studyId, {
        clinical_query: textContent,
        attachment_name: attachmentName
    });
    
    closeModal('modal-clinical-query');
    window.renderRisTsrmView();
    alert("Quesito diagnostico e allegato salvati con successo!");
};

window.prelevaSample = async function(sampleId, forceSessionBulk = false) {
    const loggedUser = JSON.parse(localStorage.getItem('nextcare_logged_in_user') || '{}');
    const staffId = loggedUser.id || 4;
    
    const samples = DB.get('lab_samples') || [];
    const targetSam = samples.find(s => s.id === sampleId);
    if (!targetSam) return;
    
    const sessionUid = targetSam.session_uid;
    const sameSessionSamples = sessionUid 
        ? samples.filter(s => s.session_uid === sessionUid && s.status === 'da prelevare') 
        : [];
        
    let toCollect = [targetSam];
    let bulkMsg = "";
    
    if (!forceSessionBulk && sameSessionSamples.length > 1) {
        const choice = confirm(`Questo campione fa parte di una sessione con altri ${sameSessionSamples.length - 1} campioni da prelevare.\nVuoi prelevare TUTTI i campioni di questa sessione insieme?\n\n[OK] per prelevarli TUTTI\n[Annulla] per prelevare solo questo singolo campione.`);
        if (choice) {
            toCollect = sameSessionSamples;
            bulkMsg = " (Sessione Intera)";
        }
    } else if (forceSessionBulk && sameSessionSamples.length > 0) {
        toCollect = sameSessionSamples;
    }
    
    for (const sam of toCollect) {
        DB.update('lab_samples', sam.id, {
            collected_at: new Date().toISOString(),
            collected_by: staffId,
            status: 'collected'
        });
        DB.logAudit(staffId, "PRELEVA_LIS_SAMPLE", "lab_samples", sam.id, { collected_at: new Date().toISOString() });
    }
    
    await DB.waitForSync();
    
    if (typeof loadActiveTab === 'function') {
        loadActiveTab();
    }
    alert(`Prelievo effettuato con successo per ${toCollect.length} campione/i${bulkMsg}!`);
};

window.resolveDoctorFromName = function(docNameStr) {
    if (!docNameStr) return { doctor_id: null, requesting_doctor: null };
    const doctors = DB.get('doctors') || [];
    const staff = DB.get('staff') || [];
    
    // Check if the typed string matches an internal doctor's name
    const matchedDoc = doctors.find(d => {
        const s = staff.find(st => st.id === d.staff_id);
        if (!s) return false;
        const prefix = s.first_name.trim().endsWith('a') ? "Dott.ssa" : "Dott.";
        const fullName = `${prefix} ${s.first_name} ${s.last_name}`.toLowerCase();
        const shortName = `${s.first_name} ${s.last_name}`.toLowerCase();
        const typedLower = docNameStr.trim().toLowerCase();
        return fullName === typedLower || shortName === typedLower;
    });

    if (matchedDoc) {
        return { doctor_id: matchedDoc.id, requesting_doctor: null };
    } else {
        return { doctor_id: null, requesting_doctor: docNameStr.trim() };
    }
};

window.populateRequesterDatalist = function() {
    const datalist = document.getElementById('requester-doctors-list');
    if (!datalist) return;

    datalist.innerHTML = '';
    
    // Add internal doctors
    const doctors = DB.get('doctors') || [];
    const staff = DB.get('staff') || [];
    doctors.forEach(d => {
        const s = staff.find(st => st.id === d.staff_id);
        if (s) {
            const prefix = s.first_name.trim().endsWith('a') ? "Dott.ssa" : "Dott.";
            const opt = document.createElement('option');
            opt.value = `${prefix} ${s.first_name} ${s.last_name}`;
            datalist.appendChild(opt);
        }
    });

    // Add unique external doctors from existing records
    const uniqueExternals = new Set();
    const studies = DB.get('radiology_studies') || [];
    const samples = DB.get('lab_samples') || [];
    const apps = DB.get('appointments') || [];

    studies.forEach(s => { if (s.requesting_doctor) uniqueExternals.add(s.requesting_doctor); });
    samples.forEach(s => { if (s.requesting_doctor) uniqueExternals.add(s.requesting_doctor); });
    apps.forEach(a => { if (a.requesting_doctor) uniqueExternals.add(a.requesting_doctor); });

    uniqueExternals.forEach(name => {
        const opt = document.createElement('option');
        opt.value = name;
        datalist.appendChild(opt);
    });
};

// --- NATURAL LANGUAGE SEARCH & CHIPS ---

window.parseNaturalLanguageQuery = function(query, context) {
    if (!query) return null;
    const q = query.toLowerCase().trim();
    const result = {
        status: null,
        startDate: null,
        endDate: null,
        doctorName: null,
        serviceType: null,
        textQuery: '',
        isOutRange: false
    };

    const now = new Date();
    if (q.includes('oggi')) {
        const todayStr = now.toISOString().substring(0, 10);
        result.startDate = todayStr;
        result.endDate = todayStr;
    } else if (q.includes('ieri')) {
        const yesterday = new Date();
        yesterday.setDate(now.getDate() - 1);
        const yestStr = yesterday.toISOString().substring(0, 10);
        result.startDate = yestStr;
        result.endDate = yestStr;
    } else if (q.includes('questo mese')) {
        const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        const endOfMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0);
        result.startDate = startOfMonth.toISOString().substring(0, 10);
        result.endDate = endOfMonth.toISOString().substring(0, 10);
    } else if (q.includes('giugno')) {
        result.startDate = '2026-06-01';
        result.endDate = '2026-06-30';
    } else if (q.includes('maggio')) {
        result.startDate = '2026-05-01';
        result.endDate = '2026-05-31';
    } else if (q.includes('gennaio')) {
        result.startDate = '2026-01-01';
        result.endDate = '2026-01-31';
    }

    const rangeMatch = q.match(/da[l]?\s+([0-9]{4}-[0-9]{2}-[0-9]{2})(?:\s+a[l]?\s+([0-9]{4}-[0-9]{2}-[0-9]{2}))?/);
    if (rangeMatch) {
        result.startDate = rangeMatch[1];
        if (rangeMatch[2]) {
            result.endDate = rangeMatch[2];
        }
    }

    if (q.includes('pianificat') || q.includes('attive') || q.includes('attivo') || q.includes('da prelevare') || q.includes('scheduled')) {
        result.status = 'scheduled';
    } else if (q.includes('completat') || q.includes('refertat') || q.includes('pagat') || q.includes('paid')) {
        result.status = 'completed';
    } else if (q.includes('annullat') || q.includes('disdett') || q.includes('cancelled')) {
        result.status = 'cancelled';
    } else if (q.includes('non pagat') || q.includes('sospes') || q.includes('insoluto') || q.includes('unpaid')) {
        result.status = 'unpaid';
    } else if (q.includes('in lavorazione') || q.includes('in corso') || q.includes('processing')) {
        result.status = 'in_progress';
    }

    if (q.includes('rossi')) result.doctorName = 'rossi';
    else if (q.includes('bianchi')) result.doctorName = 'bianchi';
    else if (q.includes('verdi')) result.doctorName = 'verdi';

    if (q.includes('visita') || q.includes('visite')) result.serviceType = 'visita';
    else if (q.includes('lis') || q.includes('laboratorio') || q.includes('sangue') || q.includes('prelievo')) result.serviceType = 'lis';
    else if (q.includes('ris') || q.includes('radiologia') || q.includes('mri') || q.includes('rx')) result.serviceType = 'ris';

    if (q.includes('fuori norma') || q.includes('fuori range') || q.includes('anomalo') || q.includes('anomali')) {
        result.isOutRange = true;
    }

    let text = q;
    const keywords = [
        'oggi', 'ieri', 'questo mese', 'giugno', 'maggio', 'gennaio',
        'pianificat', 'attive', 'attivo', 'da prelevare', 'scheduled',
        'completat', 'refertat', 'pagat', 'paid', 'annullat', 'disdett', 'cancelled',
        'non pagat', 'sospes', 'insoluto', 'unpaid', 'in lavorazione', 'in corso', 'processing',
        'rossi', 'bianchi', 'verdi', 'visita', 'visite', 'lis', 'laboratorio', 'sangue', 'prelievo',
        'ris', 'radiologia', 'mri', 'rx', 'mostra', 'cerca', 'trova', 'filtra', 'di', 'del', 'da', 'dal', 'a', 'al',
        'fuori norma', 'fuori range', 'anomalo', 'anomali', 'prenotazione', 'prenotazioni',
        'accettazione', 'accettazioni', 'ricovero', 'ricoveri', 'fattura', 'fatture', 'esame', 'esami',
        'campione', 'campioni', 'medico', 'medici', 'dottore', 'dottor', 'dott', 'studio', 'studi',
        'paziente', 'pazienti', 'degenti', 'degente', 'tutte', 'tutti'
    ];
    keywords.forEach(kw => {
        text = text.replace(new RegExp('\\b' + kw + '[a-z]*\\b', 'g'), '');
    });
    result.textQuery = text.replace(/\s+/g, ' ').trim();

    return result;
};

